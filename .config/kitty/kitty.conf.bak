# /* ---- 💫 https://github.com/LinuxBeginnings 💫 ---- */  #

# you can choose themes from $HOME/.config/kitty/kitty-themes/
# ===================================================================
# 🎨 THEME & COLORS
# ===================================================================
include kitty-color.conf

# ===================================================================
# 📑 TABS (Powerline Style)
# ===================================================================tab_bar_edge bottom
tab_bar_margin_width 0.0
tab_bar_margin_height 0.0 0.0
tab_bar_style powerline
tab_bar_align left
tab_bar_min_tabs 1
tab_switch_strategy previous
tab_fade 0.25 0.5 0.75 1
tab_separator " ┇"
tab_powerline_style slanted
tab_activity_symbol ⚡
tab_title_template          {title}{' :{}:'.format(num_windows) if num_windows > 1 else ''}
active_tab_title_template none
active_tab_font_style   bold
inactive_tab_font_style normal

# ===================================================================
# 🖥️  FONTS
# ===================================================================font_family      auto
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size		 12

# Fix for "cursor_blink" error:
# 0 = off, 0.5 = standard blink. Set to 0 if you prefer a static cursor.
cursor_blink_interval 0.5

# Makes the underline cursor 10 pixels thick (adjust to taste)
cursor_underline_thickness 4.0

# Stop blinking after 15 seconds to save resources/reduce distraction
cursor_stop_blinking_after 2.0

# 🚀 CURSOR TRAIL (The "Neovide" effect)
# Your Intel 12700H handles this easily.
cursor_trail 10
# Optimized decay for high refresh rate screens (smoother fade)
cursor_trail_decay 0.15 0.4
cursor_trail_start_threshold 2

# Shell integration configuration
shell_integration no-cursor


# ===================================================================
# 🖼️  WINDOW & AESTHETICS (Hyprland Focused)
# ===================================================================
# Hide the default title bar (Hyprland handles borders)
hide_window_decorations yes

# internal padding keeps text away from the border (cleaner look)
 window_padding_width 10

# 🔮 Transparency & Blur
# Note: 'background_opacity' works best if your generated colors file 
# doesn't force a solid background color code.
 background_opacity 0.90
 background_blur 15

# Do not ask for confirmation when closing a window (as requested)
confirm_os_window_close 0

# ===================================================================
# ⚡ PERFORMANCE (Intel 12700H)
# ===================================================================
# refresh rate synchronization (prevents tearing)
 sync_to_monitor yes

# Input latency optimization
input_delay 3


# Enable ligatures (e.g., => turns into an arrow)
disable_ligatures never

background_opacity 0.9
dynamic_background_opacity 1
#confirm_os_window_close 0

#selection_foreground none
#selection_background none
#foreground #dddddd
#background #000000
# cursor #dddddd

# Keybindings
kitty_mod ctrl+shift

# Others
map kitty_mod+e launch --type=background --cwd=current sh -c 'hyprctl dispatch exec "[float; size 60% 60%; center 1] xdg-open" $(pwd)'
map kitty_mod+u launch --type=background --cwd=current sh -c 'vscodium $(pwd)'
map kitty_mod+y launch --type=overlay-main --cwd=current yazi

map kitty_mod+f5 load_config_file

# BEGIN_KITTY_THEME
# Catppuccin-Mocha
include current-theme.conf
# END_KITTY_THEME
