# ──────────────────────────────────────────
# PREFIX & RELOAD
# ──────────────────────────────────────────
set -g prefix C-Space
set -g prefix2 C-b
bind C-Space send-prefix
bind q source-file ~/.config/tmux/tmux.conf

# ──────────────────────────────────────────
# NAVIGATION - Panes
# ──────────────────────────────────────────
bind h split-window -v -c "#{pane_current_path}"
bind v split-window -h -c "#{pane_current_path}"
bind x kill-pane

bind -n C-M-Left select-pane -L
bind -n C-M-Right select-pane -R
bind -n C-M-Up select-pane -U
bind -n C-M-Down select-pane -D

# ──────────────────────────────────────────
# NAVIGATION - Windows
# ──────────────────────────────────────────
bind c new-window -c "#{pane_current_path}"
bind k kill-window
bind r command-prompt -I "#W" "rename-window -- '%%'"

bind -n M-1 select-window -t 1
bind -n M-2 select-window -t 2
bind -n M-3 select-window -t 3
bind -n M-4 select-window -t 4
bind -n M-5 select-window -t 5
bind -n M-6 select-window -t 6
bind -n M-7 select-window -t 7
bind -n M-8 select-window -t 8
bind -n M-9 select-window -t 9

bind -n M-Left select-window -t -1
bind -n M-Right select-window -t +1

# ──────────────────────────────────────────
# NAVIGATION - Sessions
# ──────────────────────────────────────────
bind C new-session -c "#{pane_current_path}"
bind K kill-session
bind R command-prompt -I "#S" "rename-session -- '%%'"
bind P switch-client -p
bind N switch-client -n

# ──────────────────────────────────────────
# VI MODE
# ──────────────────────────────────────────
setw -g mode-keys vi
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-selection-and-cancel

# ──────────────────────────────────────────
# GENERAL
# ──────────────────────────────────────────
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",*:RGB"
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g history-limit 50000
set -g escape-time 0
set -g focus-events on
set -g set-clipboard on
set -g allow-passthrough on
setw -g aggressive-resize on
set -g detach-on-destroy off

# ──────────────────────────────────────────
# STATUS BAR
# ──────────────────────────────────────────
set -g status-position top
set -g status-interval 5
set -g status-left ""
set -g status-right "#[fg=colour244]%H:%M %d/%m"
set -g status-style "bg=colour235,fg=colour223"
set -g window-status-format "#[fg=colour240] #I:#W "
set -g window-status-current-format "#[fg=colour223,bold] #I:#W "
set -gw automatic-rename on
set -gw automatic-rename-format '#{b:pane_current_path}'
set -gF status-format[0] "#{T;=/#{status-right-length}:status-right}"

# Pane borders
set -g pane-border-style "fg=colour240"
set -g pane-active-border-style "fg=colour240"

# Override plugins
set -g @_powerkit_left_edge_sep ""
