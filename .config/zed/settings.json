// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "project_panel": {
        "dock": "right",
        "default_width": 400,
        "auto_fold_dirs": false,
        "starts_open": false,
        "git_status": true,
        "sticky_scroll": false,
        "button": true,
    },
    "status_bar": {
        "experimental.show": false,
    },
    "tabs": {
        "file_icons": true,
        "git_status": false,
    },
    "tab_bar": {
        "show_pinned_tabs_in_separate_row": false,
        "show": true,
    },
    "toolbar": {
        "quick_actions": false,
    },
    "scrollbar": {
        "show": "never",
    },
    "gutter": {
        "min_line_number_digits": 0,
        "folds": false,
        "runnables": false,
    },
    "indent_guides": {
        "enabled": true,
    },
    "outline_panel": {
        "default_width": 300,
        "indent_guides": {
            "show": "never",
        },
    },
    "icon_theme": {
        "mode": "system",
        "light": "Zed (Default)",
        "dark": "Soft Charmed Icons",
    },
    "terminal": {
        "font_size": 14.0,
    },
    "base_keymap": "VSCode",
    "minimap": {
        "show": "never",
    },
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    "auto_update": false,
    "extend_comment_on_newline": false,
    "horizontal_scroll_margin": 1,
    "vertical_scroll_margin": 1,
    "when_closing_with_no_tabs": "keep_window_open",
    "close_on_file_delete": true,
    "restore_on_file_reopen": false,
    "restore_on_startup": "empty_tab",
    "session": {
        "restore_unsaved_buffers": false,
    },
    "git": {
        "git_gutter": "hide",
        "inline_blame": {
            "enabled": false,
        },
    },
    "centered_layout": {
        "right_padding": 0.15,
        "left_padding": 0.15
    },
    "confirm_quit": false,
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "show_whitespaces": "selection",
    "soft_wrap": "editor_width",
    "tab_size": 4,
    "ui_font_size": 16,
    "buffer_font_size": 14.0,
    "buffer_line_height": {
        "custom": 2,
    },
    "agent_ui_font_size": 16,
    "agent_buffer_font_size": 14.0,
    "theme": "Omarchy",
},
"title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_name": false,
},
"tab_size": 2,
"auto_indent": false,
"auto_indent_on_paste": false,
"show_completions_on_input": true,
"show_completion_documentation": false,
"inline_code_actions": false,
"lsp_document_color": true,
}
