#!/usr/bin/env bash
# wayflipper - Waybar theme switcher for Omarchy
# Expected structure: themes_dir/<theme-name>/{config.jsonc,style.css}

set -euo pipefail

VERSION="0.2.3"
CONFIG_FILE="${HOME}/.wayflipper"
WAYBAR_DIR="${HOME}/.config/waybar"
DEFAULT_THEMES_DIR="${HOME}/.config/waybar/themes"
THEMES_DIR="${DEFAULT_THEMES_DIR}"
ACTIVE_CONFIG="${WAYBAR_DIR}/config.jsonc"
ACTIVE_STYLE="${WAYBAR_DIR}/style.css"
STATE_FILE="${WAYBAR_DIR}/.wayflipper-links"

DRY_RUN=false
LIST_ONLY=false
BROWSE=false
BROWSE_ONCE=false
THEME=""

usage() {
  cat <<'EOF'
Usage: wayflipper <theme-name> [--dry-run]
       wayflipper --list
       wayflipper --version
       wayflipper --help
       wayflipper --browse [--dry-run] [--browse-once]

Options:
  -l, --list      List available themes in themes_dir (default ~/.config/waybar/themes)
  -b, --browse    Interactive selector for themes (fzf stays open after applying; Ctrl-Q quits)
  --browse-once   Exit after applying a selection in browse mode
  --dry-run       Show actions without modifying files
  -v, --version   Show version and exit
  -h, --help      Show this help message
EOF
}

write_default_config() {
  cat >"${CONFIG_FILE}" <<EOF
# wayflipper configuration
themes_dir=${DEFAULT_THEMES_DIR}
EOF
}

ensure_config() {
  if [ -f "${CONFIG_FILE}" ]; then
    return 0
  fi

  if [ "${DRY_RUN}" = true ]; then
    printf 'Would create config file: %s\n' "${CONFIG_FILE}"
    return 0
  fi

  write_default_config
}

load_config() {
  THEMES_DIR="${DEFAULT_THEMES_DIR}"

  if [ -f "${CONFIG_FILE}" ]; then
    local line key value
    while IFS= read -r line; do
      case "${line}" in
        ""|\#*) continue ;;
      esac
      if [[ "${line}" != *=* ]]; then
        continue
      fi
      key="${line%%=*}"
      value="${line#*=}"
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"
      case "${key}" in
        themes_dir)
          if [ -n "${value}" ]; then
            case ${value} in
              \~)
                value="${HOME}"
                ;;
              \~/*)
                value="${HOME}/${value#~/}"
                ;;
            esac
            THEMES_DIR="${value}"
          fi
          ;;
      esac
    done <"${CONFIG_FILE}"
  fi

  if [ -n "${WAYFLIPPER_THEMES_DIR:-}" ]; then
    THEMES_DIR="${WAYFLIPPER_THEMES_DIR}"
  fi
}

list_themes() {
  if [ ! -d "${THEMES_DIR}" ]; then
    printf 'No themes directory found at %s\n' "${THEMES_DIR}" >&2
    exit 1
  fi

  local found=false
  for dir in "${THEMES_DIR}"/*; do
    [ -d "${dir}" ] || continue
    if [ -f "${dir}/config.jsonc" ] && [ -f "${dir}/style.css" ]; then
      printf '%s\n' "$(basename "${dir}")"
      found=true
    fi
  done

  if [ "${found}" = false ]; then
    printf 'No valid themes (config.jsonc and style.css) found in %s\n' "${THEMES_DIR}" >&2
    exit 1
  fi
}

browse_themes() {
  local last_selection="${1:-}"
  if [ ! -d "${THEMES_DIR}" ]; then
    printf 'No themes directory found at %s\n' "${THEMES_DIR}" >&2
    exit 1
  fi

  local themes=()
  local dir
  for dir in "${THEMES_DIR}"/*; do
    [ -d "${dir}" ] || continue
    if [ -f "${dir}/config.jsonc" ] && [ -f "${dir}/style.css" ]; then
      themes+=("$(basename "${dir}")")
    fi
  done

  if [ "${#themes[@]}" -eq 0 ]; then
    printf 'No valid themes (config.jsonc and style.css) found in %s\n' "${THEMES_DIR}" >&2
    exit 1
  fi

  local selection=""
  if command -v fzf >/dev/null 2>&1; then
    local pos_found=""
    if [ -n "${last_selection}" ]; then
      local pos=1
      local theme
      for theme in "${themes[@]}"; do
        if [ "${theme}" = "${last_selection}" ]; then
          pos_found="${pos}"
          break
        fi
        pos=$((pos + 1))
      done
    fi
    local preview_cmd
    preview_cmd=$(cat <<EOF
bash -c '
theme_dir="${THEMES_DIR}/{}"
image=""
for img in "\${theme_dir}"/*.png "\${theme_dir}"/*.PNG; do
  [ -e "\${img}" ] || continue
  image="\${img}"
  break
done
preview_cols="\${FZF_PREVIEW_COLUMNS:-80}"
preview_lines="\${FZF_PREVIEW_LINES:-20}"
image_lines=\$((preview_lines * 40 / 100))
if [ "\${image_lines}" -lt 6 ]; then
  image_lines=6
fi
if [ -n "\${image}" ]; then
  pad_lines=0
  if command -v chafa >/dev/null 2>&1; then
    chafa -f symbols -s "\${preview_cols}x\${image_lines}" "\${image}"
    pad_lines=0
  elif command -v kitty >/dev/null 2>&1 && [ -n "\${KITTY_WINDOW_ID:-}" ]; then
    kitty +kitten icat --clear --transfer-mode=stream --stdin=no \
      --place="\${preview_cols}x\${image_lines}@0x0" --scale-up "\${image}"
    pad_lines=\${image_lines}
  else
    printf "Image preview requires chafa or kitty: %s\n" "\${image}"
    pad_lines=1
  fi
  if [ "\${pad_lines}" -gt 0 ]; then
    i=0
    while [ "\${i}" -lt "\${pad_lines}" ]; do
      printf "\n"
      i=\$((i + 1))
    done
  fi
else
  if command -v kitty >/dev/null 2>&1 && [ -n "\${KITTY_WINDOW_ID:-}" ]; then
    kitty +kitten icat --clear --transfer-mode=stream --stdin=no
  fi
  printf "No preview image found in %s\n" "\${theme_dir}"
fi
printf "\n---\n"
printf "Theme: %s\n\n" "{}"
printf "=== config.jsonc ===\n"
if command -v bat >/dev/null 2>&1; then
  bat --paging=never --color=always --style=plain --language json \
    --line-range 1:120 "\${theme_dir}/config.jsonc"
else
  sed -n "1,120p" "\${theme_dir}/config.jsonc"
fi
printf "\n=== style.css ===\n"
if command -v bat >/dev/null 2>&1; then
  bat --paging=never --color=always --style=plain --language css \
    --line-range 1:120 "\${theme_dir}/style.css"
else
  sed -n "1,120p" "\${theme_dir}/style.css"
fi
'
EOF
)
    if [ -n "${pos_found}" ]; then
      fzf_bind="ctrl-q:abort,result:pos(${pos_found})"
    else
      fzf_bind="ctrl-q:abort"
    fi
    if ! selection="$(printf '%s\n' "${themes[@]}" | fzf --ansi --sync --prompt='Select Waybar theme (Ctrl-Q to quit): ' --cycle --reverse --bind "${fzf_bind}" --border --border-label="Wayflipper v${VERSION}" --preview="${preview_cmd}" --preview-window='right:75%:wrap:border')"; then
      return 1
    fi
  else
    printf 'fzf not found; using numbered selection (press q to quit).\n' >&2
    while true; do
      select sel in "${themes[@]}"; do
        if [[ "${REPLY:-}" =~ ^[qQ]$ ]]; then
          return 1
        fi
        if [ -n "${sel:-}" ]; then
          selection="${sel}"
          break 2
        fi
        printf 'Invalid selection. Try again or press q to quit.\n' >&2
        break
      done
    done
  fi

  if [ -z "${selection}" ]; then
    printf 'No theme selected; exiting browse.\n' >&2
    return 1
  fi

  THEME="${selection}"
  return 0
}

browse_themes_live() {
  if [ ! -d "${THEMES_DIR}" ]; then
    printf 'No themes directory found at %s\n' "${THEMES_DIR}" >&2
    exit 1
  fi

  local themes=()
  local dir
  for dir in "${THEMES_DIR}"/*; do
    [ -d "${dir}" ] || continue
    if [ -f "${dir}/config.jsonc" ] && [ -f "${dir}/style.css" ]; then
      themes+=("$(basename "${dir}")")
    fi
  done

  if [ "${#themes[@]}" -eq 0 ]; then
    printf 'No valid themes (config.jsonc and style.css) found in %s\n' "${THEMES_DIR}" >&2
    exit 1
  fi

  if ! command -v fzf >/dev/null 2>&1; then
    printf 'fzf not found; using numbered selection (press q to quit).\n' >&2
    return 1
  fi

  local preview_cmd
  preview_cmd=$(cat <<EOF
bash -c '
theme_dir="${THEMES_DIR}/{}"
image=""
for img in "\${theme_dir}"/*.png "\${theme_dir}"/*.PNG; do
  [ -e "\${img}" ] || continue
  image="\${img}"
  break
done
preview_cols="\${FZF_PREVIEW_COLUMNS:-80}"
preview_lines="\${FZF_PREVIEW_LINES:-20}"
image_lines=\$((preview_lines * 40 / 100))
if [ "\${image_lines}" -lt 6 ]; then
  image_lines=6
fi
if [ -n "\${image}" ]; then
  pad_lines=0
  if command -v chafa >/dev/null 2>&1; then
    chafa -f symbols -s "\${preview_cols}x\${image_lines}" "\${image}"
    pad_lines=0
  elif command -v kitty >/dev/null 2>&1 && [ -n "\${KITTY_WINDOW_ID:-}" ]; then
    kitty +kitten icat --clear --transfer-mode=stream --stdin=no \
      --place="\${preview_cols}x\${image_lines}@0x0" --scale-up "\${image}"
    pad_lines=\${image_lines}
  else
    printf "Image preview requires chafa or kitty: %s\n" "\${image}"
    pad_lines=1
  fi
  if [ "\${pad_lines}" -gt 0 ]; then
    i=0
    while [ "\${i}" -lt "\${pad_lines}" ]; do
      printf "\n"
      i=\$((i + 1))
    done
  fi
else
  if command -v kitty >/dev/null 2>&1 && [ -n "\${KITTY_WINDOW_ID:-}" ]; then
    kitty +kitten icat --clear --transfer-mode=stream --stdin=no
  fi
  printf "No preview image found in %s\n" "\${theme_dir}"
fi
printf "\n---\n"
printf "Theme: %s\n\n" "{}"
printf "=== config.jsonc ===\n"
if command -v bat >/dev/null 2>&1; then
  bat --paging=never --color=always --style=plain --language json \
    --line-range 1:120 "\${theme_dir}/config.jsonc"
else
  sed -n "1,120p" "\${theme_dir}/config.jsonc"
fi
printf "\n=== style.css ===\n"
if command -v bat >/dev/null 2>&1; then
  bat --paging=never --color=always --style=plain --language css \
    --line-range 1:120 "\${theme_dir}/style.css"
else
  sed -n "1,120p" "\${theme_dir}/style.css"
fi
'
EOF
)

  local self_path self_path_escaped apply_cmd
  self_path="${0}"
  self_path_escaped="$(printf '%q' "${self_path}")"
  apply_cmd=$(cat <<EOF
bash -c '
theme="\$1"
cmd=(${self_path_escaped})
if [ "${DRY_RUN}" = true ]; then
  cmd+=("--dry-run")
fi
cmd+=("\$theme")
"\${cmd[@]}"
' _ {}
EOF
)

  printf '%s\n' "${themes[@]}" | fzf --ansi --sync --prompt='Select Waybar theme (Ctrl-Q to quit): ' \
    --cycle --reverse --bind "ctrl-q:abort" \
    --bind "enter:execute-silent(${apply_cmd})" \
    --border --border-label="Wayflipper v${VERSION}" \
    --preview="${preview_cmd}" --preview-window='right:75%:wrap:border'
}

restart_waybar() {
  if [ "${DRY_RUN}" = true ]; then
    printf 'Would run omarchy-restart-waybar\n'
    return
  fi

  if command -v omarchy-restart-waybar >/dev/null 2>&1; then
    omarchy-restart-waybar
    return
  fi

  printf 'omarchy-restart-waybar not found. Install it or reload Waybar manually.\n' >&2
  exit 1
}

backup_existing_waybar_theme() {
  local backup_dir="${THEMES_DIR}/existing-backup"
  local backup_config="${backup_dir}/config.jsonc"
  local backup_style="${backup_dir}/style.css"
  local needs_backup=false

  if [ -e "${ACTIVE_CONFIG}" ] && [ ! -L "${ACTIVE_CONFIG}" ]; then
    needs_backup=true
  fi
  if [ -e "${ACTIVE_STYLE}" ] && [ ! -L "${ACTIVE_STYLE}" ]; then
    needs_backup=true
  fi

  if [ "${needs_backup}" = false ]; then
    return 0
  fi

  if [ -e "${backup_config}" ] || [ -e "${backup_style}" ]; then
    printf 'Existing Waybar files detected; backup theme already exists at %s\n' "${backup_dir}" >&2
    printf 'Move or rename it, then retry.\n' >&2
    exit 1
  fi

  if [ "${DRY_RUN}" = true ]; then
    printf 'Would create backup theme directory: %s\n' "${backup_dir}"
    if [ -e "${ACTIVE_CONFIG}" ] && [ ! -L "${ACTIVE_CONFIG}" ]; then
      printf 'Would move %s to %s\n' "${ACTIVE_CONFIG}" "${backup_config}"
    fi
    if [ -e "${ACTIVE_STYLE}" ] && [ ! -L "${ACTIVE_STYLE}" ]; then
      printf 'Would move %s to %s\n' "${ACTIVE_STYLE}" "${backup_style}"
    fi
    return 0
  fi

  mkdir -p "${backup_dir}"
  if [ -e "${ACTIVE_CONFIG}" ] && [ ! -L "${ACTIVE_CONFIG}" ]; then
    mv -f "${ACTIVE_CONFIG}" "${backup_config}"
  fi
  if [ -e "${ACTIVE_STYLE}" ] && [ ! -L "${ACTIVE_STYLE}" ]; then
    mv -f "${ACTIVE_STYLE}" "${backup_style}"
  fi
}

resolve_path() {
  local path="$1"

  if [ -z "${path}" ]; then
    return 1
  fi

  if [ -d "${path}" ]; then
    (cd "${path}" && pwd)
    return 0
  fi

  local dir
  dir="$(dirname "${path}")"
  if [ -d "${dir}" ]; then
    printf '%s/%s\n' "$(cd "${dir}" && pwd)" "$(basename "${path}")"
    return 0
  fi

  return 1
}

cleanup_previous_symlinks() {
  if [ ! -f "${STATE_FILE}" ]; then
    return 0
  fi

  local state_theme_dir=""
  local line
  while IFS= read -r line; do
    case "${line}" in
      ""|\#*) continue ;;
      theme_dir=*)
        state_theme_dir="${line#theme_dir=}"
        if [ -n "${state_theme_dir}" ]; then
          state_theme_dir="$(resolve_path "${state_theme_dir}" || printf '%s' "${state_theme_dir}")"
        fi
        ;;
      *)
        local target="${line}"
        if [ -L "${target}" ]; then
          local link_target
          link_target="$(readlink "${target}")"
          if [[ "${link_target}" != /* ]]; then
            link_target="$(resolve_path "$(dirname "${target}")/${link_target}")"
          else
            link_target="$(resolve_path "${link_target}" || printf '%s' "${link_target}")"
          fi
          if [ -z "${state_theme_dir}" ] || [[ "${link_target}" == "${state_theme_dir}"/* ]]; then
            if [ "${DRY_RUN}" = true ]; then
              printf 'Would remove symlink %s\n' "${target}"
            else
              rm -f "${target}"
            fi
          fi
        fi
        ;;
    esac
  done <"${STATE_FILE}"

  if [ "${DRY_RUN}" = true ]; then
    printf 'Would remove state file %s\n' "${STATE_FILE}"
    return 0
  fi

  rm -f "${STATE_FILE}"
}

list_theme_subdirs() {
  local theme_dir="$1"
  local entry

  for entry in "${theme_dir}"/*; do
    [ -d "${entry}" ] || continue
    printf '%s\n' "${entry}"
  done
}

write_state_file() {
  local theme_dir="$1"
  shift
  local linked_paths=("$@")

  if [ "${DRY_RUN}" = true ]; then
    if [ "${#linked_paths[@]}" -gt 0 ]; then
      printf 'Would write state file %s\n' "${STATE_FILE}"
    fi
    return 0
  fi

  if [ "${#linked_paths[@]}" -eq 0 ]; then
    rm -f "${STATE_FILE}"
    return 0
  fi

  {
    printf 'theme_dir=%s\n' "${theme_dir}"
    local path
    for path in "${linked_paths[@]}"; do
      printf '%s\n' "${path}"
    done
  } >"${STATE_FILE}"
}

apply_theme_symlinks() {
  local theme_dir="$1"
  local config_path="${theme_dir}/config.jsonc"
  local style_path="${theme_dir}/style.css"
  local linked_paths=()

  if [ "${DRY_RUN}" = true ]; then
    printf 'Would symlink %s to %s\n' "${config_path}" "${ACTIVE_CONFIG}"
    printf 'Would symlink %s to %s\n' "${style_path}" "${ACTIVE_STYLE}"
  else
    ln -sfn "${config_path}" "${ACTIVE_CONFIG}"
    ln -sfn "${style_path}" "${ACTIVE_STYLE}"
  fi

  local subdir
  while IFS= read -r subdir; do
    [ -n "${subdir}" ] || continue
    local target="${WAYBAR_DIR}/$(basename "${subdir}")"
    if [ -e "${target}" ] && [ ! -L "${target}" ]; then
      printf 'Cannot symlink %s; target exists and is not a symlink: %s\n' "${subdir}" "${target}" >&2
      exit 1
    fi
    if [ "${DRY_RUN}" = true ]; then
      printf 'Would symlink %s to %s\n' "${subdir}" "${target}"
    else
      ln -sfn "${subdir}" "${target}"
    fi
    linked_paths+=("${target}")
  done < <(list_theme_subdirs "${theme_dir}")

  local resolved_theme_dir
  resolved_theme_dir="$(resolve_path "${theme_dir}" || printf '%s' "${theme_dir}")"
  write_state_file "${resolved_theme_dir}" "${linked_paths[@]}"
}

process_theme() {
  local theme_name="$1"

  if [ -z "${theme_name}" ]; then
    printf 'No theme specified.\n' >&2
    usage
    exit 1
  fi

  if [ ! -d "${THEMES_DIR}" ]; then
    printf 'Themes directory not found: %s\n' "${THEMES_DIR}" >&2
    exit 1
  fi

  local theme_dir="${THEMES_DIR}/${theme_name}"
  if [ ! -d "${theme_dir}" ]; then
    printf 'Theme not found: %s\n' "${theme_dir}" >&2
    exit 1
  fi

  if [ ! -f "${theme_dir}/config.jsonc" ] || [ ! -f "${theme_dir}/style.css" ]; then
    printf 'Theme is missing config.jsonc or style.css: %s\n' "${theme_dir}" >&2
    exit 1
  fi

  if [ ! -d "${WAYBAR_DIR}" ]; then
    if [ "${DRY_RUN}" = true ]; then
      printf 'Would create directory: %s\n' "${WAYBAR_DIR}"
    else
      mkdir -p "${WAYBAR_DIR}"
    fi
  fi

  backup_existing_waybar_theme
  cleanup_previous_symlinks
  apply_theme_symlinks "${theme_dir}"
  restart_waybar

  if [ "${DRY_RUN}" = true ]; then
    printf 'Dry run complete. Theme "%s" would symlink into %s\n' \
      "${theme_name}" "${WAYBAR_DIR}"
  else
    notify-send -t 1200 "Wayflipper" "Flipped to ${theme_name}"
  fi
}

parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      -l|--list) LIST_ONLY=true ;;
      -b|--browse) BROWSE=true ;;
      --browse-once) BROWSE=true; BROWSE_ONCE=true ;;
      --dry-run) DRY_RUN=true ;;
      -v|--version) printf 'wayflipper %s\n' "${VERSION}"; exit 0 ;;
      -h|--help) usage; exit 0 ;;
      --) shift; break ;;
      -*)
        printf 'Unknown option: %s\n' "$1" >&2
        usage
        exit 1
        ;;
      *)
        if [ -n "${THEME}" ]; then
          printf 'Multiple themes specified. Only one theme is allowed.\n' >&2
          usage
          exit 1
        fi
        THEME="$1"
        ;;
    esac
    shift
  done
}

main() {
  parse_args "$@"

  ensure_config
  load_config

  if [ "${LIST_ONLY}" = true ]; then
    list_themes
    exit 0
  fi

  if [ "${BROWSE}" = true ]; then
    local last_selection=""
    if [ "${BROWSE_ONCE}" = true ]; then
      if ! browse_themes "${last_selection}"; then
        exit 0
      fi
      process_theme "${THEME}"
      exit 0
    fi
    browse_themes_live
    local browse_status=$?
    if [ "${browse_status}" -eq 0 ] || [ "${browse_status}" -eq 130 ]; then
      exit 0
    fi
    while true; do
      if ! browse_themes "${last_selection}"; then
        exit 0
      fi
      last_selection="${THEME}"
      process_theme "${THEME}"
    done
  fi

  process_theme "${THEME}"
}

main "$@"
