ype == pwa-node && view == workbench.debug.callStackView && jsDebugIsMapSteppingDisabled || debugType == pwa-chrome && view == workbench.debug.callStackView && jsDebugIsMapSteppingDisabled || debugType == pwa-msedge && view == workbench.debug.callStackView && jsDebugIsMapSteppingDisabled"},{"command":"extension.js-debug.network.clear","group":"navigation","when":"view == jsDebugNetworkTree"}],"view/item/context":[{"command":"extension.js-debug.addXHRBreakpoints","when":"view == jsBrowserBreakpoints && viewItem == xhrBreakpoint"},{"command":"extension.js-debug.editXHRBreakpoints","when":"view == jsBrowserBreakpoints && viewItem == xhrBreakpoint","group":"inline"},{"command":"extension.js-debug.editXHRBreakpoints","when":"view == jsBrowserBreakpoints && viewItem == xhrBreakpoint"},{"command":"extension.js-debug.removeXHRBreakpoint","when":"view == jsBrowserBreakpoints && viewItem == xhrBreakpoint","group":"inline"},{"command":"extension.js-debug.removeXHRBreakpoint","when":"view == jsBrowserBreakpoints && viewItem == xhrBreakpoint"},{"command":"extension.js-debug.addXHRBreakpoints","when":"view == jsBrowserBreakpoints && viewItem == xhrCategory","group":"inline"},{"command":"extension.js-debug.callers.goToCaller","group":"inline","when":"view == jsExcludedCallers"},{"command":"extension.js-debug.callers.gotToTarget","group":"inline","when":"view == jsExcludedCallers"},{"command":"extension.js-debug.callers.remove","group":"inline","when":"view == jsExcludedCallers"},{"command":"extension.js-debug.network.viewRequest","group":"inline@1","when":"view == jsDebugNetworkTree"},{"command":"extension.js-debug.network.openBody","group":"body@1","when":"view == jsDebugNetworkTree"},{"command":"extension.js-debug.network.openBodyInHex","group":"body@2","when":"view == jsDebugNetworkTree"},{"command":"extension.js-debug.network.copyUri","group":"other@1","when":"view == jsDebugNetworkTree"},{"command":"extension.js-debug.network.replayXHR","group":"other@2","when":"view == jsDebugNetworkTree"}],"editor/title":[{"command":"extension.js-debug.prettyPrint","group":"navigation","when":"jsDebugCanPrettyPrint"}]},"breakpoints":[{"language":"javascript"},{"language":"typescript"},{"language":"typescriptreact"},{"language":"javascriptreact"},{"language":"fsharp"},{"language":"html"},{"language":"wat"},{"language":"c"},{"language":"cpp"},{"language":"rust"},{"language":"zig"}],"debuggers":[{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"attach":{"properties":{"address":{"default":"localhost","description":"Địa chỉ TCP/IP của tiến trình cần gỡ lỗi. Giá trị mặc định là \"localhost\".","type":"string"},"attachExistingChildren":{"default":false,"description":"Chỉ định có nên thử gắn kèm các tiến trình con đã được tạo sẵn hay không.","type":"boolean"},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"continueOnAttach":{"default":true,"markdownDescription":"Nếu là TRUE, các chương trình tự động khởi chạy sẽ được tiếp tục và sẽ chờ --inspect-brk","type":"boolean"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"port":{"default":9229,"description":"Cổng gỡ lỗi để đính kèm. Mặc định là 9229.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}],"tags":["setup"]},"processId":{"default":"${command:PickProcess}","description":"ID của tiến trình để gắn kèm.","type":"string"},"remoteHostHeader":{"description":"Tiêu đề máy chủ rõ ràng sẽ được sử dụng khi kết nối với websocket của thanh tra viên. Nếu không chỉ định, tiêu đề máy chủ sẽ được đặt thành \"localhost\". Điều này hữu ích khi thanh tra viên chạy sau một proxy chỉ chấp nhận một tiêu đề máy chủ cụ thể.","type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"websocketAddress":{"description":"Địa chỉ WebSocket chính xác cho quá trình đính kèm. Nếu không được cung cấp, nó sẽ được suy ra từ địa chỉ và cổng.","type":"string"}}},"launch":{"properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}}}},"configurationSnippets":[],"deprecated":"Please use type node instead","label":"Node.js","languages":["javascript","typescript","javascriptreact","typescriptreact"],"strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"pwa-node","variables":{"PickProcess":"extension.js-debug.pickNodeProcess"}},{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"attach":{"properties":{"address":{"default":"localhost","description":"Địa chỉ TCP/IP của tiến trình cần gỡ lỗi. Giá trị mặc định là \"localhost\".","type":"string"},"attachExistingChildren":{"default":false,"description":"Chỉ định có nên thử gắn kèm các tiến trình con đã được tạo sẵn hay không.","type":"boolean"},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"continueOnAttach":{"default":true,"markdownDescription":"Nếu là TRUE, các chương trình tự động khởi chạy sẽ được tiếp tục và sẽ chờ --inspect-brk","type":"boolean"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"port":{"default":9229,"description":"Cổng gỡ lỗi để đính kèm. Mặc định là 9229.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}],"tags":["setup"]},"processId":{"default":"${command:PickProcess}","description":"ID của tiến trình để gắn kèm.","type":"string"},"remoteHostHeader":{"description":"Tiêu đề máy chủ rõ ràng sẽ được sử dụng khi kết nối với websocket của thanh tra viên. Nếu không chỉ định, tiêu đề máy chủ sẽ được đặt thành \"localhost\". Điều này hữu ích khi thanh tra viên chạy sau một proxy chỉ chấp nhận một tiêu đề máy chủ cụ thể.","type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"websocketAddress":{"description":"Địa chỉ WebSocket chính xác cho quá trình đính kèm. Nếu không được cung cấp, nó sẽ được suy ra từ địa chỉ và cổng.","type":"string"}}},"launch":{"properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}}}},"configurationSnippets":[{"body":{"name":"${1:Attach}","port":9229,"request":"attach","skipFiles":["<node_internals>/**"],"type":"node"},"description":"Đính kèm vào một chương trình Node đang chạy","label":"Node.js: Đính kèm"},{"body":{"address":"${2:TCP/IP address of process to be debugged}","localRoot":"^\"\\${workspaceFolder}\"","name":"${1:Attach to Remote}","port":9229,"remoteRoot":"${3:Absolute path to the remote directory containing the program}","request":"attach","skipFiles":["<node_internals>/**"],"type":"node"},"description":"Đính kèm vào cổng gỡ lỗi của chương trình Node từ xa","label":"Node.js: Đính kèm vào chương trình từ xa"},{"body":{"name":"${1:Attach by Process ID}","processId":"^\"\\${command:PickProcess}\"","request":"attach","skipFiles":["<node_internals>/**"],"type":"node"},"description":"Mở lựa chọn quy trình để chọn quy trình Node cần đính kèm","label":"Node.js: Đính kèm vào Quy trình"},{"body":{"name":"${2:Launch Program}","program":"^\"\\${workspaceFolder}/${1:app.js}\"","request":"launch","skipFiles":["<node_internals>/**"],"type":"node"},"description":"Khởi chạy chương trình Node ở chế độ gỡ lỗi","label":"Node.js: Khởi chạy chương trình"},{"body":{"name":"${1:Launch via NPM}","request":"launch","runtimeArgs":["run-script","debug"],"runtimeExecutable":"npm","skipFiles":["<node_internals>/**"],"type":"node"},"label":"Node.js: Khởi chạy qua npm","markdownDescription":"Khởi chạy chương trình Node qua tập lệnh npm \"debug\""},{"body":{"console":"integratedTerminal","internalConsoleOptions":"neverOpen","name":"nodemon","program":"^\"\\${workspaceFolder}/${1:app.js}\"","request":"launch","restart":true,"runtimeExecutable":"nodemon","skipFiles":["<node_internals>/**"],"type":"node"},"description":"Sử dụng Nodemon để khởi động lại phiên gỡ lỗi khi nguồn thay đổi.","label":"Node.js: Thiết lập Nodemon"},{"body":{"args":["-u","tdd","--timeout","999999","--colors","^\"\\${workspaceFolder}/${1:test}\""],"internalConsoleOptions":"openOnSessionStart","name":"Mocha Tests","program":"^\"mocha\"","request":"launch","skipFiles":["<node_internals>/**"],"type":"node"},"description":"Gỡ lỗi kiểm thử Mocha","label":"Node.js: Kiểm thử Mocha"},{"body":{"args":["${1:generator}"],"console":"integratedTerminal","internalConsoleOptions":"neverOpen","name":"Yeoman ${1:generator}","program":"^\"\\${workspaceFolder}/node_modules/yo/lib/cli.js\"","request":"launch","skipFiles":["<node_internals>/**"],"type":"node"},"label":"Node.js: Trình tạo Yeoman","markdownDescription":"Gỡ lỗi trình tạo Yeoman (cài đặt bằng cách chạy \"npm link\" trong thư mục dự án)"},{"body":{"args":["${1:task}"],"name":"Gulp ${1:task}","program":"^\"\\${workspaceFolder}/node_modules/gulp/bin/gulp.js\"","request":"launch","skipFiles":["<node_internals>/**"],"type":"node"},"description":"Gỡ lỗi tác vụ Gulp (phải có Gulp cục bộ được cài đặt trong dự án của bạn)","label":"Node.js: Tác vụ Gulp"},{"body":{"name":"Electron Main","program":"^\"\\${workspaceFolder}/main.js\"","request":"launch","runtimeExecutable":"^\"electron\"","skipFiles":["<node_internals>/**"],"type":"node"},"description":"Gỡ lỗi quy trình chính Electron","label":"Node.js: Quy trình chính Electron"}],"label":"Node.js","strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"node","variables":{"PickProcess":"extension.js-debug.pickNodeProcess"}},{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"launch":{"properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}}}},"configurationSnippets":[{"body":{"command":"npm start","name":"Run npm start","request":"launch","type":"node-terminal"},"description":"Chạy \"npm start\" trong một terminal gỡ lỗi","label":"Chạy \"npm start\" trong một terminal gỡ lỗi"}],"label":"Terminal gỡ lỗi JavaScript","languages":[],"strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"node-terminal"},{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"launch":{"properties":{"args":{"default":["--extensionDevelopmentPath=${workspaceFolder}"],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":"array"},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"debugWebWorkerHost":{"default":true,"markdownDescription":"Cấu hình xem có nên thử đính kèm vào host tiện ích mở rộng webworker hay không.","type":["boolean"]},"debugWebviews":{"default":true,"markdownDescription":"Cấu hình xem có nên thử đính kèm vào webview trong phiên bản VS Code đã khởi động hay không. Điều này chỉ hoạt động trong VS Code trên máy tính để bàn.","type":["boolean"]},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"rendererDebugOptions":{"default":{"webRoot":"${workspaceFolder}"},"markdownDescription":"Tùy chọn khởi động Chrome được sử dụng khi đính kèm vào tiến trình renderer với \"debugWebviews\" hoặc \"debugWebWorkerHost\".","properties":{"address":{"default":"localhost","description":"Địa chỉ IP hoặc tên máy chủ mà trình duyệt đang lắng nghe để gỡ lỗi.","type":"string"},"browserAttachLocation":{"default":null,"description":"Buộc trình duyệt đính kèm tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để đính kèm trình duyệt trên máy từ xa thay vì trình duyệt trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Cổng được sử dụng khi gỡ lỗi trình duyệt từ xa, được chỉ định là \"--remote-debugging-port\" khi khởi động trình duyệt.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}],"tags":["setup"]},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":false,"markdownDescription":"Chỉ định xem kết nối có được thiết lập lại không khi kết nối trình duyệt bị đóng.","type":"boolean"},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"targetSelection":{"default":"automatic","enum":["pick","automatic"],"markdownDescription":"Chỉ định xem có đính kèm vào tất cả các mục tiêu khớp với bộ lọc URL (\"automatic\") hay chọn một mục tiêu (\"pick\").","type":"string"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":t