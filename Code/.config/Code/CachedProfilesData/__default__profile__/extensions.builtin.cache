r && !isEmbeddedDiffEditor && resourceScheme == file"}],"editor/context":[{"command":"git.stageSelectedRanges","group":"2_git@1","when":"config.git.enabled && !git.missing && gitOpenRepositoryCount != 0 && isInDiffEditor && isInDiffRightEditor && !isEmbeddedDiffEditor && resourceScheme == file"},{"command":"git.unstageSelectedRanges","group":"2_git@2","when":"config.git.enabled && !git.missing && gitOpenRepositoryCount != 0 && isInDiffEditor && isInDiffRightEditor && !isEmbeddedDiffEditor && resourceScheme == git"},{"command":"git.revertSelectedRanges","group":"2_git@3","when":"config.git.enabled && !git.missing && gitOpenRepositoryCount != 0 && isInDiffEditor && isInDiffRightEditor && !isEmbeddedDiffEditor && resourceScheme == file"}],"editor/content":[{"command":"git.acceptMerge","when":"isMergeResultEditor && mergeEditorBaseUri =~ /^(git|file):/ && mergeEditorResultUri in git.mergeChanges"},{"command":"git.openMergeEditor","group":"navigation@-10","when":"config.git.enabled && !git.missing && !isInDiffEditor && !isMergeEditor && resource in git.mergeChanges && git.activeResourceHasMergeConflicts"},{"command":"git.commitMessageAccept","group":"navigation","when":"config.git.enabled && !git.missing && gitOpenRepositoryCount != 0 && editorLangId == git-commit"},{"command":"git.commitMessageDiscard","group":"secondary","when":"config.git.enabled && !git.missing && gitOpenRepositoryCount != 0 && editorLangId == git-commit"}],"multiDiffEditor/resource/title":[{"command":"git.stageFile","group":"navigation","when":"scmProvider == git && scmResourceGroup == workingTree"},{"command":"git.stageFile","group":"navigation","when":"scmProvider == git && scmResourceGroup == untracked"},{"command":"git.unstageFile","group":"navigation","when":"scmProvider == git && scmResourceGroup == index"}],"diffEditor/gutter/hunk":[{"command":"git.diff.stageHunk","group":"primary@10","when":"diffEditorOriginalUri =~ /^git\\:.*%22ref%22%3A%22~%22%7D$/"}],"diffEditor/gutter/selection":[{"command":"git.diff.stageSelection","group":"primary@10","when":"diffEditorOriginalUri =~ /^git\\:.*%22ref%22%3A%22~%22%7D$/"}],"scm/change/title":[{"command":"git.stageChange","when":"config.git.enabled && !git.missing && originalResource =~ /^git\\:.*%22ref%22%3A%22%22%7D$/"},{"command":"git.revertChange","when":"config.git.enabled && !git.missing && originalResource =~ /^git\\:.*%22ref%22%3A%22%22%7D$/"},{"command":"git.unstageChange","when":"false"}],"timeline/item/context":[{"command":"git.timeline.viewCommit","group":"inline","when":"config.git.enabled && !git.missing && timelineItem =~ /git:file:commit\\b/ && !listMultiSelection"},{"command":"git.timeline.openDiff","group":"1_actions@1","when":"config.git.enabled && !git.missing && timelineItem =~ /git:file\\b/ && !listMultiSelection"},{"command":"git.timeline.viewCommit","group":"1_actions@2","when":"config.git.enabled && !git.missing && timelineItem =~ /git:file:commit\\b/ && !listMultiSelection"},{"command":"git.timeline.compareWithSelected","group":"3_compare@1","when":"config.git.enabled && !git.missing && git.timeline.selectedForCompare && timelineItem =~ /git:file\\b/ && !listMultiSelection"},{"command":"git.timeline.selectForCompare","group":"3_compare@2","when":"config.git.enabled && !git.missing && timelineItem =~ /git:file\\b/ && !listMultiSelection"},{"command":"git.timeline.copyCommitId","group":"5_copy@1","when":"config.git.enabled && !git.missing && timelineItem =~ /git:file:commit\\b/ && !listMultiSelection"},{"command":"git.timeline.copyCommitMessage","group":"5_copy@2","when":"config.git.enabled && !git.missing && timelineItem =~ /git:file:commit\\b/ && !listMultiSelection"}],"git.commit":[{"command":"git.commit","group":"1_commit@1"},{"command":"git.commitStaged","group":"1_commit@2"},{"command":"git.commitAll","group":"1_commit@3"},{"command":"git.undoCommit","group":"1_commit@4"},{"command":"git.rebaseAbort","group":"1_commit@5"},{"command":"git.commitNoVerify","group":"2_commit_noverify@1","when":"config.git.allowNoVerifyCommit"},{"command":"git.commitStagedNoVerify","group":"2_commit_noverify@2","when":"config.git.allowNoVerifyCommit"},{"command":"git.commitAllNoVerify","group":"2_commit_noverify@3","when":"config.git.allowNoVerifyCommit"},{"command":"git.commitAmend","group":"3_amend@1"},{"command":"git.commitStagedAmend","group":"3_amend@2"},{"command":"git.commitAllAmend","group":"3_amend@3"},{"command":"git.commitAmendNoVerify","group":"4_amend_noverify@1","when":"config.git.allowNoVerifyCommit"},{"command":"git.commitStagedAmendNoVerify","group":"4_amend_noverify@2","when":"config.git.allowNoVerifyCommit"},{"command":"git.commitAllAmendNoVerify","group":"4_amend_noverify@3","when":"config.git.allowNoVerifyCommit"},{"command":"git.commitSigned","group":"5_signoff@1"},{"command":"git.commitStagedSigned","group":"5_signoff@2"},{"command":"git.commitAllSigned","group":"5_signoff@3"},{"command":"git.commitSignedNoVerify","group":"6_signoff_noverify@1","when":"config.git.allowNoVerifyCommit"},{"command":"git.commitStagedSignedNoVerify","group":"6_signoff_noverify@2","when":"config.git.allowNoVerifyCommit"},{"command":"git.commitAllSignedNoVerify","group":"6_signoff_noverify@3","when":"config.git.allowNoVerifyCommit"}],"git.changes":[{"command":"git.stageAll","group":"changes@1"},{"command":"git.unstageAll","group":"changes@2"},{"command":"git.cleanAll","group":"changes@3"}],"git.pullpush":[{"command":"git.sync","group":"1_sync@1"},{"command":"git.syncRebase","when":"gitState == idle","group":"1_sync@2"},{"command":"git.pull","group":"2_pull@1"},{"command":"git.pullRebase","group":"2_pull@2"},{"command":"git.pullFrom","group":"2_pull@3"},{"command":"git.push","group":"3_push@1"},{"command":"git.pushForce","when":"config.git.allowForcePush","group":"3_push@2"},{"command":"git.pushTo","group":"3_push@3"},{"command":"git.pushToForce","when":"config.git.allowForcePush","group":"3_push@4"},{"command":"git.fetch","group":"4_fetch@1"},{"command":"git.fetchPrune","group":"4_fetch@2"},{"command":"git.fetchAll","group":"4_fetch@3"}],"git.branch":[{"command":"git.merge","group":"1_merge@1"},{"command":"git.rebase","group":"1_merge@2"},{"command":"git.branch","group":"2_branch@1"},{"command":"git.branchFrom","group":"2_branch@2"},{"command":"git.renameBranch","group":"3_modify@1"},{"command":"git.deleteBranch","group":"3_modify@2"},{"command":"git.deleteRemoteBranch","group":"3_modify@3"},{"command":"git.publish","group":"4_publish@1"}],"git.remotes":[{"command":"git.addRemote","group":"remote@1"},{"command":"git.removeRemote","group":"remote@2"}],"git.stash":[{"command":"git.stash","group":"1_stash@1"},{"command":"git.stashIncludeUntracked","group":"1_stash@2"},{"command":"git.stashStaged","when":"gitVersion2.35","group":"1_stash@3"},{"command":"git.stashApplyLatest","group":"2_apply@1"},{"command":"git.stashApply","group":"2_apply@2"},{"command":"git.stashPopLatest","group":"3_pop@1"},{"command":"git.stashPop","group":"3_pop@2"},{"command":"git.stashDrop","group":"4_drop@1"},{"command":"git.stashDropAll","group":"4_drop@2"},{"command":"git.stashView","group":"5_preview@1"}],"git.repositories.stash":[{"command":"git.stash","group":"1_stash@1"},{"command":"git.stashStaged","when":"gitVersion2.35","group":"2_stash@1"},{"command":"git.stashIncludeUntracked","group":"2_stash@2"}],"git.tags":[{"command":"git.createTag","group":"1_tags@1"},{"command":"git.deleteTag","group":"1_tags@2"},{"command":"git.deleteRemoteTag","group":"1_tags@3"},{"command":"git.pushTags","group":"2_tags@1"}],"git.worktrees":[{"when":"scmProviderContext == worktree","command":"git.openWorktree","group":"openWorktrees@1"},{"when":"scmProviderContext == worktree","command":"git.openWorktreeInNewWindow","group":"openWorktrees@2"},{"when":"scmProviderContext == repository","command":"git.createWorktree","group":"worktrees@1"},{"when":"scmProviderContext == worktree","command":"git.deleteWorktree2","group":"worktrees@2"}]},"submenus":[{"id":"git.commit","label":"Commit"},{"id":"git.changes","label":"Thay đổi"},{"id":"git.pullpush","label":"Kéo, Đẩy"},{"id":"git.branch","label":"Nhánh"},{"id":"git.remotes","label":"Từ xa"},{"id":"git.stash","label":"Thực hiện Stash"},{"id":"git.tags","label":"Các thẻ"},{"id":"git.worktrees","label":"Cây làm việc"},{"id":"git.repositories.stash","label":"Thực hiện Stash","icon":"$(plus)"}],"configuration":{"title":"Git","properties":{"git.enabled":{"type":"boolean","scope":"resource","description":"Xác định liệu Git có được bật hay không.","default":true},"git.path":{"type":["string","null","array"],"markdownDescription":"Đường dẫn và tên tệp thực thi của Git, ví dụ \"C:\\Program Files\\Git\\bin\\git.exe\" (Windows). Cũng có thể là mảng các chuỗi chứa nhiều đường dẫn để tìm kiếm.","default":null,"scope":"machine"},"git.autoRepositoryDetection":{"type":["boolean","string"],"enum":[true,false,"subFolders","openEditors"],"enumDescriptions":["Tìm kiếm cả thư mục con của thư mục hiện đang mở và thư mục cha của các tệp đang mở.","Tắt tìm kiếm tự động các kho lưu trữ.","Tìm kiếm các thư mục con của thư mục hiện đang mở.","Tìm kiếm các thư mục cha của các tệp đang mở."],"description":"Xác định khi nào các kho lưu trữ sẽ được tự động phát hiện.","default":true},"git.autorefresh":{"type":"boolean","description":"Chỉ định liệu tính năng tự động làm mới có được bật hay không.","default":true},"git.autofetch":{"type":["boolean","string"],"enum":[true,false,"all"],"scope":"resource","markdownDescription":"Khi đặt thành TRUE, các commit sẽ tự động được fetch từ remote mặc định của kho Git hiện tại. Khi đặt thành \"Tất cả\", fetch từ tất cả các remote.","default":false,"tags":["usesOnlineServices"]},"git.autofetchPeriod":{"type":"number","scope":"resource","markdownDescription":"Khoảng thời gian tính bằng giây giữa mỗi lần fetch Git tự động, khi \"#git.autofetch#\" được bật.","default":180},"git.defaultBranchName":{"type":"string","markdownDescription":"Tên nhánh mặc định (ví dụ: main, trunk, development) khi khởi tạo một kho Git mới. Nếu đặt là 'empty', sẽ sử dụng tên nhánh mặc định được cấu hình trong Git. **Lưu ý:** Yêu cầu Git phiên bản 2.28.0 trở lên.","default":"main","scope":"resource"},"git.branchPrefix":{"type":"string","description":"Tiền tố được sử dụng khi tạo một nhánh mới.","default":"","scope":"resource"},"git.branchProtection":{"type":"array","markdownDescription":"Danh sách các nhánh được bảo vệ. Theo mặc định, một lời nhắc sẽ hiển thị trước khi commit các thay đổi cho một nhánh được bảo vệ. Lời nhắc có thể được điều khiển bằng cài đặt '#git.branchProtectionPrompt#'.","items":{"type":"string"},"default":[],"scope":"resource"},"git.branchProtectionPrompt":{"type":"string","description":"Điều khiển việc hiển thị lời nhắc trước khi thực hiện commit thay đổi vào một nhánh được bảo vệ.","enum":["alwaysCommit","alwaysCommitToNewBranch","alwaysPrompt"],"enumDescriptions":["Commit thay đổi phải luôn được thực hiện cho nhánh được bảo vệ.","Commit thay đổi phải luôn được thực hiện cho một nhánh mới.","Luôn hỏi trước khi thực hiện commit thay đổi cho một nhánh được bảo vệ."],"default":"alwaysPrompt","scope":"resource"},"git.branchValidationRegex":{"type":"string","description":"Biểu thức chính quy để xác thực tên nhánh mới.","default":""},"git.branchWhitespaceChar":{"type":"string","description":"Ký tự dùng để thay thế khoảng trắng trong tên nhánh mới và phân tách các phần của tên nhánh được tạo ngẫu nhiên.","default":"-"},"git.branchRandomName.enable":{"type":"boolean","description":"Điều khiển việc tạo tên ngẫu nhiên khi tạo nhánh mới.","default":false,"scope":"resource"},"git.branchRandomName.dictionary":{"type":"array","markdownDescription":"Danh sách từ điển được sử dụng để tạo tên nhánh ngẫu nhiên. Mỗi giá trị đại diện cho từ điển được dùng để tạo một phần của tên nhánh. Các từ điển được hỗ trợ: \"Tính từ\", \"Động vật\", \"Màu sắc\" và \"Số\".","items":{"type":"string","enum":["adjectives","animals","colors","numbers"],"enumDescriptions":["Một tính từ ngẫu nhiên","Một tên động vật ngẫu nhiên","Một tên màu sắc ngẫu nhiên","Một số ngẫu nhiên từ 100 đến 999"]},"minItems":1,"maxItems":5,"default":["adjectives","animals"],"scope":"resource"},"git.confirmSync":{"type":"boolean","description":"Xác nhận trước khi đồng bộ hóa kho lưu trữ Git.","default":true},"git.confirmCommittedDelete":{"type":"boolean","description":"Confirm before deleting committed files with Git.","default":true},"git.countBadge":{"type":"string","enum":["all","tracked","off"],"enumDescriptions":["Đếm tất cả các thay đổi.","Chỉ tính các thay đổi đã được theo dõi.","Tắt bộ đếm."],"description":"Điều khiển huy hiệu đếm Git.","default":"all","scope":"resource"},"git.checkoutType":{"type":"array","items":{"type":"string","enum":["local","tags","remote"],"enumDescriptions":["Các nhánh cục bộ","Các thẻ","Các nhánh từ xa"]},"uniqueItems":true,"markdownDescription":"Xác định loại tham chiếu Git nào sẽ được liệt kê khi thực hiện \"Check-Out to\".","default":["local","remote","tags"]},"git.ignoreLegacyWarning":{"type":"boolean","description":"Bỏ qua cảnh báo Git cũ.","default":false},"git.ignoreMissingGitWarning":{"type":"boolean","description":"Bỏ qua cảnh báo khi Git không tồn tại.","default":false},"git.ignoreWindowsGit27Warning":{"type":"boolean","description":"Bỏ qua cảnh báo khi Git 2.25–2.26 được cài đặt trên Windows.","default":false},"git.ignoreLimitWarning":{"type":"boolean","description":"Bỏ qua cảnh báo khi có quá nhiều thay đổi trong một kho.","default":false},"git.ignoreRebaseWarning":{"type":"boolean","description":"Bỏ qua cảnh báo khi pull nếu nhánh có thể đã được rebase.","default":false},"git.defaultCloneDirectory":{"type":["string","null"],"default":null,"scope":"machine","description":"Vị trí mặc định để sao chép một kho Git."},"git.useEditorAsCommitInput":{"type":"boolean","description":"Điều khiển việc có sử dụng trình soạn thảo văn bản đầy đủ để tạo thông điệp commit khi không có thông điệp nào được cung cấp trong trường nhập commit không.","default":true},"git.verboseCommit":{"type":"boolean","scope":"resource","markdownDescription":"Bật đầu ra chi tiết khi \"#git.useEditorAsCommitInput#\" được bật.","default":false},"git.enableSmartCommit":{"type":"boolean","scope":"resource","description":"Commit tất cả thay đổi khi không có thay đổi nào được staged.","default":false},"git.smartCommitChanges":{"type":"string","enum":["all","tracked"],"enumDescriptions":["Tất cả thay đổi sẽ được tự động đưa vào stage.","Chỉ các thay đổi đã được theo dõi được tự động đưa vào stage."],"scope":"resource","description":"Điều khiển những thay đổi nào được tự động đưa vào stage khi commit thông minh.","default":"all"},"git.suggestSmartCommit":{"type":"boolean","scope":"resource","description":"Đề xuất bật commit thông minh. Commit tất cả thay đổi khi không có thay đổi nào được stage.","default":true},"git.enableCommitSigning":{"type":"boolean","scope":"resource","description":"Kích hoạt ký commit bằng GPG, X.509 hoặc SSH.","default":false},"git.confirmEmptyCommits":{"type":"boolean","scope":"resource","description":"Luôn xác nhận việc tạo commit trống cho lệnh \"Git: Commit Empty\".","default":true},"git.decorations.enabled":{"type":"boolean","default":true,"description":"Xác định liệu Git có cung cấp màu sắc và huy hiệu cho chế độ xem Explorer và chế độ xem 'Trình chỉnh sửa đang mở' hay không."},"git.enableStatusBarSync":{"type":"boolean","default":true,"description":"Điều khiển việc lệnh Git Sync có được hiển thị trong thanh trạng thái hay không.","scope":"resource"},"git.followTagsWhenSync":{"type":"boolean","scope":"resource","default":false,"description":"Đẩy tất cả các thẻ có chú thích khi thực hiện lệnh đồng bộ."},"git.replaceTagsWhenPull":{"type":"boolean","scope":"resource","default":false,"description":"Khi xảy ra xung đột khi thực hiện lệnh pull, các tag cục bộ sẽ tự động được thay thế bằng tag từ xa."},"git.promptToSaveFilesBeforeStash":{"type":"string","enum":["always","staged","never"],"enumDescriptions":["Kiểm tra các tệp chưa lưu.","Chỉ kiểm tra các tệp đã staged nhưng chưa lưu.","Tắt kiểm tra này."],"scope":"resource","default":"always","description":"Xác định liệu Git có nên kiểm tra các tệp chưa lưu trước khi stash thay đổi hay không."},"git.promptToSaveFilesBeforeCommit":{"type":"string","enum":["always","staged","never"],"enumDescriptions":["Kiểm tra các tệp chưa lưu.","Chỉ kiểm tra các tệp đã staged nhưng chưa lưu.","Tắt kiểm tra này."],"scope":"resource","default":"always","description":"Xác định liệu Git có nên kiểm tra các tệp chưa lưu trước khi check-in hay không."},"git.postCommitCommand":{"type":"string","enum":["none","push","sync"],"enumDescriptions":["Không thực thi lệnh nào sau khi commit.","Thực thi \"git push\" sau khi commit thành công.","Thực thi \"git pull\" và \"git push\" sau khi commit thành công."],"markdownDescription":"Thực thi lệnh Git sau khi commit thành công.","scope":"resource","default":"none"},"git.rememberPostCommitCommand":{"type":"boolean","description":"Lưu lệnh Git cuối cùng được thực hiện sau một commit.","scope":"resource","default":false},"git.openAfterClone":{"type":"string","enum":["always","alwaysNewWindow","whenNoFolderOpen","prompt"],"enumDescriptions":["Luôn mở các phần tử trong cửa sổ hiện tại.","Luôn mở các phần tử trong cửa sổ mới.","Chỉ mở các phần tử trong cửa sổ hiện tại nếu không có thư mục nào đang mở.","Luôn yêu cầu một hành động."],"default":"prompt","description":"Điều khiển việc tự động mở kho sau khi sao chép."},"git.showInlineOpenFileAction":{"type":"boolean","default":true,"description":"Điều khiển việc liệu có hiển thị hành động nội tuyến để mở tệp trong chế độ xem \"Thay đổi Git\" hay không."},"git.showPushSuccessNotification":{"type":"boolean","description":"Xác định liệu có nên hiển thị thông báo khi push thành công hay không.","default":false},"git.inputValidation":{"type":"boolean","default":false,"description":"Điều khiển việc hiển thị chẩn đoán để xác thực đầu vào của thông điệp commit."},"git.inputValidationLength":{"type":"number","default":72,"description":"Điều khiển độ dài tối thiểu để cảnh báo cho thông điệp commit."},"git.inputValidationSubjectLength":{"type":["number","null"],"default":50,"markdownDescription":"Điều khiển ngưỡng độ dài tiêu đề thông điệp commit để hiển thị cảnh báo. Bỏ cài đặt để kế thừa giá trị từ \"#git.inputValidationLength#\"."},"git.detectSubmodules":{"type":"boolean","scope":"resource","default":true,"description":"Điều khiển việc Git-Submodules có được tự động phát hiện hay không."},"git.detectSubmodulesLimit":{"type":"number","scope":"resource","default":10,"description":"Điều khiển giới hạn cho các Git-Submodules được phát hiện."},"git.detectWorktrees":{"type":"boolean","scope":"resource","default":true,"description":"Điều khiển việc Git-Worktrees có được tự động phát hiện hay không."},"git.detectWorktreesLimit":{"type":"number","scope":"resource","default":50,"description":"Điều khiển giới hạn của các Git-Worktrees được phát hiện."},"git.worktreeIncludeFiles":{"type":"array","items":{"type":"string"},"default":[],"markdownDescription":"Configure [glob patterns](https://aka.ms/vscode-glob-patterns) for files and folders that are included when creating a new worktree. Only files and folders that match the patterns and are listed in `.gitignore` will be copied to the newly created worktree.","scope":"resource","tags":["experimental"]},"git.alwaysShowStagedChangesResourceGroup":{"type":"boolean","scope":"resource","default":false,"description":"Luôn hiển thị nhóm tài nguyên cho các thay đổi đã staged."},"git.alwaysSignOff":{"type":"boolean","scope":"resource","default":false,"description":"Đặt cờ signoff cho tất cả các commit."},"git.addAICoAuthor":{"type":"string","enum":["off","chatAndAgent","all"],"enumDescriptions":["Never add the AI co-author trailer.","Add the AI co-author trailer when code from chat or agent edits is included.","Add the AI co-author trailer when any AI-generated code is included, such as inline completions, chat, or agent edits."],"scope":"resource","default":"off","description":"Controls whether a 'Co-authored-by' trailer is automatically added to the commit message when AI-generated code is included in the commit."},"git.ignoreSubmodules":{"type":"boolean","scope":"resource","default":false,"description":"Bỏ qua các thay đổi đối với submodules trong cây tệp."},"git.ignoredRepositories":{"type":"array","items":{"type":"string"},"default":[],"scope":"window","description":"Danh sách các kho Git cần bỏ qua."},"git.scanRepositories":{"type":"array","items":{"type":"string"},"default":[],"scope":"resource","description":"Danh sách các đường dẫn để tìm kiếm kho lưu trữ Git."},"git.showProgress":{"type":"boolean","description":"Điều khiển việc liệu tiến trình có được hiển thị cho các hành động Git hay không.","default":true,"scope":"resource"},"git.rebaseWhenSync":{"type":"boolean","scope":"resource","default":false,"description":"Buộc Git sử dụng \"rebase\" khi thực hiện lệnh đồng bộ."},"git.pullBeforeCheckout":{"type":"boolean","scope":"resource","default":false,"description":"Điều khiển việc liệu một nhánh không có commit đi ra ngoài có nên được chuyển tiếp nhanh trước khi checkout hay không."},"git.fetchOnPull":{"type":"boolean","scope":"resource","default":false,"description":"Khi bật, tải xuống tất cả các nhánh khi pull. Nếu không, chỉ tải xuống nhánh hiện tại."},"git.pruneOnFetch":{"type":"boolean","scope":"resource","default":false,"description":"Xóa các phần tử khi fetch."},"git.pullTags":{"type":"boolean","scope":"resource","default":true,"description":"Fetch tất cả các tag khi pull."},"git.autoStash":{"type":"boolean","scope":"resource","default":false,"description":"Stash các thay đổi trước khi pull và khôi phục chúng sau khi pull thành công."},"git.allowForcePush":{"type":"boolean","default":false,"description":"Điều khiển việc đẩy cưỡng bức (có hoặc không có lease) có được bật hay không."},"git.useForcePushWithLease":{"type":"boolean","default":true,"description":"Điều khiển việc các lần push cưỡng bức có sử dụng biến thể an toàn hơn với lease không."},"git.useForcePushIfIncludes":{"type":"boolean","default":true,"markdownDescription":"Điều khiển việc các lần push cưỡng bức có sử dụng biến thể an toàn hơn force-if-includes không. Lưu ý: Cài đặt này yêu cầu cài đặt \"#git.useForcePushWithLease#\" được bật. Cần Git phiên bản 2.30.0 trở lên."},"git.confirmForcePush":{"type":"boolean","default":true,"description":"Điều khiển việc nhắc người dùng xác nhận trước khi thực hiện push cưỡng bức."},"git.allowNoVerifyCommit":{"type":"boolean","default":false,"description":"Điều khiển việc cho phép commit mà không chạy các hook pre-commit và commit-msg."},"git.confirmNoVerifyCommit":{"type":"boolean","default":true,"description":"Điều khiển việc yêu cầu xác nhận không kiểm tra trước khi commit."},"git.closeDiffOnOperation":{"type":"boolean","scope":"resource","default":false,"description":"Điều khiển việc đóng tự động trình soạn thảo diff khi thay đổi được stash, commit, discard, stage hoặc unstage."},"git.openDiffOnClick":{"type":"boolean","scope":"resource","default":true,"description":"Điều khiển việc mở trình so sánh khi nhấp vào một thay đổi. Nếu không, trình chỉnh sửa thông thường sẽ mở."},"git.supportCancellation":{"type":"boolean","scope":"resource","default":false,"description":"Điều khiển việc hiển thị thông báo khi thực hiện hành động đồng bộ, cho phép người dùng hủy thao tác."},"git.branchSortOrder":{"type":"string","enum":["committerdate","alphabetically"],"default":"committerdate","description":"Điều khiển thứ tự sắp xếp cho các nhánh."},"git.untrackedChanges":{"type":"string","enum":["mixed","separate","hidden"],"enumDescriptions":["Tất cả thay đổi (được theo dõi và không được theo dõi) được hiển thị cùng nhau và có hành vi giống nhau.","Các thay đổi không được theo dõi được hiển thị riêng biệt trong quản lý mã nguồn. Chúng cũng bị loại khỏi nhiều hành động.","Các thay đổi không được theo dõi bị ẩn và bị loại khỏi nhiều hành động."],"default":"mixed","description":"Xác định cách xử lý các thay đổi không được theo dõi.","scope":"resource"},"git.requireGitUserConfig":{"type":"boolean","description":"Điều khiển việc liệu có yêu cầu cấu hình người dùng Git rõ ràng hay không, hoặc liệu Git có nên đưa ra giả định nếu cấu hình bị thiếu.","default":true,"scope":"resource"},"git.showCommitInput":{"type":"boolean","scope":"resource","default":true,"description":"Điều khiển việc liệu đầu vào commit có được hiển thị trong bảng điều khiển kiểm soát nguồn Git hay không."},"git.terminalAuthentication":{"type":"boolean","default":true,"description":"Điều khiển việc có nên bật VS Code làm trình xử lý xác thực cho các tiến trình Git được tạo trong terminal tích hợp không. Lưu ý: Terminal phải khởi động lại để thay đổi cài đặt này có hiệu lực."},"git.terminalGitEditor":{"type":"boolean","default":false,"description":"Điều khiển việc có nên bật VS Code làm trình soạn thảo Git cho các tiến trình Git được tạo trong terminal tích hợp không. Lưu ý: Terminal phải khởi động lại để áp dụng thay đổi cài đặt này."},"git.useCommitInputAsStashMessage":{"type":"boolean","scope":"resource","default":false,"description":"Điều khiển việc có sử dụng thông điệp từ trường nhập commit làm thông điệp stash mặc định không."},"git.useIntegratedAskPass":{"type":"boolean","default":true,"description":"Điều khiển việc có ghi đè GIT_ASKPASS để sử dụng phiên bản tích hợp không."},"git.githubAuthentication":{"markdownDeprecationMessage":"This setting is now deprecated, please use `#github.gitAuthentication#` instead."},"git.timeline.date":{"type":"string","enum":["committed","authored"],"enumDescriptions":["Sử dụng ngày commit","Sử dụng ngày tạo"],"default":"committed","description":"Điều khiển ngày tháng nào được sử dụng cho các mục trong chế độ xem dòng thời gian.","scope":"window"},"git.timeline.showAuthor":{"type":"boolean","default":true,"description":"Điều khiển việc có hiển thị tác giả commit trong chế độ xem dòng thời gian không.","scope":"window"},"git.timeline.showUncommitted":{"type":"boolean","default":false,"description":"Điều khiển việc có hiển thị tác giả commit trong chế độ xem dòng thời gian không.","scope":"window"},"git.showActionButton":{"type":"object","additionalProperties":false,"description":"Điều khiển việc liệu có hiển thị nút hành động trong chế độ xem kiểm soát nguồn hay không.","properties":{"commit":{"type":"boolean","description":"Hiển thị nút hành động để đẩy thay đổi khi nhánh cục bộ chứa các tệp đã thay đổi sẵn sàng để đẩy."},"publish":{"type":"boolean","description":"Hiển thị nút hành động để xuất bản nhánh cục bộ nếu nó không có nhánh từ xa theo dõi."},"sync":{"type":"boolean","description":"Hiển thị nút hành động để đồng bộ thay đổi khi nhánh cục bộ ở phía trước hoặc phía sau nhánh từ xa."}},"default":{"commit":true,"publish":true,"sync":true},"scope":"resource"},"git.statusLimit":{"type":"number","scope":"resource","default":10000,"description":"Điều khiển cách giới hạn số lượng thay đổi có thể phân tích qua lệnh trạng thái Git. Có thể đặt thành 0 để không đặt giới hạn."},"git.repositoryScanIgnoredFolders":{"type":"array","items":{"type":"string"},"default":["node_modules"],"scope":"resource","markdownDescription":"Danh sách các thư mục bị bỏ qua khi quét tìm kho lưu trữ Git nếu \"#git.autoRepositoryDetection#\" được đặt thành \"TRUE\" hoặc \"subFolders\"."},"git.repositoryScanMaxDepth":{"type":"number","scope":"resource","default":1,"markdownDescription":"Điều khiển độ sâu được sử dụng khi kiểm tra các thư mục không gian làm việc cho kho lưu trữ Git nếu \"#git.autoRepositoryDetection#\" được đặt thành \"TRUE\" hoặc \"subFolders\". Có thể đặt thành \"-1\" để không giới hạn."},"git.commandsToLog":{"type":"array","items":{"type":"string"},"default":[],"markdownDescription":"Danh sách các lệnh Git (ví dụ: commit, push) mà \"stdout\" của chúng sẽ được ghi lại trong [Git Output](command:git.showOutput). Nếu một hook phía client được cấu hình cho lệnh Git, \"stdout\" của hook đó cũng sẽ được ghi lại trong [Git Output](command:git.showOutput)."},"git.mergeEditor":{"type":"boolean","default":false,"markdownDescription":"Mở trình chỉnh sửa hợp nhất cho các tệp hiện đang xung đột.","scope":"window"},"git.optimisticUpdate":{"type":"boolean","default":true,"markdownDescription":"Điều khiển việc cập nhật lạc quan chế độ xem quản lý mã nguồn sau khi thực thi lệnh Git.","scope":"resource","tags":["experimental"]},"git.openRepositoryInParentFolders":{"type":"string","enum":["always","never","prompt"],"enumDescriptions":["Luôn mở kho trong các thư mục cha của không gian làm việc hoặc tệp đang mở.","Không bao giờ mở kho trong các thư mục cha của không gian làm việc hoặc tệp đang mở.","Nhắc trước khi mở kho trong các thư mục cha của không gian làm việc hoặc tệp đang mở."],"default":"prompt","markdownDescription":"Điều khiển việc có nên mở kho trong các thư mục cha của không gian làm việc hoặc tệp đang mở hay không.","scope":"resource"},"git.similarityThreshold":{"type":"number","default":50,"minimum":0,"maximum":100,"markdownDescription":"Điều chỉnh ngưỡng chỉ số tương đồng (số lần thêm/xóa so với kích thước tệp) mà từ đó các thay đổi trong một cặp tệp được thêm/xóa được coi là đổi tên. **Lưu ý:** Yêu cầu Git phiên bản 2.18.0 trở lên.","scope":"resource"},"git.blame.editorDecoration.enabled":{"type":"boolean","default":false,"markdownDescription":"Điều khiển việc thông tin blame có được hiển thị trong trình soạn thảo bằng cách sử dụng trang trí trình soạn thảo hay không."},"git.blame.editorDecoration.template":{"type":"string","default":"${subject}, ${authorName} (${authorDateAgo})","markdownDescription":"Mẫu cho trang trí trình soạn thảo của thông tin blame. Các biến được hỗ trợ:\r\n\r\n* 'hash': Hash commit\r\n\r\n* 'hashShort': N ký tự đầu tiên của hash commit theo '#git.commitShortHashLength#'\r\n\r\n* 'subject': Dòng đầu tiên của thông điệp commit\r\n\r\n* 'authorName': Tên tác giả\r\n\r\n* 'authorEmail': Địa chỉ email của tác giả\r\n\r\n* 'authorDate': Ngày tạo\r\n\r\n* 'authorDateAgo': Khoảng thời gian từ bây giờ đến ngày tạo\r\n\r\n"},"git.blame.editorDecoration.disableHover":{"type":"boolean","default":false,"markdownDescription":"Controls whether to disable the blame information editor decoration hover."},"git.blame.statusBarItem.enabled":{"type":"boolean","default":true,"markdownDescription":"Điều khiển việc thông tin blame có được hiển thị trong thanh trạng thái hay không."},"git.blame.statusBarItem.template":{"type":"string","default":"${authorName} (${authorDateAgo})","markdownDescription":"Mẫu cho mục thanh trạng thái của thông tin blame. Các biến được hỗ trợ:\r\n\r\n* 'hash': Hash commit\r\n\r\n* 'hashShort': N ký tự đầu tiên của hash commit theo '#git.commitShortHashLength#'\r\n\r\n* 'subject': Dòng đầu tiên của thông điệp commit\r\n\r\n* 'authorName': Tên tác giả\r\n\r\n* 'authorEmail': Địa chỉ email của tác giả\r\n\r\n* 'authorDate': Ngày tạo\r\n\r\n* 'authorDateAgo': Khoảng thời gian từ bây giờ đến ngày tạo\r\n\r\n"},"git.blame.ignoreWhitespace":{"type":"boolean","default":false,"markdownDescription":"Controls whether to ignore whitespace changes when computing blame information."},"git.commitShortHashLength":{"type":"number","default":7,"minimum":7,"maximum":40,"markdownDescription":"Điều khiển độ dài của mã băm commit rút gọn.","scope":"resource"},"git.diagnosticsCommitHook.enabled":{"type":"boolean","default":false,"markdownDescription":"Điều khiển việc có kiểm tra các chẩn đoán chưa được giải quyết trước khi commit hay không.","scope":"resource"},"git.diagnosticsCommitHook.sources":{"type":"object","additionalProperties":{"type":"string","enum":["error","warning","information","hint","none"]},"default":{"*":"error"},"markdownDescription":"Điều khiển danh sách các nguồn (**Phần tử**) và mức độ nghiêm trọng tối thiểu (**Giá trị**) cần xem xét trước khi commit. **Lưu ý:** Để bỏ qua chẩn đoán từ một nguồn cụ thể, hãy thêm nguồn đó vào danh sách và đặt mức độ nghiêm trọng tối thiểu thành 'không'.","scope":"resource"},"git.discardUntrackedChangesToTrash":{"type":"boolean","default":true,"markdownDescription":"Điều khiển việc loại bỏ các thay đổi không được theo dõi có di chuyển tệp vào Thùng rác (Windows), Thùng rác (macOS, Linux) thay vì xóa vĩnh viễn hay không. **Lưu ý:** Cài đặt này không có hiệu lực khi kết nối với máy từ xa hoặc khi chạy trên Linux dưới dạng gói Snap."},"git.showReferenceDetails":{"type":"boolean","default":true,"markdownDescription":"Điều khiển việc liệu có hiển thị chi tiết của commit cuối cùng cho các tham chiếu Git trong hộp chọn Checkout, Branch và Tag hay không."}}},"colors":[{"id":"gitDecoration.addedResourceForeground","description":"Màu cho tài nguyên đã thêm.","defaults":{"light":"#587c0c","dark":"#81b88b","highContrast":"#a1e3ad","highContrastLight":"#374e06"}},{"id":"gitDecoration.modifiedResourceForeground","description":"Màu cho tài nguyên đã thay đổi.","defaults":{"light":"#895503","dark":"#E2C08D","highContrast":"#E2C08D","highContrastLight":"#895503"}},{"id":"gitDecoration.deletedResourceForeground","description":"Màu cho tài nguyên đã xóa.","defaults":{"light":"#ad0707","dark":"#c74e39","highContrast":"#c74e39","highContrastLight":"#ad0707"}},{"id":"gitDecoration.renamedResourceForeground","description":"Màu cho tài nguyên đã đổi tên hoặc sao chép.","defaults":{"light":"#007100","dark":"#73C991","highContrast":"#73C991","highContrastLight":"#007100"}},{"id":"gitDecoration.untrackedResourceForeground","description":"Màu sắc cho tài nguyên không được theo dõi.","defaults":{"light":"#007100","dark":"#73C991","highContrast":"#73C991","highContrastLight":"#007100"}},{"id":"gitDecoration.ignoredResourceForeground","description":"Màu cho tài nguyên bị bỏ qua.","defaults":{"light":"#8E8E90","dark":"#8C8C8C","highContrast":"#A7A8A9","highContrastLight":"#8e8e90"}},{"id":"gitDecoration.stageModifiedResourceForeground","description":"Màu cho tài nguyên đã thay đổi đã được staged.","defaults":{"light":"#895503","dark":"#E2C08D","highContrast":"#E2C08D","highContrastLight":"#895503"}},{"id":"gitDecoration.stageDeletedResourceForeground","description":"Màu cho tài nguyên đã xóa đã được staged.","defaults":{"light":"#ad0707","dark":"#c74e39","highContrast":"#c74e39","highContrastLight":"#ad0707"}},{"id":"gitDecoration.conflictingResourceForeground","description":"Màu cho tài nguyên có xung đột.","defaults":{"light":"#ad0707","dark":"#e4676b","highContrast":"#c74e39","highContrastLight":"#ad0707"}},{"id":"gitDecoration.submoduleResourceForeground","description":"Màu cho tài nguyên submodule.","defaults":{"light":"#1258a7","dark":"#8db9e2","highContrast":"#8db9e2","highContrastLight":"#1258a7"}},{"id":"git.blame.editorDecorationForeground","description":"Màu cho trang trí trình chỉnh sửa blame.","defaults":{"dark":"editorInlayHint.foreground","light":"editorInlayHint.foreground","highContrast":"editorInlayHint.foreground","highContrastLight":"editorInlayHint.foreground"}}],"configurationDefaults":{"[git-commit]":{"editor.rulers":[50,72],"editor.wordWrap":"off","workbench.editor.restoreViewState":false},"[git-rebase]":{"workbench.editor.restoreViewState":false}},"viewsWelcome":[{"view":"scm","contents":"Nếu bạn muốn sử dụng các tính năng Git, hãy bật Git trong [cài đặt](command:workbench.action.openSettings?%5B%22git.enabled%22%5D) của bạn.\r\nTìm hiểu thêm về cách sử dụng Git và quản lý mã nguồn trong VS Code [tại tài liệu của chúng tôi](https://aka.ms/vscode-scm).","when":"!config.git.enabled"},{"view":"scm","contents":"Cài đặt Git, một hệ thống quản lý mã nguồn phổ biến, để theo dõi thay đổi mã và cộng tác với người khác. Tìm hiểu thêm trong [hướng dẫn Git](https://aka.ms/vscode-scm) của chúng tôi.","when":"config.git.enabled && git.missing && remoteName != ''"},{"view":"scm","contents":"[Tải Git cho macOS](https://git-scm.com/download/mac)\r\nSau khi cài đặt, vui lòng [tải lại](command:workbench.action.reloadWindow) (hoặc [khắc phục sự cố](command:git.showOutput)). Các nhà cung cấp quản lý mã nguồn bổ sung có thể được cài đặt [từ Marketplace](command:workbench.extensions.search?%22%40category%3A%5C%22scm%20providers%5C%22%22).","when":"config.git.enabled && git.missing && remoteName == '' && isMac"},{"view":"scm","contents":"[Tải Git cho Windows](https://git-scm.com/download/win)\r\nSau khi cài đặt, vui lòng [tải lại](command:workbench.action.reloadWindow) (hoặc [khắc phục sự cố](command:git.showOutput)). Các nhà cung cấp quản lý mã nguồn bổ sung có thể được cài đặt [từ Marketplace](command:workbench.extensions.search?%22%40category%3A%5C%22scm%20providers%5C%22%22).","when":"config.git.enabled && git.missing && remoteName == '' && isWindows"},{"view":"scm","contents":"Quản lý mã nguồn phụ thuộc vào việc cài đặt Git.\r\n[Tải Git cho Linux](https://git-scm.com/download/linux)\r\nSau khi cài đặt, vui lòng [tải lại](command:workbench.action.reloadWindow) (hoặc [khắc phục sự cố](command:git.showOutput)). Các nhà cung cấp quản lý mã nguồn bổ sung có thể được cài đặt [từ Marketplace](command:workbench.extensions.search?%22%40category%3A%5C%22scm%20providers%5C%22%22).","when":"config.git.enabled && git.missing && remoteName == '' && isLinux"},{"view":"scm","contents":"Để sử dụng các tính năng Git, bạn có thể mở một thư mục chứa kho lưu trữ Git hoặc sao chép một kho lưu trữ từ URL.\r\n[Mở thư mục](command:vscode.openFolder)\r\n[Sao chép kho lưu trữ](command:git.cloneRecursive)\r\nTìm hiểu thêm về cách sử dụng Git và quản lý mã nguồn trong VS Code [tại tài liệu của chúng tôi](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && workbenchState == empty && git.parentRepositoryCount == 0 && git.unsafeRepositoryCount == 0 && git.closedRepositoryCount == 0","enablement":"git.state == initialized","group":"2_open@1"},{"view":"scm","contents":"Không gian làm việc hiện đang mở không chứa thư mục nào có kho lưu trữ Git.\r\n[Thêm thư mục vào không gian làm việc](command:workbench.action.addRootFolder)\r\nTìm hiểu thêm về cách sử dụng Git và quản lý mã nguồn trong VS Code [tại tài liệu của chúng tôi](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && workbenchState == workspace && workspaceFolderCount == 0 && git.parentRepositoryCount == 0 && git.unsafeRepositoryCount == 0 && git.closedRepositoryCount == 0","enablement":"git.state == initialized","group":"2_open@1"},{"view":"scm","contents":"Đang kiểm tra thư mục cho kho lưu trữ Git...","when":"config.git.enabled && !git.missing && workbenchState == folder && workspaceFolderCount != 0 && git.state != initialized"},{"view":"scm","contents":"Đang kiểm tra không gian làm việc cho kho lưu trữ Git...","when":"config.git.enabled && !git.missing && workbenchState == workspace && workspaceFolderCount != 0 && git.state != initialized"},{"view":"scm","contents":"Thư mục hiện đang mở không chứa kho lưu trữ Git. Bạn có thể khởi tạo một kho lưu trữ, điều này sẽ kích hoạt các tính năng quản lý mã nguồn của Git.\r\n[Khởi tạo kho lưu trữ](command:git.init?%5Btrue%5D)\r\nTìm hiểu thêm về cách sử dụng Git và quản lý mã nguồn trong VS Code [tại tài liệu của chúng tôi](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && git.state == initialized && workbenchState == folder && scm.providerCount == 0 && git.parentRepositoryCount == 0 && git.unsafeRepositoryCount == 0 && git.closedRepositoryCount == 0 && remoteName != 'codespaces'","group":"5_scm@1"},{"view":"scm","contents":"Không gian làm việc hiện đang mở không chứa thư mục nào có kho Git. Bạn có thể khởi tạo một kho cho một thư mục, điều này sẽ kích hoạt các tính năng Git để quản lý mã nguồn.\r\n[Khởi tạo kho](command:git.init)\r\nTìm hiểu thêm về cách sử dụng Git và quản lý mã nguồn trong VS Code [tại tài liệu của chúng tôi](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && git.state == initialized && workbenchState == workspace && workspaceFolderCount != 0 && scm.providerCount == 0 && git.parentRepositoryCount == 0 && git.unsafeRepositoryCount == 0 && git.closedRepositoryCount == 0 && remoteName != 'codespaces'","group":"5_scm@1"},{"view":"scm","contents":"Đã tìm thấy một kho lưu trữ Git trong thư mục cha của không gian làm việc hoặc tệp đang mở.\r\n[Mở kho lưu trữ](command:git.openRepositoriesInParentFolders)\r\nSử dụng cài đặt [git.openRepositoryInParentFolders](command:workbench.action.openSettings?%5B%22git.openRepositoryInParentFolders%22%5D) để kiểm soát việc có mở kho lưu trữ Git trong thư mục cha của không gian làm việc hoặc tệp đang mở hay không. Tìm hiểu thêm [tại tài liệu của chúng tôi](https://aka.ms/vscode-git-repository-in-parent-folders).","when":"config.git.enabled && !git.missing && git.state == initialized && git.parentRepositoryCount == 1"},{"view":"scm","contents":"Đã tìm thấy các kho lưu trữ Git trong thư mục cha của không gian làm việc hoặc tệp đang mở.\r\n[Mở kho lưu trữ](command:git.openRepositoriesInParentFolders)\r\nSử dụng cài đặt [git.openRepositoryInParentFolders](command:workbench.action.openSettings?%5B%22git.openRepositoryInParentFolders%22%5D) để kiểm soát việc có mở kho lưu trữ Git trong thư mục cha của không gian làm việc hoặc tệp đang mở hay không. Tìm hiểu thêm [tại tài liệu của chúng tôi](https://aka.ms/vscode-git-repository-in-parent-folders).","when":"config.git.enabled && !git.missing && git.state == initialized && git.parentRepositoryCount > 1"},{"view":"scm","contents":"Kho Git được phát hiện có thể không an toàn vì thư mục thuộc sở hữu của người khác chứ không phải người dùng hiện tại.\r\n[Quản lý kho không an toàn](command:git.manageUnsafeRepositories)\r\nTìm hiểu thêm về kho không an toàn trong [tài liệu của chúng tôi](https://aka.ms/vscode-git-unsafe-repository).","when":"config.git.enabled && !git.missing && git.state == initialized && git.unsafeRepositoryCount == 1"},{"view":"scm","contents":"Các kho Git được phát hiện có thể không an toàn vì các thư mục thuộc sở hữu của người khác chứ không phải người dùng hiện tại.\r\n[Quản lý kho không an toàn](command:git.manageUnsafeRepositories)\r\nTìm hiểu thêm về kho không an toàn trong [tài liệu của chúng tôi](https://aka.ms/vscode-git-unsafe-repository).","when":"config.git.enabled && !git.missing && git.state == initialized && git.unsafeRepositoryCount > 1"},{"view":"scm","contents":"Đã tìm thấy một kho lưu trữ Git đã đóng trước đó.\r\n[Mở lại kho lưu trữ đã đóng](command:git.reopenClosedRepositories)\r\nTìm hiểu thêm về cách sử dụng Git và quản lý mã nguồn trong VS Code [tại tài liệu của chúng tôi](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && git.state == initialized && git.closedRepositoryCount == 1"},{"view":"scm","contents":"Đã tìm thấy các kho lưu trữ Git đã đóng trước đó.\r\n[Mở lại kho lưu trữ đã đóng](command:git.reopenClosedRepositories)\r\nTìm hiểu thêm về cách sử dụng Git và quản lý mã nguồn trong VS Code [tại tài liệu của chúng tôi](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && git.state == initialized && git.closedRepositoryCount > 1"},{"view":"explorer","contents":"Bạn có thể sao chép một kho lưu trữ cục bộ.\r\n[Sao chép kho lưu trữ](command:git.clone 'Clone a repository once the git extension has activated')","when":"config.git.enabled && git.state == initialized && scm.providerCount == 0","group":"5_scm@1"},{"view":"explorer","contents":"Tìm hiểu thêm về cách sử dụng Git và quản lý mã nguồn trong VS Code [tại tài liệu của chúng tôi](https://aka.ms/vscode-scm).","when":"config.git.enabled && git.state == initialized && scm.providerCount == 0","group":"5_scm@10"}]},"repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/git","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.git-base"},"manifest":{"name":"git-base","displayName":"Cơ sở Git","description":"Các đóng góp và lựa chọn Git tĩnh.","version":"10.0.0","publisher":"vscode","license":"MIT","engines":{"vscode":"0.10.x"},"categories":["Other"],"activationEvents":["*"],"main":"./dist/extension.js","browser":"./dist/browser/extension.js","icon":"resources/icons/git.png","capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"contributes":{"commands":[{"command":"git-base.api.getRemoteSources","title":{"value":"Lấy nguồn từ xa","original":"Get Remote Sources"},"category":"Git Base API"}],"menus":{"commandPalette":[{"command":"git-base.api.getRemoteSources","when":"false"}]},"languages":[{"id":"git-commit","aliases":["Git Commit Message","git-commit"],"filenames":["COMMIT_EDITMSG","MERGE_MSG"],"configuration":"./languages/git-commit.language-configuration.json"},{"id":"git-rebase","aliases":["Git Rebase Message","git-rebase"],"filenames":["git-rebase-todo"],"filenamePatterns":["**/rebase-merge/done"],"configuration":"./languages/git-rebase.language-configuration.json"},{"id":"ignore","aliases":["Ignore","ignore"],"extensions":[".gitignore_global",".gitignore",".git-blame-ignore-revs"],"configuration":"./languages/ignore.language-configuration.json"}],"grammars":[{"language":"git-commit","scopeName":"text.git-commit","path":"./syntaxes/git-commit.tmLanguage.json"},{"language":"git-rebase","scopeName":"text.git-rebase","path":"./syntaxes/git-rebase.tmLanguage.json"},{"language":"ignore","scopeName":"source.ignore","path":"./syntaxes/ignore.tmLanguage.json"}]},"repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/git-base","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.github"},"manifest":{"name":"github","displayName":"GitHub","description":"Tính năng GitHub cho VS Code","publisher":"vscode","license":"MIT","version":"0.0.1","engines":{"vscode":"^1.41.0"},"aiKey":"0c6ae279ed8