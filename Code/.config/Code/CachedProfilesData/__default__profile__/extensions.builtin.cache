ations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.css-language-features"},"manifest":{"name":"css-language-features","displayName":"Tính năng ngôn ngữ CSS","description":"Cung cấp hỗ trợ ngôn ngữ toàn diện cho các tệp CSS, LESS và SCSS.","version":"10.0.0","publisher":"vscode","license":"MIT","engines":{"vscode":"^1.77.0"},"icon":"icons/css.png","activationEvents":["onLanguage:css","onLanguage:less","onLanguage:scss","onCommand:_css.applyCodeAction"],"main":"./client/dist/node/cssClientMain","browser":"./client/dist/browser/cssClientMain","capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"categories":["Programming Languages"],"contributes":{"configuration":[{"order":22,"id":"css","title":"CSS","properties":{"css.customData":{"type":"array","markdownDescription":"Danh sách đường dẫn tệp tương đối tham chiếu đến các tệp JSON theo [định dạng dữ liệu tùy chỉnh](https://github.com/microsoft/vscode-css-languageservice/blob/master/docs/customData.md).\r\n\r\nVS Code tải dữ liệu tùy chỉnh khi khởi động để cải thiện hỗ trợ CSS cho các thuộc tính CSS tùy chỉnh (biến), quy tắc @, lớp giả và phần tử giả mà bạn chỉ định trong tệp JSON.\r\n\r\nĐường dẫn tệp được chỉ định tương đối với không gian làm việc và chỉ các cài đặt cho thư mục không gian làm việc được xem xét.","default":[],"items":{"type":"string"},"scope":"resource"},"css.completion.triggerPropertyValueCompletion":{"type":"boolean","scope":"resource","default":true,"description":"Theo mặc định, VS Code kích hoạt hoàn tất giá trị thuộc tính sau khi chọn một thuộc tính CSS. Dùng cài đặt này để tắt hành vi đó."},"css.completion.completePropertyWithSemicolon":{"type":"boolean","scope":"resource","default":true,"description":"Chèn dấu chấm phẩy ở cuối dòng khi hoàn tất thuộc tính CSS."},"css.validate":{"type":"boolean","scope":"resource","default":true,"description":"Bật hoặc tắt tất cả các kiểm tra."},"css.hover.documentation":{"type":"boolean","scope":"resource","default":true,"description":"Hiển thị tài liệu thuộc tính và giá trị trong CSS hovers."},"css.hover.references":{"type":"boolean","scope":"resource","default":true,"description":"Hiển thị các tham chiếu đến MDN trong CSS hovers."},"css.lint.compatibleVendorPrefixes":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","description":"Khi sử dụng tiền tố nhà cung cấp cụ thể, hãy đảm bảo bao gồm tất cả các thuộc tính cụ thể của nhà cung cấp khác."},"css.lint.vendorPrefix":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"warning","description":"Khi sử dụng tiền tố nhà cung cấp cụ thể, hãy bao gồm cả thuộc tính chuẩn."},"css.lint.duplicateProperties":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","description":"Không sử dụng các định nghĩa định dạng trùng lặp."},"css.lint.emptyRules":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"warning","description":"Không sử dụng các quy tắc rỗng."},"css.lint.importStatement":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","description":"Các câu lệnh import không được tải song song."},"css.lint.boxModel":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","markdownDescription":"Không sử dụng \"width\" hoặc \"height\" khi đang sử dụng \"padding\" hoặc \"border\"."},"css.lint.universalSelector":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","markdownDescription":"Bộ chọn toàn cục (*) được biết là chậm."},"css.lint.zeroUnits":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","description":"Không cần đơn vị cho số không."},"css.lint.fontFaceProperties":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"warning","markdownDescription":"Quy tắc `@font-face` phải định nghĩa các thuộc tính `src` và `font-family`."},"css.lint.hexColorLength":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"error","description":"Màu hex phải bao gồm 3, 4, 6 hoặc 8 chữ số hex."},"css.lint.argumentsInColorFunction":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"error","description":"Số lượng tham số không hợp lệ."},"css.lint.unknownProperties":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"warning","description":"Thuộc tính không xác định."},"css.lint.validProperties":{"type":"array","uniqueItems":true,"items":{"type":"string"},"scope":"resource","default":[],"description":"Một danh sách các thuộc tính không được kiểm tra khớp với quy tắc \"unknownProperties\"."},"css.lint.ieHack":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","description":"Các hack IE chỉ cần thiết để hỗ trợ IE7 trở xuống."},"css.lint.unknownVendorSpecificProperties":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","description":"Thuộc tính đặc thù nhà cung cấp không xác định."},"css.lint.propertyIgnoredDueToDisplay":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"warning","markdownDescription":"Thuộc tính bị bỏ qua do hiển thị. Ví dụ: chỉ định \"display: inline\" sẽ làm cho các thuộc tính \"width\", \"height\", \"margin-top\", \"margin-bottom\" và \"float\" không có hiệu lực."},"css.lint.important":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","markdownDescription":"Tránh sử dụng \"!important\". Nó chỉ ra rằng có vấn đề với tính cụ thể của toàn bộ mã CSS và cần được cấu trúc lại."},"css.lint.float":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","markdownDescription":"Tránh sử dụng \"float\". Các thuộc tính float dễ dẫn đến CSS bị hỏng khi một khía cạnh của bố cục thay đổi."},"css.lint.idSelector":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"ignore","description":"Bộ chọn không nên chứa ID vì các quy tắc này quá gắn chặt với HTML."},"css.lint.unknownAtRules":{"type":"string","scope":"resource","enum":["ignore","warning","error"],"default":"warning","description":"Quy tắc @ không xác định."},"css.trace.server":{"type":"string","scope":"window","enum":["off","messages","verbose"],"default":"off","description":"Theo dõi giao tiếp giữa VS Code và máy chủ ngôn ngữ CSS."},"css.format.enable":{"type":"boolean","scope":"window","default":true,"description":"Bật/Tắt trình định dạng CSS mặc định."},"css.format.newlineBetweenSelectors":{"type":"boolean","scope":"resource","default":true,"markdownDescription":"Phân tách các bộ chọn bằng một dòng mới."},"css.format.newlineBetweenRules":{"type":"boolean","scope":"resource","default":true,"markdownDescription":"Phân tách các quy tắc bằng một dòng trống."},"css.format.spaceAroundSelectorSeparator":{"type":"boolean","scope":"resource","default":false,"markdownDescription":"Đảm bảo có khoảng trắng xung quanh các dấu phân cách bộ chọn \">\", \"+\", \"~\" (ví dụ: \"a > b\")."},"css.format.braceStyle":{"type":"string","scope":"resource","default":"collapse","enum":["collapse","expand"],"markdownDescription":"Chèn dấu ngoặc nhọn cùng dòng với quy tắc (`collapse`) hoặc dấu ngoặc nhọn trên dòng riêng (`expand`)."},"css.format.preserveNewLines":{"type":"boolean","scope":"resource","default":true,"markdownDescription":"Chỉ định liệu có giữ lại các ngắt dòng hiện có trước các quy tắc và khai báo hay không."},"css.format.maxPreserveNewLines":{"type":["number","null"],"scope":"resource","default":null,"markdownDescription":"Số dòng tối đa được giữ trong một khối khi `#css.format.preserveNewLines#` được bật."}}},{"id":"scss","order":24,"title":"SCSS (SASS)","properties":{"scss.completion.triggerPropertyValueCompletion":{"type":"boolean","scope":"resource","default":true,"description":"Theo mặc định, VS Code kích 