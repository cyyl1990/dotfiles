ile"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.references-view"},"manifest":{"name":"references-view","displayName":"Chế độ xem tìm kiếm tham chiếu","description":"Kết quả tìm kiếm tham chiếu dưới dạng chế độ xem riêng biệt, ổn định trong thanh bên","icon":"media/icon.png","version":"10.0.0","publisher":"vscode","license":"MIT","engines":{"vscode":"^1.67.0"},"capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"repository":{"type":"git","url":"https://github.com/Microsoft/vscode-references-view"},"bugs":{"url":"https://github.com/Microsoft/vscode-references-view/issues"},"activationEvents":["onCommand:references-view.find","onCommand:editor.action.showReferences"],"main":"./dist/extension","browser":"./dist/browser/extension","contributes":{"configuration":{"properties":{"references.preferredLocation":{"description":"Điều khiển việc gọi \"Xem tham chiếu\" hay \"Tìm tham chiếu\" khi chọn các tham chiếu CodeLens.","type":"string","default":"peek","enum":["peek","view"],"enumDescriptions":["Hiển thị tham chiếu trong trình chỉnh sửa Peek.","Hiển thị tham chiếu trong chế độ xem riêng biệt."]}}},"viewsContainers":{"activitybar":[{"id":"references-view","icon":"$(references)","title":"Tham chiếu"}]},"views":{"references-view":[{"id":"references-view.tree","name":"Kết quả tìm kiếm tham chiếu","when":"reference-list.isActive"}]},"commands":[{"command":"references-view.findReferences","title":{"value":"Tìm tất cả tham chiếu","original":"Find All References"},"category":{"value":"Tham chiếu","original":"References"}},{"command":"references-view.findImplementations","title":{"value":"Tìm tất cả triển khai","original":"Find All Implementations"},"category":{"value":"Tham chiếu","original":"References"}},{"command":"references-view.clearHistory","title":{"value":"Xóa lịch sử","original":"Clear History"},"category":{"value":"Tham chiếu","original":"References"},"icon":"$(clear-all)"},{"command":"references-view.clear","title":{"value":"Xóa","original":"Clear"},"category":{"value":"Tham chiếu","original":"References"},"icon":"$(clear-all)"},{"command":"references-view.refresh","title":{"value":"Cập nhật","original":"Refresh"},"category":{"value":"Tham chiếu","original":"References"},"icon":"$(refresh)"},{"command":"references-view.pickFromHistory","title":{"value":"Hiển thị lịch sử","original":"Show History"},"category":{"value":"Tham chiếu","original":"References"}},{"command":"references-view.removeReferenceItem","title":{"value":"Đóng","original":"Dismiss"},"icon":"$(close)"},{"command":"references-view.copy","title":{"value":"Sao chép","original":"Copy"}},{"command":"references-view.copyAll","title":{"value":"Sao chép tất cả","original":"Copy All"}},{"command":"references-view.copyPath","title":{"value":"Sao chép đường dẫn","original":"Copy Path"}},{"command":"references-view.refind","title":{"value":"Chạy lại","original":"Rerun"},"icon":"$(refresh)"},{"command":"references-view.showCallHierarchy","title":{"value":"Hiển thị hệ thống phân cấp gọi","original":"Show Call Hierarchy"},"category":"Calls"},{"command":"references-view.showOutgoingCalls","title":{"value":"Hiển thị cuộc gọi đi","original":"Show Outgoing Calls"},"category":"Calls","icon":"$(call-incoming)"},{"command":"references-view.showIncomingCalls","title":{"value":"Hiển thị cuộc gọi đến","original":"Show Incoming Calls"},"category":"Calls","icon":"$(call-outgoing)"},{"command":"references-view.removeCallItem","title":{"value":"Đóng","original":"Dismiss"},"icon":"$(close)"},{"command":"references-view.next","title":{"value":"Chuyển đến tham chiếu tiếp theo","original":"Go to Next Reference"},"enablement":"references-view.canNavigate"},{"command":"references-view.prev","title":{"value":"Chuyển đến tham chiếu trước đó","original":"Go to Previous Reference"},"enablement":"references-view.canNavigate"},{"command":"references-view.showTypeHierarchy","title":{"v