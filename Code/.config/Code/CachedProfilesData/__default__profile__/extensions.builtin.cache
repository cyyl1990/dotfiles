"},{"command":"markdown.showLockedPreviewToSide","title":{"value":"Mở xem trước đã khóa ở bên cạnh","original":"Open Locked Preview to the Side"},"category":"Markdown","icon":"$(open-preview)"},{"command":"markdown.showSource","title":{"value":"Hiển thị nguồn","original":"Show Source"},"category":"Markdown","icon":"$(go-to-file)"},{"command":"markdown.showPreviewSecuritySelector","title":{"value":"Thay đổi cài đặt bảo mật cho xem trước","original":"Change Preview Security Settings"},"category":"Markdown"},{"command":"markdown.preview.refresh","title":{"value":"Cập nhật xem trước","original":"Refresh Preview"},"category":"Markdown"},{"command":"markdown.preview.toggleLock","title":{"value":"Chuyển đổi khóa xem trước","original":"Toggle Preview Locking"},"category":"Markdown"},{"command":"markdown.findAllFileReferences","title":{"value":"Tìm tham chiếu tệp","original":"Find File References"},"category":"Markdown"},{"command":"markdown.editor.insertLinkFromWorkspace","title":{"value":"Dán liên kết đến tệp trong không gian làm việc","original":"Insert Link to File in Workspace"},"category":"Markdown","enablement":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !activeEditorIsReadonly"},{"command":"markdown.editor.insertImageFromWorkspace","title":{"value":"Dán hình ảnh từ không gian làm việc","original":"Insert Image from Workspace"},"category":"Markdown","enablement":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !activeEditorIsReadonly"}],"menus":{"webview/context":[{"command":"_markdown.copyImage","when":"webviewId == 'markdown.preview' && (webviewSection == 'image' || webviewSection == 'localImage')"},{"command":"_markdown.openImage","when":"webviewId == 'markdown.preview' && webviewSection == 'localImage'"}],"editor/title":[{"command":"markdown.showPreviewToSide","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused && !hasCustomMarkdownPreview","alt":"markdown.showPreview","group":"navigation"},{"command":"markdown.showSource","when":"activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'","group":"navigation"},{"command":"markdown.preview.refresh","when":"activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'","group":"1_markdown"},{"command":"markdown.preview.toggleLock","when":"activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'","group":"1_markdown"},{"command":"markdown.showPreviewSecuritySelector","when":"activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'","group":"1_markdown"}],"explorer/context":[{"command":"markdown.showPreview","when":"resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !hasCustomMarkdownPreview","group":"navigation"},{"command":"markdown.findAllFileReferences","when":"resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/","group":"4_search"}],"editor/title/context":[{"command":"markdown.showPreview","when":"resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !hasCustomMarkdownPreview","group":"1_open"},{"command":"markdown.findAllFileReferences","when":"resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/"}],"commandPalette":[{"command":"_markdown.openImage","when":"false"},{"command":"_markdown.copyImage","when":"false"},{"command":"markdown.showPreview","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused","group":"navigation"},{"command":"markdown.showPreviewToSide","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused","group":"navigation"},{"command":"markdown.showLockedPreviewToSide","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused","group":"navigation"},{"command":"markdown.showSource","when":"activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'","group":"navigation"},{"command":"markdown.showPreviewSecuritySelector","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused"},{"command":"markdown.showPreviewSecuritySelector","when":"activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'"},{"command":"markdown.preview.toggleLock","when":"activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'"},{"command":"markdown.preview.refresh","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused"},{"command":"markdown.preview.refresh","when":"activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'"},{"command":"markdown.findAllFileReferences","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/"}]},"keybindings":[{"command":"markdown.showPreview","key":"shift+ctrl+v","mac":"shift+cmd+v","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused"},{"command":"markdown.showPreviewToSide","key":"ctrl+k v","mac":"cmd+k v","when":"editorLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/ && !notebookEditorFocused"}],"configuration":{"type":"object","title":"Markdown","order":20,"properties":{"markdown.styles":{"type":"array","items":{"type":"string"},"default":[],"description":"Danh sách các URL hoặc đường dẫn cục bộ đến bảng định kiểu CSS sẽ được sử dụng trong phần xem trước Markdown. Đường dẫn tương đối được hiểu so với thư mục đang mở trong Explorer. Nếu không có thư mục nào mở, chúng được hiểu so với vị trí của tệp Markdown. Tất cả '\\ phải được viết là '\\\\'.","scope":"resource"},"markdown.preview.breaks":{"type":"boolean","default":false,"markdownDescription":"Xác định cách ngắt dòng được hiển thị trong bản xem trước Markdown. Đặt thành TRUE sẽ tạo \"<br>\" cho ngắt dòng bên trong đoạn văn.","scope":"resource"},"markdown.preview.linkify":{"type":"boolean","default":true,"description":"Chuyển đổi văn bản giống URL thành liên kết trong phần xem trước Markdown.","scope":"resource"},"markdown.preview.typographer":{"type":"boolean","default":false,"description":"Bật thay thế ngôn ngữ trung lập và tùy chỉnh dấu ngoặc kép trong phần xem trước Markdown.","scope":"resource"},"markdown.preview.fontFamily":{"type":"string","default":"-apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif","description":"Điều khiển họ phông chữ được sử dụng trong phần xem trước Markdown.","scope":"resource"},"markdown.preview.fontSize":{"type":"number","default":14,"description":"Điều khiển kích thước phông chữ tính bằng pixel được sử dụng trong phần xem trước Markdown.","scope":"resource"},"markdown.preview.lineHeight":{"type":"number","default":1.6,"description":"Điều khiển chiều cao dòng được sử dụng trong phần xem trước Markdown. Giá trị này tương đối so với kích thước phông chữ.","scope":"resource"},"markdown.preview.scrollPreviewWithEditor":{"type":"boolean","default":true,"description":"Cập nhật chế độ xem của phần xem trước khi cuộn trong trình soạn thảo Markdown.","scope":"resource"},"markdown.preview.markEditorSelection":{"type":"boolean","default":true,"description":"Đánh dấu vùng chọn hiện tại của trình soạn thảo trong phần xem trước Markdown.","scope":"resource"},"markdown.preview.scrollEditorWithPreview":{"type":"boolean","default":true,"description":"Cập nhật chế độ xem của trình soạn thảo khi cuộn trong phần xem trước Markdown.","scope":"resource"},"markdown.preview.doubleClickToSwitchToEditor":{"type":"boolean","default":true,"description":"Để chuyển sang trình soạn thảo, hãy nhấp đúp vào phần xem trước Markdown.","scope":"resource"},"markdown.preview.openMarkdownLinks":{"type":"string","default":"inPreview","description":"Điều khiển cách mở liên kết đến các tệp Markdown khác trong bản xem trước Markdown.","scope":"resource","enum":["inPreview","inEditor"],"enumDescriptions":["Mở liên kết trong bản xem trước Markdown","Mở liên kết trong trình soạn thảo"]},"markdown.links.openLocation":{"type":"string","default":"currentGroup","description":"Điều khiển nơi mở liên kết trong các tệp Markdown.","scope":"resource","enum":["currentGroup","beside"],"enumDescriptions":["Mở liên kết trong nhóm trình soạn thảo đang hoạt động.","Mở các liên kết bên cạnh trình soạn thảo đang hoạt động."]},"markdown.suggest.paths.enabled":{"type":"boolean","default":true,"description":"Bật gợi ý đường dẫn trong khi bạn viết liên kết trong các tệp Markdown.","scope":"resource"},"markdown.suggest.paths.includeWorkspaceHeaderCompletions":{"type":"string","default":"onDoubleHash","scope":"resource","markdownDescription":"Bật gợi ý tiêu đề trong các tệp Markdown khác trong không gian làm việc hiện tại. Khi chấp nhận một trong những gợi ý này, đường dẫn đầy đủ đến tiêu đề trong tệp đó sẽ được chèn, ví dụ: \"[Văn bản liên kết](/đường/dẫn/đến/tệp.md#tiêu-đề)\".","enum":["never","onDoubleHash","onSingleOrDoubleHash"],"markdownEnumDescriptions":["Tắt gợi ý tiêu đề không gian làm việc.","Bật gợi ý tiêu đề không gian làm việc sau khi nhập \"##\" vào đường dẫn, ví dụ: \"[Văn bản liên kết](##).\"","Kích hoạt gợi ý tiêu đề không gian làm việc sau khi nhập \"##\" hoặc \"#\" vào đường dẫn, ví dụ: \"[Văn bản liên kết](#)\" hoặc \"[Văn bản liên kết](##).\""]},"markdown.trace.server":{"type":"string","scope":"window","enum":["off","messages","verbose"],"default":"off","description":"Theo dõi giao tiếp giữa VS Code và máy chủ ngôn ngữ Markdown."},"markdown.server.log":{"type":"string","scope":"window","enum":["off","debug","trace"],"default":"off","description":"Điều khiển mức độ ghi nhật ký của máy chủ ngôn ngữ Markdown."},"markdown.editor.drop.enabled":{"type":"string","scope":"resource","markdownDescription":"Kích hoạt thả tệp vào trình soạn thảo Markdown trong khi giữ phím SHIFT. Yêu cầu kích hoạt \"#editor.dropIntoEditor.enabled#\".","default":"smart","enum":["always","smart","never"],"markdownEnumDescriptions":["Luôn chèn liên kết Markdown.","Mặc định tạo liên kết Markdown một cách thông minh khi chúng không rơi vào khối mã hoặc phần tử đặc biệt khác. Sử dụng widget thả để chuyển đổi giữa chèn dưới dạng văn bản thuần hoặc liên kết Markdown.","Không bao giờ tạo liên kết Markdown."]},"markdown.editor.drop.copyIntoWorkspace":{"type":"string","markdownDescription":"Điều khiển việc các tệp bên ngoài không gian làm việc được thả vào trình soạn thảo Markdown có nên được sao chép vào không gian làm việc hay không.\r\n\r\nSử dụng \"#markdown.copyFiles.destination#\" để cấu hình nơi tạo các tệp đã sao chép, đã thả.","default":"mediaFiles","enum":["mediaFiles","never"],"markdownEnumDescriptions":["Thử sao chép các tệp hình ảnh và video bên ngoài vào không gian làm việc.","Không sao chép tệp bên ngoài vào không gian làm việc."]},"markdown.editor.filePaste.enabled":{"type":"string","scope":"resource","markdownDescription":"Bật tính năng dán tệp vào trình soạn thảo Markdown để tạo liên kết Markdown. Yêu cầu bật \"#editor.pasteAs.enabled#\".","default":"smart","enum":["always","smart","never"],"markdownEnumDescriptions":["Luôn chèn liên kết Markdown.","Mặc định tạo liên kết Markdown một cách thông minh khi chúng không được dán vào khối mã hoặc phần tử đặc biệt khác. Sử dụng widget dán để chuyển đổi giữa dán dưới dạng văn bản thuần hoặc liên kết Markdown.","Không bao giờ tạo liên kết Markdown."]},"markdown.editor.filePaste.copyIntoWorkspace":{"type":"string","markdownDescription":"Điều khiển việc liệu các tệp bên ngoài không gian làm việc được dán vào trình soạn thảo Markdown có nên được sao chép vào không gian làm việc hay không.\r\n\r\nSử dụng \"#markdown.copyFiles.destination#\" để cấu hình nơi tạo các tệp đã sao chép.","default":"mediaFiles","enum":["mediaFiles","never"],"markdownEnumDescriptions":["Thử sao chép các tệp hình ảnh và video bên ngoài vào không gian làm việc.","Không sao chép tệp bên ngoài vào không gian làm việc."]},"markdown.editor.filePaste.videoSnippet":{"type":"string","markdownDescription":"Đoạn mã được sử dụng khi thêm video vào Markdown. Đoạn mã này có thể sử dụng các biến sau:\r\n– \"${src}\" – Đường dẫn đã giải quyết của tệp video.\r\n– \"${title}\" – Tiêu đề được sử dụng cho video. Một trình giữ chỗ đoạn mã sẽ tự động được tạo cho biến này.","default":"<video controls src=\"${src}\" title=\"${title}\"></video>"},"markdown.editor.filePaste.audioSnippet":{"type":"string","markdownDescription":"Đoạn mã được sử dụng khi thêm âm thanh vào Markdown. Đoạn mã này có thể sử dụng các biến sau:\r\n– \"${src}\" – Đường dẫn đã giải quyết của tệp âm thanh.\r\n– \"${title}\" – Tiêu đề được sử dụng cho âm thanh. Một trình giữ chỗ đoạn mã sẽ tự động được tạo cho biến này.","default":"<audio controls src=\"${src}\" title=\"${title}\"></audio>"},"markdown.editor.pasteUrlAsFormattedLink.enabled":{"type":"string","scope":"resource","markdownDescription":"Điều khiển việc liệu liên kết Markdown có được tạo khi URL được dán vào trình soạn thảo Markdown hay không. Yêu cầu bật \"#editor.pasteAs.enabled#\".","default":"smartWithSelection","enum":["always","smart","smartWithSelection","never"],"markdownEnumDescriptions":["Luôn chèn liên kết Markdown.","Mặc định tạo liên kết Markdown một cách thông minh khi chúng không được dán vào khối mã hoặc phần tử đặc biệt khác. Sử dụng widget dán để chuyển đổi giữa dán dưới dạng văn bản thuần hoặc liên kết Markdown.","Mặc định tạo liên kết Markdown thông minh khi bạn có văn bản được chọn và không dán vào khối mã hoặc phần tử đặc biệt khác. Sử dụng tiện ích dán để chuyển đổi giữa dán dưới dạng văn bản thuần hoặc liên kết Markdown.","Không bao giờ tạo liên kết Markdown."]},"markdown.validate.enabled":{"type":"boolean","scope":"resource","description":"Bật tất cả báo cáo lỗi trong tệp Markdown.","default":false},"markdown.validate.referenceLinks.enabled":{"type":"string","scope":"resource","markdownDescription":"Kiểm tra liên kết tham chiếu trong tệp Markdown, ví dụ: \"[link][ref]\". Yêu cầu bật \"#markdown.validate.enabled#\".","default":"warning","enum":["ignore","warning","error"]},"markdown.validate.fragmentLinks.enabled":{"type":"string","scope":"resource","markdownDescription":"Kiểm tra liên kết mảnh đến tiêu đề trong tệp Markdown hiện tại, ví dụ: \"[link](#header)\". Yêu cầu bật \"#markdown.validate.enabled#\".","default":"warning","enum":["ignore","warning","error"]},"markdown.validate.fileLinks.enabled":{"type":"string","scope":"resource","markdownDescription":"Kiểm tra liên kết đến các tệp khác trong tệp Markdown, ví dụ: \"[link](/path/to/file.md)\". Điều này kiểm tra xem tệp đích có tồn tại không. Yêu cầu bật \"#markdown.validate.enabled#\".","default":"warning","enum":["ignore","warning","error"]},"markdown.validate.fileLinks.markdownFragmentLinks":{"type":"string","scope":"resource","markdownDescription":"Kiểm tra phần mảnh của liên kết đến tiêu đề trong các tệp khác trong tệp Markdown, ví dụ: \"[link](/path/to/file.md#header)\". Mặc định kế thừa giá trị cài đặt từ \"#markdown.validate.fragmentLinks.enabled#\".","default":"inherit","enum":["inherit","ignore","warning","error"]},"markdown.validate.ignoredLinks":{"type":"array","scope":"resource","markdownDescription":"Cấu hình các liên kết không được kiểm tra. Ví dụ: thêm \"/about\" sẽ bỏ qua kiểm tra liên kết \"[about](/about)\", trong khi mẫu toàn cục \"/assets/**/*.svg\" có thể bỏ qua kiểm tra cho tất cả liên kết đến tệp \".svg\" trong thư mục \"assets\".","items":{"type":"string"}},"markdown.validate.unusedLinkDefinitions.enabled":{"type":"string","scope":"resource","markdownDescription":"Kiểm tra các định nghĩa liên kết không được sử dụng trong tệp hiện tại.","default":"hint","enum":["ignore","hint","warning","error"]},"markdown.validate.duplicateLinkDefinitions.enabled":{"type":"string","scope":"resource","markdownDescription":"Kiểm tra các định nghĩa trùng lặp trong tệp hiện tại.","default":"warning","enum":["ignore","warning","error"]},"markdown.updateLinksOnFileMove.enabled":{"type":"string","enum":["prompt","always","never"],"markdownEnumDescriptions":["Luôn hỏi khi di chuyển tệp.","Luôn tự động cập nhật liên kết.","Không bao giờ cập nhật liên kết và không hiển thị lời nhắc."],"default":"never","markdownDescription":"Cố gắng cập nhật liên kết trong tệp Markdown khi một tệp trong không gian làm việc được đổi tên/di chuyển. Sử dụng \"#markdown.updateLinksOnFileMove.include#\" để cấu hình tệp nào kích hoạt cập nhật liên kết.","scope":"window"},"markdown.updateLinksOnFileMove.include":{"type":"array","markdownDescription":"Mẫu toàn cục chỉ định các tệp kích hoạt cập nhật liên kết tự động. Xem \"#markdown.updateLinksOnFileMove.enabled#\" để biết chi tiết về tính năng này.","scope":"window","items":{"type":"string","description":"Mẫu toàn cục để so sánh với đường dẫn tệp. Đặt giá trị này thành \"true\" để bật mẫu."},"default":["**/*.{md,mkd,mdwn,mdown,markdown,markdn,mdtxt,mdtext,workbook}","**/*.{jpg,jpe,jpeg,png,bmp,gif,ico,webp,avif,tiff,svg,mp4}"]},"markdown.updateLinksOnFileMove.enableForDirectories":{"type":"boolean","default":true,"description":"Bật cập nhật liên kết khi một thư mục trong không gian làm việc được di chuyển hoặc đổi tên.","scope":"window"},"markdown.occurrencesHighlight.enabled":{"type":"boolean","default":false,"description":"Bật tính năng làm nổi bật các lần xuất hiện liên kết trong tài liệu hiện tại.","scope":"resource"},"markdown.copyFiles.destination":{"type":"object","markdownDescription":"Cấu hình đường dẫn và tên tệp của các tệp được tạo bằng cách sao chép/dán hoặc kéo & thả. Đây là một ánh xạ của các mẫu glob khớp với đường dẫn tài liệu Markdown với đường dẫn đích nơi tệp mới sẽ được tạo.\r\n\r\nĐường dẫn đích có thể sử dụng các biến sau:\r\n\r\n– „${documentDirName}“: Đường dẫn thư mục cha tuyệt đối của tài liệu Markdown, ví dụ: „/Users/me/myProject/docs“.\r\n– „${documentRelativeDirName}“: Đường dẫn thư mục cha tương đối của tài liệu Markdown, ví dụ: „docs“. Giống với „${documentDirName}“ nếu tệp không thuộc không gian làm việc.\r\n– „${documentFileName}“: Tên tệp đầy đủ của tài liệu Markdown, ví dụ: „README.md“.\r\n– „${documentBaseName}“: Tên cơ bản của tài liệu Markdown, ví dụ: „README“.\r\n– „${documentExtName}“: Phần mở rộng của tài liệu Markdown, ví dụ: „md“.\r\n– „${documentFilePath}“: Đường dẫn tuyệt đối của tài liệu Markdown, ví dụ: „/Users/me/myProject/docs/README.md“.\r\n– „${documentRelativeFilePath}“: Đường dẫn tương đối của tài liệu Markdown, ví dụ: „docs/README.md“. Giống với „${documentFilePath}“ nếu tệp không thuộc không gian làm việc.\r\n– „${documentWorkspaceFolder}“: Thư mục không gian làm việc cho tài liệu Markdown, ví dụ: „/Users/me/myProject“. Giống với „${documentDirName}“ nếu tệp không thuộc không gian làm việc.\r\n– „${fileName}“: Tên tệp của tệp đã thả, ví dụ: „image.png“.\r\n– „${fileExtName}“: Phần mở rộng của tệp đã thả, ví dụ: „png“.\r\n– „${unixTime}“: Dấu thời gian Unix hiện tại tính bằng mili giây.\r\n– „${isoTime}“ – Thời gian hiện tại theo định dạng ISO 8601, ví dụ: „2025-06-06T08:40:32.123Z“.","additionalProperties":{"type":"string"}},"markdown.copyFiles.overwriteBehavior":{"type":"string","markdownDescription":"Điều khiển việc các tệp được tạo bằng cách thả hoặc dán có nên ghi đè lên các tệp hiện có hay không.","default":"nameIncrementally","enum":["nameIncrementally","overwrite"],"markdownEnumDescriptions":["Nếu đã có tệp cùng tên, hãy thêm một số vào tên tệp, ví dụ: \"image.png\" thành \"image-1.png\".","Nếu đã có tệp cùng tên, hãy ghi đè lên nó."]},"markdown.preferredMdPathExtensionStyle":{"type":"string","default":"auto","markdownDescription":"Điều khiển việc liệu các tệp Markdown có thêm phần mở rộng tệp (ví dụ: \".md\") cho liên kết hay không. Cài đặt này được sử dụng khi đường dẫn tệp được thêm bởi các công cụ như hoàn thành đường dẫn hoặc đổi tên tệp.","enum":["auto","includeExtension","removeExtension"],"markdownEnumDescriptions":["Đối với đường dẫn hiện có, cố gắng giữ nguyên kiểu phần mở rộng tệp. Đối với đường dẫn mới, thêm phần mở rộng tệp.","Ưu tiên bao gồm phần mở rộng tệp. Ví dụ: hoàn thành đường dẫn đến tệp có tên \"file.md\" sẽ chèn một tệp có tên \"file\" mà không có \".md\" đi kèm.","Ưu tiên loại bỏ phần mở rộng tệp. Ví dụ: hoàn thành đường dẫn đến tệp có tên \"file.md\" sẽ chèn một tệp có tên \"file\" mà không có \".md\" đi kèm."]},"markdown.editor.updateLinksOnPaste.enabled":{"type":"boolean","markdownDescription":"Bật/tắt tùy chọn dán cập nhật liên kết và tham chiếu trong văn bản được sao chép và dán giữa các trình soạn thảo Markdown.\r\n\r\nĐể sử dụng tính năng này, chỉ cần nhấp vào widget \"Dán\" sau khi dán văn bản chứa liên kết có thể cập nhật và chọn \"Dán và cập nhật liên kết đã dán\".","scope":"resource","default":true}}},"configurationDefaults":{"[markdown]":{"editor.wordWrap":"on","editor.quickSuggestions":{"comments":"off","strings":"off","other":"off"}}},"jsonValidation":[{"fileMatch":"package.json","url":"./schemas/package.schema.json"}],"markdown.previewStyles":["./media/markdown.css","./media/highlight.css"],"markdown.previewScripts":["./media/index.js"],"customEditors":[{"viewType":"vscode.markdown.preview.editor","displayName":"Markdown Preview","priority":"option","selector":[{"filenamePattern":"*.md"}]}]},"repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/markdown-language-features","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.markdown-math"},"manifest":{"name":"markdown-math","displayName":"Markdown Math","description":"Thêm hỗ trợ toán học vào Markdown trong Notebooks.","version":"10.0.0","icon":"icon.png","publisher":"vscode","license":"MIT","aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","engines":{"vscode":"^1.54.0"},"categories":["Other","Programming Languages"],"capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"main":"./dist/extension","browser":"./dist/browser/extension","activationEvents":[],"contributes":{"languages":[{"id":"markdown-math","aliases":[]}],"grammars":[{"language":"markdown-math","scopeName":"text.html.markdown.math","path":"./syntaxes/md-math.tmLanguage.json"},{"scopeName":"markdown.math.block","path":"./syntaxes/md-math-block.tmLanguage.json","injectTo":["text.html.markdown"],"embeddedLanguages":{"meta.embedded.math.markdown":"latex"}},{"scopeName":"markdown.math.inline","path":"./syntaxes/md-math-inline.tmLanguage.json","injectTo":["text.html.markdown"],"embeddedLanguages":{"meta.embedded.math.markdown":"latex","punctuation.definition.math.end.markdown":"latex"}},{"scopeName":"markdown.math.codeblock","path":"./syntaxes/md-math-fence.tmLanguage.json","injectTo":["text.html.markdown"],"embeddedLanguages":{"meta.embedded.math.markdown":"latex"}}],"notebookRenderer":[{"id":"vscode.markdown-it-katex-extension","displayName":"Markdown it KaTeX renderer","entrypoint":{"extends":"vscode.markdown-it-renderer","path":"./notebook-out/katex.js"}}],"markdown.markdownItPlugins":true,"markdown.previewStyles":["./notebook-out/katex.min.css","./preview-styles/index.css"],"configuration":[{"title":"Markdown Math","properties":{"markdown.math.enabled":{"type":"boolean","default":true,"description":"Bật/Tắt tính toán kết xuất trong chế độ xem trước Markdown tích hợp."},"markdown.math.macros":{"type":"object","additionalProperties":{"type":"string"},"default":{},"description":"Danh sách các macro tùy chỉnh. Mỗi macro là một cặp khóa-giá trị, trong đó khóa là tên lệnh mới và giá trị là phần mở rộng của macro.","scope":"resource"}}}]},"repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/markdown-math","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.media-preview"},"manifest":{"name":"media-preview","displayName":"Xem trước phương tiện","description":"Cung cấp chế độ xem trước tích hợp của VS Code cho hình ảnh, âm thanh và video.","extensionKind":["ui","workspace"],"version":"10.0.0","publisher":"vscode","icon":"icon.png","license":"MIT","aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","engines":{"vscode":"^1.70.0"},"main":"./dist/extension","browser":"./dist/browser/extension.js","categories":["Other"],"activationEvents":[],"capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"contributes":{"configuration":{"type":"object","title":"Media Previewer","properties":{"mediaPreview.video.autoPlay":{"type":"boolean","default":false,"markdownDescription":"Tự động bắt đầu phát video khi tắt tiếng."},"mediaPreview.video.loop":{"type":"boolean","default":false,"markdownDescription":"Tự động phát lại video."}}},"customEditors":[{"viewType":"imagePreview.previewEditor","displayName":"Xem trước hình ảnh","priority":"builtin","selector":[{"filenamePattern":"*.{jpg,jpe,jpeg,png,bmp,gif,ico,webp,avif,svg}"}]},{"viewType":"vscode.audioPreview","displayName":"Xem trước âm thanh","priority":"builtin","selector":[{"filenamePattern":"*.{mp3,wav,ogg,oga}"}]},{"viewType":"vscode.videoPreview","displayName":"Xem trước video","priority":"builtin","selector":[{"filenamePattern":"*.{mp4,webm}"}]}],"commands":[{"command":"imagePreview.zoomIn","title":{"value":"Phóng to","original":"Zoom in"},"category":"Image Preview"},{"command":"imagePreview.zoomOut","title":{"value":"Thu nhỏ","original":"Zoom out"},"category":"Image Preview"},{"command":"imagePreview.copyImage","title":{"value":"Sao chép","original":"Copy"},"category":"Image Preview"},{"command":"imagePreview.reopenAsPreview","title":{"value":"Mở lại dưới dạng xem trước hình ảnh","original":"Reopen as image preview"},"category":"Image Preview","icon":"$(preview)"},{"command":"imagePreview.reopenAsText","title":{"value":"Mở lại dưới dạng mã nguồn","original":"Reopen as source text"},"category":"Image Preview","icon":"$(go-to-file)"}],"menus":{"commandPalette":[{"command":"imagePreview.zoomIn","when":"activeCustomEditorId == 'imagePreview.previewEditor'","group":"1_imagePreview"},{"command":"imagePreview.zoomOut","when":"activeCustomEditorId == 'imagePreview.previewEditor'","group":"1_imagePreview"},{"command":"imagePreview.copyImage","when":"false"},{"command":"imagePreview.reopenAsPreview","when":"activeEditor == workbench.editors.files.textFileEditor && resourceExtname == '.svg'","group":"navigation"},{"command":"imagePreview.reopenAsText","when":"activeCustomEditorId == 'imagePreview.previewEditor' && resourceExtname == '.svg'","group":"navigation"}],"webview/context":[{"command":"imagePreview.copyImage","when":"webviewId == 'imagePreview.previewEditor'"}],"editor/title":[{"command":"imagePreview.reopenAsPreview","when":"editorFocus && resourceExtname == '.svg'","group":"navigation"},{"command":"imagePreview.reopenAsText","when":"activeCustomEditorId == 'imagePreview.previewEditor' && resourceExtname == '.svg'","group":"navigation"}]}},"repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/media-preview","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.merge-conflict"},"manifest":{"name":"merge-conflict","publisher":"vscode","displayName":"Xung đột gộp","description":"Tô sáng và lệnh cho các xung đột hợp nhất nội tuyến.","icon":"media/icon.png","version":"10.0.0","license":"MIT","aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","engines":{"vscode":"^1.5.0"},"categories":["Other"],"capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"activationEvents":["onStartupFinished"],"main":"./dist/mergeConflictMain","browser":"./dist/browser/mergeConflictMain","contributes":{"commands":[{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Chấp nhận tất cả hiện tại","original":"Accept All Current"},"original":"Accept All Current","command":"merge-conflict.accept.all-current","enablement":"!isMergeEditor"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Chấp nhận tất cả đến","original":"Accept All Incoming"},"original":"Accept All Incoming","command":"merge-conflict.accept.all-incoming","enablement":"!isMergeEditor"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Chấp nhận tất cả cả hai","original":"Accept All Both"},"original":"Accept All Both","command":"merge-conflict.accept.all-both","enablement":"!isMergeEditor"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Chấp nhận hiện tại","original":"Accept Current"},"original":"Accept Current","command":"merge-conflict.accept.current","enablement":"!isMergeEditor"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Chấp nhận đến","original":"Accept Incoming"},"original":"Accept Incoming","command":"merge-conflict.accept.incoming","enablement":"!isMergeEditor"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Chấp nhận lựa chọn","original":"Accept Selection"},"original":"Accept Selection","command":"merge-conflict.accept.selection","enablement":"!isMergeEditor"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Chấp nhận cả hai","original":"Accept Both"},"original":"Accept Both","command":"merge-conflict.accept.both","enablement":"!isMergeEditor"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Xung đột tiếp theo","original":"Next Conflict"},"original":"Next Conflict","command":"merge-conflict.next","enablement":"!isMergeEditor","icon":"$(arrow-down)"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"Xung đột trước đó","original":"Previous Conflict"},"original":"Previous Conflict","command":"merge-conflict.previous","enablement":"!isMergeEditor","icon":"$(arrow-up)"},{"category":{"value":"Xung đột gộp","original":"Merge Conflict"},"title":{"value":"So sánh xung đột hiện tại","original":"Compare Current Conflict"},"original":"Compare Current Conflict","command":"merge-conflict.compare","enablement":"!isMergeEditor"}],"menus":{"scm/resourceState/context":[{"command":"merge-conflict.accept.all-current","when":"scmProvider == git && scmResourceGroup == merge","group":"1_modification"},{"command":"merge-conflict.accept.all-incoming","when":"scmProvider == git && scmResourceGroup == merge","group":"1_modification"}],"editor/title":[{"command":"merge-conflict.previous","group":"navigation@1","when":"!isMergeEditor && mergeConflictsCount && mergeConflictsCount != 0"},{"command":"merge-conflict.next","group":"navigation@2","when":"!isMergeEditor && mergeConflictsCount && mergeConflictsCount != 0"}]},"configuration":{"title":"Xung đột gộp","properties":{"merge-conflict.codeLens.enabled":{"type":"boolean","description":"Tạo CodeLens cho các khối xung đột gộp trong trình soạn thảo.","default":true},"merge-conflict.decorators.enabled":{"type":"boolean","description":"Tạo các phần tử trang trí cho các khối xung đột hợp nhất trong trình soạn thảo.","default":true},"merge-conflict.autoNavigateNextConflict.enabled":{"type":"boolean","description":"Chỉ định có nên tự động điều hướng đến xung đột gộp tiếp theo sau khi giải quyết xung đột gộp hay không.","default":false},"merge-conflict.diffViewPosition":{"type":"string","enum":["Current","Beside","Below"],"description":"Điều khiển nơi mở chế độ xem so sánh khi so sánh các thay đổi trong xung đột hợp nhất.","enumDescriptions":["Mở chế độ xem so sánh trong nhóm trình soạn thảo hiện tại.","Mở chế độ xem so sánh bên cạnh nhóm trình soạn thảo hiện tại.","Mở chế độ xem so sánh bên dưới nhóm trình soạn thảo hiện tại."],"default":"Current"}}}},"repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/merge-conflict","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.mermaid-chat-features"},"manifest":{"name":"mermaid-chat-features","displayName":"Mermaid Chat Features","description":"Adds Mermaid diagram support to built-in chats.","version":"10.0.0","publisher":"vscode","license":"MIT","repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"},"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","engines":{"vscode":"^1.104.0"},"enabledApiProposals":["chatOutputRenderer"],"capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"main":"./dist/extension","browser":"./dist/browser/extension","activationEvents":["onWebviewPanel:vscode.chat-mermaid-features.preview"],"contributes":{"commands":[{"command":"_mermaid-chat.resetPanZoom","title":"Reset Pan and Zoom"},{"command":"_mermaid-chat.openInEditor","title":"Open Diagram in Editor"},{"command":"_mermaid-chat.copySource","title":"Copy Diagram Source"}],"menus":{"commandPalette":[{"command":"_mermaid-chat.resetPanZoom","when":"false"},{"command":"_mermaid-chat.openInEditor","when":"false"},{"command":"_mermaid-chat.copySource","when":"false"}],"webview/context":[{"command":"_mermaid-chat.resetPanZoom","when":"webviewId == 'vscode.chat-mermaid-features.chatOutputItem'"},{"command":"_mermaid-chat.copySource","when":"webviewId == 'vscode.chat-mermaid-features.chatOutputItem' || webviewId == 'vscode.chat-mermaid-features.preview'"}]},"configuration":{"title":"Mermaid Chat Features","properties":{"mermaid-chat.enabled":{"type":"boolean","default":true,"description":"Enable a tool for Mermaid diagram rendering in chat responses.","scope":"application"}}},"chatOutputRenderers":[{"viewType":"vscode.chat-mermaid-features.chatOutputItem","mimeTypes":["text/vnd.mermaid"]}],"languageModelTools":[{"name":"renderMermaidDiagram","displayName":"Mermaid Renderer","toolReferenceName":"renderMermaidDiagram","canBeReferencedInPrompt":true,"modelDescription":"Renders a Mermaid diagram from Mermaid.js markup.","userDescription":"Render a Mermaid.js diagrams from markup.","when":"config.mermaid-chat.enabled","inputSchema":{"type":"object","properties":{"markup":{"type":"string","description":"The mermaid diagram markup to render as a Mermaid diagram. This should only be the markup of the diagram. Do not include a wrapping code block."},"title":{"type":"string","description":"A short title that describes the diagram."}}}}]}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/mermaid-chat-features","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.microsoft-authentication"},"manifest":{"name":"microsoft-authentication","publisher":"vscode","license":"MIT","displayName":"Tài khoản Microsoft","description":"Nhà cung cấp xác thực Microsoft","version":"0.0.1","engines":{"vscode":"^1.42.0"},"icon":"media/icon.png","categories":["Other"],"activationEvents":[],"enabledApiProposals":["nativeWindowHandle","authIssuers","authenticationChallenges"],"capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"extensionKind":["ui","workspace"],"contributes":{"authentication":[{"label":"Microsoft","id":"microsoft","authorizationServerGlobs":["https://login.microsoftonline.com/*","https://login.microsoftonline.com/*/v2.0"]},{"label":"Microsoft Sovereign Cloud","id":"microsoft-sovereign-cloud"}],"configuration":[{"title":"Microsoft Sovereign Cloud","properties":{"microsoft-sovereign-cloud.environment":{"type":"string","markdownDescription":"Đám mây Chủ quyền được sử dụng để xác thực. Nếu chọn \"Tùy chỉnh\", bạn cũng cần cấu hình cài đặt `#microsoft-sovereign-cloud.customEnvironment#`.","enum":["ChinaCloud","USGovernment","custom"],"enumDescriptions":["Azure Trung Quốc","Azure Chính phủ Hoa Kỳ","Một Đám mây Chủ quyền Microsoft tùy chỉnh"]},"microsoft-sovereign-cloud.customEnvironment":{"type":"object","additionalProperties":true,"markdownDescription":"Cấu hình tùy chỉnh cho Sovereign Cloud sẽ được sử dụng với nhà cung cấp xác thực Microsoft Sovereign Cloud. Điều này được yêu cầu cùng với cài đặt `#microsoft-sovereign-cloud.environment#` thành \"tùy chỉnh\" để sử dụng tính năng này.","properties":{"name":{"type":"string","description":"Tên của Sovereign Cloud tùy chỉnh."},"portalUrl":{"type":"string","description":"URL cổng thông tin cho Đám mây Chủ quyền tùy chỉnh."},"managementEndpointUrl":{"type":"string","description":"Điểm cuối quản lý cho Sovereign Cloud tùy chỉnh."},"resourceManagerEndpointUrl":{"type":"string","description":"Điểm cuối Trình quản lý Tài nguyên cho Đám mây Chủ quyền tùy chỉnh."},"activeDirectoryEndpointUrl":{"type":"string","description":"Điểm cuối Active Directory cho Sovereign Cloud tùy chỉnh."},"activeDirectoryResourceId":{"type":"string","description":"ID tài nguyên Active Directory cho Sovereign Cloud tùy chỉnh."}},"required":["name","portalUrl","managementEndpointUrl","resourceManagerEndpointUrl","activeDirectoryEndpointUrl","activeDirectoryResourceId"]}}},{"title":"Microsoft","properties":{"microsoft-authentication.implementation":{"type":"string","default":"msal","enum":["msal","msal-no-broker"],"enumDescriptions":["Sử dụng Thư viện Xác thực Microsoft (MSAL) để đăng nhập bằng tài khoản Microsoft.","Sử dụng Thư viện Xác thực Microsoft (MSAL) để đăng nhập bằng tài khoản Microsoft thông qua trình duyệt. Điều này hữu ích nếu bạn gặp sự cố với trình môi giới gốc."],"markdownDescription":"Triển khai xác thực sẽ được sử dụng để đăng nhập bằng tài khoản Microsoft.\r\n\r\n*LƯU Ý: Triển khai `classic` đã lỗi thời và sẽ bị loại bỏ trong phiên bản tương lai. Nếu triển khai `msal` không hoạt động với bạn, vui lòng [mở một vấn đề](command:workbench.action.openIssueReporter) và giải thích địa chỉ bạn đang cố gắng đăng nhập.*","tags":["onExP"]}}}]},"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","main":"./dist/extension.js","repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/microsoft-authentication","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"ms-vscode.js-debug"},"manifest":{"name":"js-debug","displayName":"JavaScript Debugger","version":"1.110.0","publisher":"ms-vscode","author":{"name":"Microsoft Corporation"},"keywords":["pwa","javascript","node","chrome","debugger"],"description":"An extension for debugging Node.js programs and Chrome.","license":"MIT","engines":{"vscode":"^1.80.0","node":">=10"},"icon":"resources/logo.png","categories":["Debuggers"],"private":true,"repository":{"type":"git","url":"https://github.com/Microsoft/vscode-pwa.git"},"bugs":{"url":"https://github.com/Microsoft/vscode-pwa/issues"},"main":"./src/extension.js","enabledApiProposals":["portsAttributes","workspaceTrust","tunnels"],"extensionKind":["workspace"],"capabilities":{"virtualWorkspaces":false,"untrustedWorkspaces":{"supported":"limited","description":"Cần thiết lập sự tin cậy để gỡ lỗi mã trong không gian làm việc này."}},"activationEvents":["onDebugDynamicConfigurations","onDebugInitialConfigurations","onFileSystem:jsDebugNetworkFs","onDebugResolve:pwa-node","onDebugResolve:node-terminal","onDebugResolve:pwa-extensionHost","onDebugResolve:pwa-chrome","onDebugResolve:pwa-msedge","onDebugResolve:node","onDeb