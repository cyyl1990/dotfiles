c đường dẫn tệp tuyệt đối đến một lược đồ. Có thể là đường dẫn tương đối (bắt đầu bằng \"./\") trong cài đặt không gian làm việc và thư mục không gian làm việc."},"fileMatch":{"type":"array","items":{"type":"string","default":"MyFile.json","description":"Một mẫu tệp có thể chứa \"*\" và \"**\", được dùng để khớp khi phân giải các tệp JSON thành lược đồ. Nếu bắt đầu bằng \"!\", nó định nghĩa một mẫu loại trừ."},"minItems":1,"description":"Một mảng các mẫu tệp để khớp khi phân giải các tệp JSON thành lược đồ. Các ký tự \"*\" và \"**\" có thể được dùng làm ký tự đại diện. Các mẫu loại trừ cũng có thể được định nghĩa và bắt đầu bằng \"!\". Một tệp được coi là khớp nếu có ít nhất một mẫu khớp và mẫu khớp cuối cùng không phải là mẫu loại trừ."},"schema":{"$ref":"http://json-schema.org/draft-07/schema#","description":"Định nghĩa lược đồ cho URL đã chỉ định. Lược đồ chỉ cần được chỉ định để tránh các yêu cầu truy cập vào URL lược đồ."}}}},"json.validate.enable":{"type":"boolean","scope":"window","default":true,"description":"Bật/tắt xác thực JSON."},"json.format.enable":{"type":"boolean","scope":"window","default":true,"description":"Bật/tắt trình định dạng JSON mặc định"},"json.format.keepLines":{"type":"boolean","scope":"window","default":false,"description":"Giữ lại tất cả các dòng mới hiện có khi định dạng."},"json.trace.server":{"type":"string","scope":"window","enum":["off","messages","verbose"],"default":"off","description":"Theo dõi giao tiếp giữa VS Code và máy chủ ngôn ngữ JSON."},"json.colorDecorators.enable":{"type":"boolean","scope":"window","default":true,"description":"Bật hoặc tắt các bộ trang trí màu","deprecationMessage":"Cài đặt \"json.colorDecorators.enable\" đã lỗi thời và được thay thế bằng \"editor.colorDecorators\"."},"json.maxItemsComputed":{"type":"number","default":5000,"description":"Số lượng tối đa các biểu tượng dàn bài và vùng thu gọn được tính toán (bị giới hạn vì lý do hiệu suất)."},"json.schemaDownload.enable":{"type":"boolean","default":tr