đến VS Code.","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"testConfiguration":{"default":"${workspaceFolder}/.vscode-test.js","markdownDescription":"Đường dẫn đến tệp cấu hình kiểm tra cho [CLI kiểm tra](https://code.visualstudio.com/api/working-with-extensions/testing-extension#quick-setup-the-test-cli).","type":"string"},"testConfigurationLabel":{"default":"","markdownDescription":"Một cấu hình duy nhất để chạy từ tệp. Nếu không được chỉ định, bạn có thể được nhắc chọn.","type":"string"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"required":[]}},"configurationSnippets":[],"deprecated":"Please use type extensionHost instead","label":"Phát triển tiện ích mở rộng VS Code","languages":["javascript","typescript","javascriptreact","typescriptreact"],"strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"pwa-extensionHost"},{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"launch":{"properties":{"args":{"default":["--extensionDevelopmentPath=${workspaceFolder}"],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":"array"},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"debugWebWorkerHost":{"default":true,"markdownDescription":"Cấu hình xem có nên thử đính kèm vào host tiện ích mở rộng webworker hay không.","type":["boolean"]},"debugWebviews":{"default":true,"markdownDescription":"Cấu hình xem có nên thử đính kèm vào webview trong phiên bản VS Code đã khởi động hay không. Điều này chỉ hoạt động trong VS Code trên máy tính để bàn.","type":["boolean"]},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"rendererDebugOptions":{"default":{"webRoot":"${workspaceFolder}"},"markdownDescription":"Tùy chọn khởi động Chrome được sử dụng khi đính kèm vào tiến trình renderer với \"debugWebviews\" hoặc \"debugWebWorkerHost\".","properties":{"address":{"default":"localhost","description":"Địa chỉ IP hoặc tên máy chủ mà trình duyệt đang lắng nghe để gỡ lỗi.","type":"string"},"browserAttachLocation":{"default":null,"description":"Buộc trình duyệt đính kèm tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để đính kèm trình duyệt trên máy từ xa thay vì trình duyệt trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Cổng được sử dụng khi gỡ lỗi trình duyệt từ xa, được chỉ định là \"--remote-debugging-port\" khi khởi động trình duyệt.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}],"tags":["setup"]},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":false,"markdownDescription":"Chỉ định xem kết nối có được thiết lập lại không khi kết nối trình duyệt bị đóng.","type":"boolean"},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"targetSelection":{"default":"automatic","enum":["pick","automatic"],"markdownDescription":"Chỉ định xem có đính kèm vào tất cả các mục tiêu khớp với bộ lọc URL (\"automatic\") hay chọn một mục tiêu (\"pick\").","type":"string"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}},"type":"object"},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeExecutable":{"default":"node","markdownDescription":"Đường dẫn tuyệt đối đến VS Code.","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"testConfiguration":{"default":"${workspaceFolder}/.vscode-test.js","markdownDescription":"Đường dẫn đến tệp cấu hình kiểm tra cho [CLI kiểm tra](https://code.visualstudio.com/api/working-with-extensions/testing-extension#quick-setup-the-test-cli).","type":"string"},"testConfigurationLabel":{"default":"","markdownDescription":"Một cấu hình duy nhất để chạy từ tệp. Nếu không được chỉ định, bạn có thể được nhắc chọn.","type":"string"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"required":[]}},"configurationSnippets":[{"body":{"args":["^\"--extensionDevelopmentPath=\\${workspaceFolder}\""],"name":"Khởi động tiện ích mở rộng","outFiles":["^\"\\${workspaceFolder}/out/**/*.js\""],"preLaunchTask":"npm","request":"launch","type":"extensionHost"},"description":"Khởi động tiện ích mở rộng VS Code ở chế độ gỡ lỗi","label":"Phát triển tiện ích mở rộng VS Code"}],"label":"Phát triển tiện ích mở rộng VS Code","strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"extensionHost"},{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"attach":{"properties":{"address":{"default":"localhost","description":"Địa chỉ IP hoặc tên máy chủ mà trình duyệt đang lắng nghe để gỡ lỗi.","type":"string"},"browserAttachLocation":{"default":null,"description":"Buộc trình duyệt đính kèm tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để đính kèm trình duyệt trên máy từ xa thay vì trình duyệt trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Cổng được sử dụng khi gỡ lỗi trình duyệt từ xa, được chỉ định là \"--remote-debugging-port\" khi khởi động trình duyệt.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}],"tags":["setup"]},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":false,"markdownDescription":"Chỉ định xem kết nối có được thiết lập lại không khi kết nối trình duyệt bị đóng.","type":"boolean"},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"targetSelection":{"default":"automatic","enum":["pick","automatic"],"markdownDescription":"Chỉ định xem có đính kèm vào tất cả các mục tiêu khớp với bộ lọc URL (\"automatic\") hay chọn một mục tiêu (\"pick\").","type":"string"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}}},"launch":{"properties":{"browserLaunchLocation":{"default":null,"description":"Buộc trình duyệt khởi động tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để mở trình duyệt trên máy từ xa thay vì trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"cleanUp":{"default":"wholeBrowser","description":"Hoạt động dọn dẹp sau khi phiên gỡ lỗi kết thúc. Chỉ đóng tab đang được gỡ lỗi, không đóng toàn bộ trình duyệt.","enum":["wholeBrowser","onlyTab"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":null,"description":"Thư mục làm việc tùy chọn cho tệp thực thi runtime.","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"default":{},"description":"Từ điển tùy chọn các cặp khóa/giá trị môi trường cho trình duyệt.","type":"object"},"file":{"default":"${workspaceFolder}/index.html","description":"Một tệp HTML cục bộ để mở trong trình duyệt","tags":["setup"],"type":"string"},"includeDefaultArgs":{"default":true,"description":"Chỉ định xem có bao gồm các đối số mặc định khi khởi động trình duyệt (để tắt các tính năng có thể gây khó khăn cho việc gỡ lỗi) khi bắt đầu hay không.","type":"boolean"},"includeLaunchArgs":{"default":true,"description":"Nâng cao: Chỉ định xem các đối số khởi động/gỡ lỗi mặc định có được đặt trong trình duyệt hay không. Trình gỡ lỗi giả định rằng trình duyệt sử dụng gỡ lỗi qua đường ống, chẳng hạn như được cung cấp với \"--remote-debugging-pipe\".","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Định cấu hình cách các tiến trình trình duyệt bị kết thúc khi phiên kết thúc với \"cleanUp: wholeBrowser\". Các tùy chọn có thể:\r\n\r\n- forceful (mặc định): Buộc kết thúc cây tiến trình. Trên POSIX, gửi SIGKILL, trên Windows sử dụng \"taskkill.exe /F\".\r\n- polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM, trên Windows sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n- none: Không kết thúc.","type":"string"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":0,"description":"Cổng mà trình duyệt đang lắng nghe. Giá trị mặc định là \"0\", khiến việc gỡ lỗi trình duyệt được thực hiện qua đường ống. Tùy chọn này thường an toàn hơn và nên được sử dụng - trừ khi bạn cần đính kèm trình duyệt bằng một công cụ khác.","type":"number"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi tiến trình khởi động.","type":"boolean"},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"type":"array"},"runtimeExecutable":{"default":"stable","description":"Có thể là \"canary\", \"stable\", \"custom\" hoặc đường dẫn đến tệp thực thi trình duyệt. \"custom\" đại diện cho một wrapper tùy chỉnh, bản dựng tùy chỉnh hoặc biến môi trường CHROME_PATH.","type":["string","null"]},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"userDataDir":{"default":true,"description":"Theo mặc định, trình duyệt được khởi chạy với hồ sơ người dùng riêng biệt trong thư mục tạm thời. Sử dụng tùy chọn này để ghi đè. Đặt giá trị này thành \"false\" để khởi chạy với hồ sơ người dùng mặc định của bạn. Không thể khởi chạy trình duyệt mới nếu một phiên bản đang chạy từ userDataDir.","type":["string","boolean"]},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}}}},"configurationSnippets":[],"deprecated":"Please use type chrome instead","label":"Ứng dụng web (Chrome)","languages":["javascript","typescript","javascriptreact","typescriptreact","html","css","coffeescript","handlebars","vue"],"strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"pwa-chrome"},{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"attach":{"properties":{"address":{"default":"localhost","description":"Địa chỉ IP hoặc tên máy chủ mà trình duyệt đang lắng nghe để gỡ lỗi.","type":"string"},"browserAttachLocation":{"default":null,"description":"Buộc trình duyệt đính kèm tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để đính kèm trình duyệt trên máy từ xa thay vì trình duyệt trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Cổng được sử dụng khi gỡ lỗi trình duyệt từ xa, được chỉ định là \"--remote-debugging-port\" khi khởi động trình duyệt.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}],"tags":["setup"]},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":false,"markdownDescription":"Chỉ định xem kết nối có được thiết lập lại không khi kết nối trình duyệt bị đóng.","type":"boolean"},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"targetSelection":{"default":"automatic","enum":["pick","automatic"],"markdownDescription":"Chỉ định xem có đính kèm vào tất cả các mục tiêu khớp với bộ lọc URL (\"automatic\") hay chọn một mục tiêu (\"pick\").","type":"string"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}}},"launch":{"properties":{"browserLaunchLocation":{"default":null,"description":"Buộc trình duyệt khởi động tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để mở trình duyệt trên máy từ xa thay vì trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"cleanUp":{"default":"wholeBrowser","description":"Hoạt động dọn dẹp sau khi phiên gỡ lỗi kết thúc. Chỉ đóng tab đang được gỡ lỗi, không đóng toàn bộ trình duyệt.","enum":["wholeBrowser","onlyTab"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":null,"description":"Thư mục làm việc tùy chọn cho tệp thực thi runtime.","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"default":{},"description":"Từ điển tùy chọn các cặp khóa/giá trị môi trường cho trình duyệt.","type":"object"},"file":{"default":"${workspaceFolder}/index.html","description":"Một tệp HTML cục bộ để mở trong trình duyệt","tags":["setup"],"type":"string"},"includeDefaultArgs":{"default":true,"description":"Chỉ định xem có bao gồm các đối số mặc định khi khởi động trình duyệt (để tắt các tính năng có thể gây khó khăn cho việc gỡ lỗi) khi bắt đầu hay không.","type":"boolean"},"includeLaunchArgs":{"default":true,"description":"Nâng cao: Chỉ định xem các đối số khởi động/gỡ lỗi mặc định có được đặt trong trình duyệt hay không. Trình gỡ lỗi giả định rằng trình duyệt sử dụng gỡ lỗi qua đường ống, chẳng hạn như được cung cấp với \"--remote-debugging-pipe\".","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Định cấu hình cách các tiến trình trình duyệt bị kết thúc khi phiên kết thúc với \"cleanUp: wholeBrowser\". Các tùy chọn có thể:\r\n\r\n- forceful (mặc định): Buộc kết thúc cây tiến trình. Trên POSIX, gửi SIGKILL, trên Windows sử dụng \"taskkill.exe /F\".\r\n- polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM, trên Windows sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n- none: Không kết thúc.","type":"string"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":0,"description":"Cổng mà trình duyệt đang lắng nghe. Giá trị mặc định là \"0\", khiến việc gỡ lỗi trình duyệt được thực hiện qua đường ống. Tùy chọn này thường an toàn hơn và nên được sử dụng - trừ khi bạn cần đính kèm trình duyệt bằng một công cụ khác.","type":"number"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi tiến trình khởi động.","type":"boolean"},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"type":"array"},"runtimeExecutable":{"default":"stable","description":"Có thể là \"canary\", \"stable\", \"custom\" hoặc đường dẫn đến tệp thực thi trình duyệt. \"custom\" đại diện cho một wrapper tùy chỉnh, bản dựng tùy chỉnh hoặc biến môi trường CHROME_PATH.","type":["string","null"]},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"userDataDir":{"default":true,"description":"Theo mặc định, trình duyệt được khởi chạy với hồ sơ người dùng riêng biệt trong thư mục tạm thời. Sử dụng tùy chọn này để ghi đè. Đặt giá trị này thành \"false\" để khởi chạy với hồ sơ người dùng mặc định của bạn. Không thể khởi chạy trình duyệt mới nếu một phiên bản đang chạy từ userDataDir.","type":["string","boolean"]},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}}}},"configurationSnippets":[{"body":{"name":"Launch Chrome","request":"launch","type":"chrome","url":"http://localhost:8080","webRoot":"^\"${2:\\${workspaceFolder\\}}\""},"description":"Khởi chạy Chrome để gỡ lỗi một URL","label":"Chrome: Khởi chạy"},{"body":{"name":"Attach to Chrome","port":9222,"request":"attach","type":"chrome","webRoot":"^\"${2:\\${workspaceFolder\\}}\""},"description":"Đính kèm vào một phiên bản Chrome đang ở chế độ gỡ lỗi.","label":"Chrome: Đính kèm"}],"label":"Ứng dụng web (Chrome)","strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"chrome"},{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"attach":{"properties":{"address":{"default":"localhost","description":"Địa chỉ IP hoặc tên máy chủ mà trình duyệt đang lắng nghe để gỡ lỗi.","type":"string"},"browserAttachLocation":{"default":null,"description":"Buộc trình duyệt đính kèm tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để đính kèm trình duyệt trên máy từ xa thay vì trình duyệt trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Cổng được sử dụng khi gỡ lỗi trình duyệt từ xa, được chỉ định là \"--remote-debugging-port\" khi khởi động trình duyệt.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}],"tags":["setup"]},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":false,"markdownDescription":"Chỉ định xem kết nối có được thiết lập lại không khi kết nối trình duyệt bị đóng.","type":"boolean"},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"targetSelection":{"default":"automatic","enum":["pick","automatic"],"markdownDescription":"Chỉ định xem có đính kèm vào tất cả các mục tiêu khớp với bộ lọc URL (\"automatic\") hay chọn một mục tiêu (\"pick\").","type":"string"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"useWebView":{"default":{"pipeName":"MyPipeName"},"description":"Một đối tượng chứa \"pipeName\" của một ống gỡ lỗi cho webview2 được UWP lưu trữ. Đây là \"MyTestSharedMemory\" khi tạo ống \"\\\\.\\pipe\\LOCAL\\MyTestSharedMemory\"","properties":{"pipeName":{"type":"string"}},"type":"object"},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}}},"launch":{"properties":{"address":{"default":"localhost","description":"Khi gỡ lỗi chế độ xem web, địa chỉ IP hoặc tên máy chủ mà chế độ xem web đang lắng nghe. Nếu không được đặt, sẽ thực hiện phát hiện tự động.","type":"string"},"browserLaunchLocation":{"default":null,"description":"Buộc trình duyệt khởi động tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để mở trình duyệt trên máy từ xa thay vì trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"cleanUp":{"default":"wholeBrowser","description":"Hoạt động dọn dẹp sau khi phiên gỡ lỗi kết thúc. Chỉ đóng tab đang được gỡ lỗi, không đóng toàn bộ trình duyệt.","enum":["wholeBrowser","onlyTab"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":null,"description":"Thư mục làm việc tùy chọn cho tệp thực thi runtime.","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"default":{},"description":"Từ điển tùy chọn các cặp khóa/giá trị môi trường cho trình duyệt.","type":"object"},"file":{"default":"${workspaceFolder}/index.html","description":"Một tệp HTML cục bộ để mở trong trình duyệt","tags":["setup"],"type":"string"},"includeDefaultArgs":{"default":true,"description":"Chỉ định xem có bao gồm các đối số mặc định khi khởi động trình duyệt (để tắt các tính năng có thể gây khó khăn cho việc gỡ lỗi) khi bắt đầu hay không.","type":"boolean"},"includeLaunchArgs":{"default":true,"description":"Nâng cao: Chỉ định xem các đối số khởi động/gỡ lỗi mặc định có được đặt trong trình duyệt hay không. Trình gỡ lỗi giả định rằng trình duyệt sử dụng gỡ lỗi qua đường ống, chẳng hạn như được cung cấp với \"--remote-debugging-pipe\".","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Định cấu hình cách các tiến trình trình duyệt bị kết thúc khi phiên kết thúc với \"cleanUp: wholeBrowser\". Các tùy chọn có thể:\r\n\r\n- forceful (mặc định): Buộc kết thúc cây tiến trình. Trên POSIX, gửi SIGKILL, trên Windows sử dụng \"taskkill.exe /F\".\r\n- polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM, trên Windows sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n- none: Không kết thúc.","type":"string"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Khi gỡ lỗi webview, cổng mà webview lắng nghe. Nếu không được đặt, sẽ thực hiện tự động phát hiện.","type":"number"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi tiến trình khởi động.","type":"boolean"},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"type":"array"},"runtimeExecutable":{"default":"stable","description":"Có thể là \"canary\", \"stable\", \"dev\", \"custom\" hoặc đường dẫn đến tệp thực thi trình duyệt. \"custom\" chỉ định một wrapper tùy chỉnh, bản dựng tùy chỉnh hoặc biến môi trường EDGE_PATH.","type":["string","null"]},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"useWebView":{"default":false,"description":"Khi là \"true\", trình gỡ lỗi sẽ xử lý tệp thực thi runtime như một ứng dụng chủ chứa WebView, cho phép bạn gỡ lỗi nội dung script của WebView.","type":"boolean"},"userDataDir":{"default":true,"description":"Theo mặc định, trình duyệt được khởi chạy với hồ sơ người dùng riêng biệt trong thư mục tạm thời. Sử dụng tùy chọn này để ghi đè. Đặt giá trị này thành \"false\" để khởi chạy với hồ sơ người dùng mặc định của bạn. Không thể khởi chạy trình duyệt mới nếu một phiên bản đang chạy từ userDataDir.","type":["string","boolean"]},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}}}},"configurationSnippets":[],"deprecated":"Please use type msedge instead","label":"Ứng dụng web (Edge)","languages":["javascript","typescript","javascriptreact","typescriptreact","html","css","coffeescript","handlebars","vue"],"strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"pwa-msedge"},{"aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","configurationAttributes":{"attach":{"properties":{"address":{"default":"localhost","description":"Địa chỉ IP hoặc tên máy chủ mà trình duyệt đang lắng nghe để gỡ lỗi.","type":"string"},"browserAttachLocation":{"default":null,"description":"Buộc trình duyệt đính kèm tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để đính kèm trình duyệt trên máy từ xa thay vì trình duyệt trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Cổng được sử dụng khi gỡ lỗi trình duyệt từ xa, được chỉ định là \"--remote-debugging-port\" khi khởi động trình duyệt.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}],"tags":["setup"]},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":false,"markdownDescription":"Chỉ định xem kết nối có được thiết lập lại không khi kết nối trình duyệt bị đóng.","type":"boolean"},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"targetSelection":{"default":"automatic","enum":["pick","automatic"],"markdownDescription":"Chỉ định xem có đính kèm vào tất cả các mục tiêu khớp với bộ lọc URL (\"automatic\") hay chọn một mục tiêu (\"pick\").","type":"string"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"useWebView":{"default":{"pipeName":"MyPipeName"},"description":"Một đối tượng chứa \"pipeName\" của một ống gỡ lỗi cho webview2 được UWP lưu trữ. Đây là \"MyTestSharedMemory\" khi tạo ống \"\\\\.\\pipe\\LOCAL\\MyTestSharedMemory\"","properties":{"pipeName":{"type":"string"}},"type":"object"},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}}},"launch":{"properties":{"address":{"default":"localhost","description":"Khi gỡ lỗi chế độ xem web, địa chỉ IP hoặc tên máy chủ mà chế độ xem web đang lắng nghe. Nếu không được đặt, sẽ thực hiện phát hiện tự động.","type":"string"},"browserLaunchLocation":{"default":null,"description":"Buộc trình duyệt khởi động tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để mở trình duyệt trên máy từ xa thay vì trên máy cục bộ.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"cleanUp":{"default":"wholeBrowser","description":"Hoạt động dọn dẹp sau khi phiên gỡ lỗi kết thúc. Chỉ đóng tab đang được gỡ lỗi, không đóng toàn bộ trình duyệt.","enum":["wholeBrowser","onlyTab"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":null,"description":"Thư mục làm việc tùy chọn cho tệp thực thi runtime.","type":"string"},"disableNetworkCache":{"default":true,"description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","type":"boolean"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"default":{},"description":"Từ điển tùy chọn các cặp khóa/giá trị môi trường cho trình duyệt.","type":"object"},"file":{"default":"${workspaceFolder}/index.html","description":"Một tệp HTML cục bộ để mở trong trình duyệt","tags":["setup"],"type":"string"},"includeDefaultArgs":{"default":true,"description":"Chỉ định xem có bao gồm các đối số mặc định khi khởi động trình duyệt (để tắt các tính năng có thể gây khó khăn cho việc gỡ lỗi) khi bắt đầu hay không.","type":"boolean"},"includeLaunchArgs":{"default":true,"description":"Nâng cao: Chỉ định xem các đối số khởi động/gỡ lỗi mặc định có được đặt trong trình duyệt hay không. Trình gỡ lỗi giả định rằng trình duyệt sử dụng gỡ lỗi qua đường ống, chẳng hạn như được cung cấp với \"--remote-debugging-pipe\".","type":"boolean"},"inspectUri":{"default":null,"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","type":["string","null"]},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Định cấu hình cách các tiến trình trình duyệt bị kết thúc khi phiên kết thúc với \"cleanUp: wholeBrowser\". Các tùy chọn có thể:\r\n\r\n- forceful (mặc định): Buộc kết thúc cây tiến trình. Trên POSIX, gửi SIGKILL, trên Windows sử dụng \"taskkill.exe /F\".\r\n- polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM, trên Windows sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n- none: Không kết thúc.","type":"string"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pathMapping":{"default":{},"description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Khi gỡ lỗi webview, cổng mà webview lắng nghe. Nếu không được đặt, sẽ thực hiện tự động phát hiện.","type":"number"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi tiến trình khởi động.","type":"boolean"},"resolveSourceMapLocations":{"default":null,"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"type":"array"},"runtimeExecutable":{"default":"stable","description":"Có thể là \"canary\", \"stable\", \"dev\", \"custom\" hoặc đường dẫn đến tệp thực thi trình duyệt. \"custom\" chỉ định một wrapper tùy chỉnh, bản dựng tùy chỉnh hoặc biến môi trường EDGE_PATH.","type":["string","null"]},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","properties":{"args":{"default":[],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"type":"string"},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"profileStartup":{"default":true,"description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","type":"boolean"},"program":{"default":"","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","type":"string"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"stopOnEntry":{"default":true,"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"Terminal gỡ lỗi JavaScript","properties":{"autoAttachChildProcesses":{"default":true,"description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","type":"string"},"localRoot":{"default":null,"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr."},"pauseForSourceMap":{"default":false,"markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","type":"boolean"},"remoteRoot":{"default":null,"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","type":"array"},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","type":"array"},"smartStep":{"default":true,"description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","type":"object"},"sourceMapRenames":{"default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi.","type":"boolean"},"sourceMaps":{"default":true,"description":"Sử dụng tệp sourcemap JavaScript (nếu có).","type":"boolean"},"timeout":{"default":10000,"description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","properties":{"hoverEvaluation":{"default":500,"description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","oneOf":[{"description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Cấu hình nơi ghi nhật ký trên đĩa.","type":["string","null"]},"stdio":{"description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","type":"string"},"useWebView":{"default":false,"description":"Khi là \"true\", trình gỡ lỗi sẽ xử lý tệp thực thi runtime như một ứng dụng chủ chứa WebView, cho phép bạn gỡ lỗi nội dung script của WebView.","type":"boolean"},"userDataDir":{"default":true,"description":"Theo mặc định, trình duyệt được khởi chạy với hồ sơ người dùng riêng biệt trong thư mục tạm thời. Sử dụng tùy chọn này để ghi đè. Đặt giá trị này thành \"false\" để khởi chạy với hồ sơ người dùng mặc định của bạn. Không thể khởi chạy trình duyệt mới nếu một phiên bản đang chạy từ userDataDir.","type":["string","boolean"]},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","tags":["setup"],"type":"string"}}}},"configurationSnippets":[{"body":{"name":"Launch Edge","request":"launch","type":"msedge","url":"http://localhost:8080","webRoot":"^\"${2:\\${workspaceFolder\\}}\""},"description":"Khởi chạy Microsoft Edge để gỡ lỗi một URL","label":"Edge: Khởi động"},{"body":{"name":"Attach to Edge","port":9222,"request":"attach","type":"msedge","webRoot":"^\"${2:\\${workspaceFolder\\}}\""},"description":"Đính kèm vào một phiên bản Microsoft Edge đã ở chế độ gỡ lỗi","label":"Edge: Đính kèm"}],"label":"Ứng dụng web (Edge)","strings":{"unverifiedBreakpoints":"Một số điểm dừng của bạn không thể được đặt. Nếu bạn gặp sự cố, bạn có thể [Chẩn đoán cấu hình khởi động của mình](command:extension.js-debug.createDiagnostics)."},"type":"msedge"}],"commands":[{"command":"extension.js-debug.prettyPrint","title":{"value":"In đẹp để gỡ lỗi","original":"Pretty print for debugging"},"category":"Debug","icon":"$(json)"},{"command":"extension.js-debug.toggleSkippingFile","title":{"value":"Bật/tắt bỏ qua tệp này","original":"Toggle Skipping this File"},"category":"Debug"},{"command":"extension.js-debug.addCustomBreakpoints","title":{"value":"Chuyển đổi điểm dừng trình nghe sự kiện","original":"Toggle Event Listener Breakpoints"},"icon":"$(add)"},{"command":"extension.js-debug.removeAllCustomBreakpoints","title":{"value":"Xóa tất cả các điểm dừng trình nghe sự kiện","original":"Remove All Event Listener Breakpoints"},"icon":"$(close-all)"},{"command":"extension.js-debug.addXHRBreakpoints","title":{"value":"Thêm điểm dừng XHR/Fetch","original":"Add XHR/fetch Breakpoint"},"icon":"$(add)"},{"command":"extension.js-debug.removeXHRBreakpoint","title":{"value":"Xóa điểm dừng XHR/Fetch","original":"Remove XHR/fetch Breakpoint"},"icon":"$(remove)"},{"command":"extension.js-debug.editXHRBreakpoints","title":{"value":"Chỉnh sửa điểm dừng XHR/Fetch","original":"Edit XHR/fetch Breakpoint"},"icon":"$(edit)"},{"command":"extension.pwa-node-debug.attachNodeProcess","title":{"value":"Đính kèm vào tiến trình Node","original":"Attach to Node Process"},"category":"Debug"},{"command":"extension.js-debug.npmScript","title":{"value":"Gỡ lỗi tập lệnh npm","original":"Debug npm Script"},"category":"Debug"},{"command":"extension.js-debug.createDebuggerTerminal","title":{"value":"Terminal gỡ lỗi JavaScript","original":"JavaScript Debug Terminal"},"category":"Debug"},{"command":"extension.js-debug.startProfile","title":{"value":"Bắt đầu hồ sơ hiệu suất","original":"Take Performance Profile"},"category":"Debug","icon":"$(record)"},{"command":"extension.js-debug.stopProfile","title":{"value":"Dừng hồ sơ hiệu suất","original":"Stop Performance Profile"},"category":"Debug","icon":"resources/dark/stop-profiling.svg"},{"command":"extension.js-debug.revealPage","title":{"value":"Tab đang được tập trung","original":"Focus Tab"},"category":"Debug"},{"command":"extension.js-debug.debugLink","title":{"value":"Mở liên kết","original":"Open Link"},"category":"Debug"},{"command":"extension.js-debug.createDiagnostics","title":{"value":"Chẩn đoán sự cố điểm dừng","original":"Diagnose Breakpoint Problems"},"category":"Debug"},{"command":"extension.js-debug.getDiagnosticLogs","title":{"value":"Lưu nhật ký gỡ lỗi JS chẩn đoán","original":"Save Diagnostic JS Debug Logs"},"category":"Debug"},{"command":"extension.node-debug.startWithStopOnEntry","title":{"value":"Bắt đầu gỡ lỗi và dừng ở điểm vào","original":"Start Debugging and Stop on Entry"},"category":"Debug"},{"command":"extension.js-debug.openEdgeDevTools","title":{"value":"Mở DevTools của trình duyệt","original":"Open Browser Devtools"},"icon":"$(inspect)","category":"Debug"},{"command":"extension.js-debug.callers.add","title":{"value":"Loại trừ hàm gọi","original":"Exclude Caller"},"category":"Debug"},{"command":"extension.js-debug.callers.remove","title":{"value":"Xóa người gọi bị loại trừ","original":"Remove excluded caller"},"icon":"$(close)"},{"command":"extension.js-debug.callers.removeAll","title":{"value":"Xóa tất cả người gọi bị loại trừ","original":"Remove all excluded callers"},"icon":"$(clear-all)"},{"command":"extension.js-debug.callers.goToCaller","title":{"value":"Chuyển đến vị trí người gọi","original":"Go to caller location"},"icon":"$(call-outgoing)"},{"command":"extension.js-debug.callers.gotToTarget","title":{"value":"Chuyển đến vị trí lưu trữ đích","original":"Go to target location"},"icon":"$(call-incoming)"},{"command":"extension.js-debug.enableSourceMapStepping","title":{"value":"Bật Bước nhảy theo Nguồn đã ánh xạ","original":"Enable Source Mapped Stepping"},"icon":"$(compass-dot)"},{"command":"extension.js-debug.disableSourceMapStepping","title":{"value":"Tắt Bước nhảy theo Nguồn đã ánh xạ","original":"Disable Source Mapped Stepping"},"icon":"$(compass)"},{"command":"extension.js-debug.network.viewRequest","title":{"value":"Xem yêu cầu dưới dạng cURL","original":"View Request as cURL"},"icon":"$(arrow-right)"},{"command":"extension.js-debug.network.clear","title":{"value":"Xóa nhật ký mạng","original":"Clear Network Log"},"icon":"$(clear-all)"},{"command":"extension.js-debug.network.openBody","title":{"value":"Mở văn bản phản hồi","original":"Open Response Body"}},{"command":"extension.js-debug.network.openBodyInHex","title":{"value":"Mở văn bản phản hồi trong trình chỉnh sửa hex","original":"Open Response Body in Hex Editor"}},{"command":"extension.js-debug.network.replayXHR","title":{"value":"Phát lại yêu cầu","original":"Replay Request"}},{"command":"extension.js-debug.network.copyUri","title":{"value":"Sao chép ID yêu cầu","original":"Copy Request URL"}}],"keybindings":[{"command":"extension.node-debug.startWithStopOnEntry","key":"F10","mac":"F10","when":"debugConfigurationType == pwa-node && !inDebugMode || debugConfigurationType == pwa-extensionHost && !inDebugMode || debugConfigurationType == node && !inDebugMode"},{"command":"extension.node-debug.startWithStopOnEntry","key":"F11","mac":"F11","when":"debugConfigurationType == pwa-node && !inDebugMode && activeViewlet == workbench.view.debug || debugConfigurationType == pwa-extensionHost && !inDebugMode && activeViewlet == workbench.view.debug || debugConfigurationType == node && !inDebugMode && activeViewlet == workbench.view.debug"}],"configuration":{"title":"JavaScript Debugger","properties":{"debug.javascript.codelens.npmScripts":{"enum":["top","all","never"],"default":"top","description":"Nơi hiển thị \"Chạy\" và \"Gỡ lỗi\" cho CodeLens trong các tập lệnh npm của bạn. Các cài đặt có thể là \"Tất cả\" tập lệnh, \"Ở trên cùng\" phần tập lệnh hoặc \"Không có\"."},"debug.javascript.terminalOptions":{"type":"object","description":"Các tùy chọn khởi động mặc định cho Terminal gỡ lỗi JavaScript và các tập lệnh npm.","default":{},"properties":{"resolveSourceMapLocations":{"type":["array","null"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","default":["${workspaceFolder}/**","!**/node_modules/**"],"items":{"type":"string"}},"outFiles":{"type":["array"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"items":{"type":"string"},"tags":["setup"]},"pauseForSourceMap":{"type":"boolean","markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","default":false},"showAsyncStacks":{"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","default":true,"oneOf":[{"type":"boolean"},{"type":"object","required":["onAttach"],"properties":{"onAttach":{"type":"number","default":32}}},{"type":"object","required":["onceBreakpointResolved"],"properties":{"onceBreakpointResolved":{"type":"number","default":32}}}]},"skipFiles":{"type":"array","description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","default":["${/**"]},"smartStep":{"type":"boolean","description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","default":true},"sourceMaps":{"type":"boolean","description":"Sử dụng tệp sourcemap JavaScript (nếu có).","default":true},"sourceMapRenames":{"type":"boolean","default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi."},"sourceMapPathOverrides":{"type":"object","description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","default":{"webpack://?:*/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","meteor://💻app/*":"${workspaceFolder}/*"}},"timeout":{"type":"number","description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","default":10000},"timeouts":{"type":"object","description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","default":{},"properties":{"sourceMapMinPause":{"type":"number","description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","default":1000},"sourceMapCumulativePause":{"type":"number","description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","default":1000},"hoverEvaluation":{"type":"number","description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","default":500}},"additionalProperties":false,"markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau."},"trace":{"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","default":true,"oneOf":[{"type":"boolean","description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa."},{"type":"object","additionalProperties":false,"properties":{"stdio":{"type":"boolean","description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không."},"logFile":{"type":["string","null"],"description":"Cấu hình nơi ghi nhật ký trên đĩa."}}}]},"outputCapture":{"enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr.","default":"console"},"enableContentValidation":{"default":true,"type":"boolean","description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn."},"customDescriptionGenerator":{"type":"string","description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      "},"customPropertiesGenerator":{"type":"string","deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181"},"cascadeTerminateToConfigurations":{"type":"array","items":{"type":"string","uniqueItems":true},"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc."},"enableDWARF":{"type":"boolean","default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động."},"cwd":{"type":"string","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","default":"${workspaceFolder}","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"]},"localRoot":{"type":["string","null"],"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","default":null},"remoteRoot":{"type":["string","null"],"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","default":null},"autoAttachChildProcesses":{"type":"boolean","description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","default":true},"env":{"type":"object","additionalProperties":{"type":["string","null"]},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","default":{},"tags":["setup"]},"envFile":{"type":"string","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","default":"${workspaceFolder}/.env"},"runtimeSourcemapPausePatterns":{"type":"array","items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","default":[]},"nodeVersionHint":{"type":"number","minimum":8,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","default":12},"command":{"type":["string","null"],"description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","default":"npm start","tags":["setup"]}}},"debug.javascript.automaticallyTunnelRemoteServer":{"type":"boolean","description":"Khi gỡ lỗi ứng dụng web từ xa, cấu hình xem có nên tự động tạo đường hầm máy chủ từ xa về máy cục bộ hay không.","default":true},"debug.javascript.debugByLinkOptions":{"default":"on","description":"Các tùy chọn được sử dụng khi nhấp vào liên kết đã mở trong terminal trong khi gỡ lỗi. Đặt cài đặt này thành \"false\" để tắt hành vi này.","oneOf":[{"type":"string","enum":["on","off","always"]},{"type":"object","properties":{"resolveSourceMapLocations":{"type":["array","null"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","default":null,"items":{"type":"string"}},"outFiles":{"type":["array"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"items":{"type":"string"},"tags":["setup"]},"pauseForSourceMap":{"type":"boolean","markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","default":false},"showAsyncStacks":{"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","default":true,"oneOf":[{"type":"boolean"},{"type":"object","required":["onAttach"],"properties":{"onAttach":{"type":"number","default":32}}},{"type":"object","required":["onceBreakpointResolved"],"properties":{"onceBreakpointResolved":{"type":"number","default":32}}}]},"skipFiles":{"type":"array","description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","default":["${/**"]},"smartStep":{"type":"boolean","description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","default":true},"sourceMaps":{"type":"boolean","description":"Sử dụng tệp sourcemap JavaScript (nếu có).","default":true},"sourceMapRenames":{"type":"boolean","default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi."},"sourceMapPathOverrides":{"type":"object","description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","default":{"webpack://?:*/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","meteor://💻app/*":"${workspaceFolder}/*"}},"timeout":{"type":"number","description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","default":10000},"timeouts":{"type":"object","description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","default":{},"properties":{"sourceMapMinPause":{"type":"number","description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","default":1000},"sourceMapCumulativePause":{"type":"number","description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","default":1000},"hoverEvaluation":{"type":"number","description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","default":500}},"additionalProperties":false,"markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau."},"trace":{"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","default":true,"oneOf":[{"type":"boolean","description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa."},{"type":"object","additionalProperties":false,"properties":{"stdio":{"type":"boolean","description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không."},"logFile":{"type":["string","null"],"description":"Cấu hình nơi ghi nhật ký trên đĩa."}}}]},"outputCapture":{"enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr.","default":"console"},"enableContentValidation":{"default":true,"type":"boolean","description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn."},"customDescriptionGenerator":{"type":"string","description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      "},"customPropertiesGenerator":{"type":"string","deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181"},"cascadeTerminateToConfigurations":{"type":"array","items":{"type":"string","uniqueItems":true},"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc."},"enableDWARF":{"type":"boolean","default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động."},"disableNetworkCache":{"type":"boolean","description":"Chỉ định xem có nên bỏ qua bộ nhớ đệm mạng cho mỗi yêu cầu hay không","default":true},"pathMapping":{"type":"object","description":"Ánh xạ từ URL/đường dẫn đến thư mục cục bộ để phân giải tập lệnh trong trình duyệt thành tập lệnh trên đĩa","default":{}},"webRoot":{"type":"string","description":"Chỉ định đường dẫn tuyệt đối của không gian làm việc đến thư mục gốc của máy chủ web. Được sử dụng để phân giải các đường dẫn như \"/app.js\" thành tệp trên đĩa. Là cách viết tắt cho một pathMapping cho \"/\".","default":"${workspaceFolder}","tags":["setup"]},"urlFilter":{"type":"string","description":"Tìm một trang có URL này và thực hiện đính kèm nếu tìm thấy. Có thể chứa * làm ký tự đại diện.","default":""},"url":{"type":"string","description":"Tìm một tab có chính xác URL này và đính kèm nếu tìm thấy.","default":"http://localhost:8080","tags":["setup"]},"inspectUri":{"type":["string","null"],"description":"Định dạng để viết lại inspectUri: Đây là một chuỗi mẫu nội suy các khóa trong \"{curlyBraces}\". Các khóa có sẵn:\r\n - \"url.*\" là địa chỉ đã phân tích của ứng dụng hiện đang chạy, ví dụ: \"{url.port}\" hoặc \"{url.hostname}\".\r\n - \"port\" là cổng gỡ lỗi mà Chrome đang lắng nghe.\r\n - \"browserInspectUri\" là URI của trình kiểm tra trong trình duyệt đã khởi động\r\n - \"browserInspectUriPath\" là đường dẫn của URI trình kiểm tra trong trình duyệt đã khởi động (ví dụ: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - \"wsProtocol\" là giao thức WebSocket được chỉ định. Được đặt thành \"wss\" nếu URL gốc là URL https. Nếu không, nó được đặt thành \"ws\".","default":null},"vueComponentPaths":{"type":"array","description":"Danh sách các mẫu glob cho tệp để tìm kiếm các thành phần *.vue. Mặc định tìm kiếm toàn bộ không gian làm việc. Cần thiết cho việc tìm kiếm bổ sung để có sourcemap Vue trong Vue CLI 4. Bạn có thể tắt xử lý đặc biệt này bằng cách đặt thành một mảng trống.","default":["${workspaceFolder}/**/*.vue"]},"server":{"oneOf":[{"type":"object","description":"Cấu hình một máy chủ web để khởi động. Sử dụng cấu hình giống với tác vụ khởi động \"node\".","additionalProperties":false,"default":{"program":"node my-server.js"},"properties":{"resolveSourceMapLocations":{"type":["array","null"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","default":["${workspaceFolder}/**","!**/node_modules/**"],"items":{"type":"string"}},"outFiles":{"type":["array"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"items":{"type":"string"},"tags":["setup"]},"pauseForSourceMap":{"type":"boolean","markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","default":false},"showAsyncStacks":{"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","default":true,"oneOf":[{"type":"boolean"},{"type":"object","required":["onAttach"],"properties":{"onAttach":{"type":"number","default":32}}},{"type":"object","required":["onceBreakpointResolved"],"properties":{"onceBreakpointResolved":{"type":"number","default":32}}}]},"skipFiles":{"type":"array","description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","default":["${/**"]},"smartStep":{"type":"boolean","description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","default":true},"sourceMaps":{"type":"boolean","description":"Sử dụng tệp sourcemap JavaScript (nếu có).","default":true},"sourceMapRenames":{"type":"boolean","default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi."},"sourceMapPathOverrides":{"type":"object","description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","default":{"webpack://?:*/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","meteor://💻app/*":"${workspaceFolder}/*"}},"timeout":{"type":"number","description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","default":10000},"timeouts":{"type":"object","description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","default":{},"properties":{"sourceMapMinPause":{"type":"number","description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","default":1000},"sourceMapCumulativePause":{"type":"number","description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","default":1000},"hoverEvaluation":{"type":"number","description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","default":500}},"additionalProperties":false,"markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau."},"trace":{"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","default":true,"oneOf":[{"type":"boolean","description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa."},{"type":"object","additionalProperties":false,"properties":{"stdio":{"type":"boolean","description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không."},"logFile":{"type":["string","null"],"description":"Cấu hình nơi ghi nhật ký trên đĩa."}}}]},"outputCapture":{"enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr.","default":"console"},"enableContentValidation":{"default":true,"type":"boolean","description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn."},"customDescriptionGenerator":{"type":"string","description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      "},"customPropertiesGenerator":{"type":"string","deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181"},"cascadeTerminateToConfigurations":{"type":"array","items":{"type":"string","uniqueItems":true},"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc."},"enableDWARF":{"type":"boolean","default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động."},"cwd":{"type":"string","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","default":"${workspaceFolder}","tags":["setup"]},"localRoot":{"type":["string","null"],"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","default":null},"remoteRoot":{"type":["string","null"],"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","default":null},"autoAttachChildProcesses":{"type":"boolean","description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","default":true},"env":{"type":"object","additionalProperties":{"type":["string","null"]},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","default":{},"tags":["setup"]},"envFile":{"type":"string","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","default":"${workspaceFolder}/.env"},"runtimeSourcemapPausePatterns":{"type":"array","items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","default":[]},"nodeVersionHint":{"type":"number","minimum":8,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","default":12},"program":{"type":"string","description":"Đường dẫn tuyệt đối đến chương trình. Giá trị được tạo ra được ước tính dựa trên \"package.json\" và các tệp đang mở. Hãy chỉnh sửa thuộc tính này.","default":"","tags":["setup"]},"stopOnEntry":{"type":["boolean","string"],"description":"Tùy chọn này sẽ tự động kết thúc chương trình sau khi khởi chạy.","default":true},"console":{"type":"string","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["Bảng điều khiển gỡ lỗi của VS Code (không hỗ trợ đọc đầu vào từ chương trình)","Terminal tích hợp của VS Code","Một terminal bên ngoài có thể được cấu hình thông qua cài đặt người dùng"],"description":"Vị trí khởi chạy của mục tiêu gỡ lỗi","default":"internalConsole"},"args":{"type":["array","string"],"description":"Các đối số dòng lệnh được truyền cho chương trình.\r\n\r\nCó thể là một mảng chuỗi hoặc một chuỗi đơn. Nếu chương trình được khởi chạy trong một terminal, việc đặt thuộc tính này thành một chuỗi đơn sẽ khiến các đối số không được thoát cho shell.","items":{"type":"string"},"default":[],"tags":["setup"]},"restart":{"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","default":true,"oneOf":[{"type":"boolean"},{"type":"object","properties":{"delay":{"type":"number","minimum":0,"default":1000},"maxAttempts":{"type":"number","minimum":0,"default":10}}}]},"runtimeExecutable":{"type":["string","null"],"markdownDescription":"Runtime sẽ được sử dụng: Chỉ định một đường dẫn tuyệt đối hoặc tên của một runtime có sẵn trong đường dẫn. Nếu không chỉ định, sẽ giả định là \"node\".","default":"node"},"runtimeVersion":{"type":"string","markdownDescription":"Phiên bản của node runtime sẽ được sử dụng. Yêu cầu \"nvm\".","default":"default"},"runtimeArgs":{"type":"array","description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"default":[],"tags":["setup"]},"profileStartup":{"type":"boolean","description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi quy trình được khởi động","default":true},"attachSimplePort":{"oneOf":[{"type":"integer"},{"type":"string","pattern":"^\\${.*}$"}],"description":"Nếu được đặt, sẽ gắn kèm vào tiến trình qua cổng được chỉ định. Điều này thường không còn cần thiết cho các chương trình Node.js và không còn hỗ trợ gỡ lỗi tiến trình con. Tuy nhiên, gắn kèm có thể hữu ích trong các kịch bản khởi chạy Deno và Docker. Nếu đặt là 0, một cổng ngẫu nhiên sẽ được chọn và \"--inspect-brk\" sẽ tự động được thêm vào các đối số khởi chạy.","default":9229},"killBehavior":{"type":"string","enum":["forceful","polite","none"],"default":"forceful","markdownDescription":"Cấu hình cách kết thúc các tiến trình gỡ lỗi khi phiên kết thúc. Các tùy chọn có thể:\r\n\r\n– forceful (mặc định): Buộc chấm dứt cây tiến trình. Trên POSIX, gửi SIGKILL; trên Windows, sử dụng \"taskkill.exe /F\".\r\n– polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM; trên Windows, sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n– none: Không kết thúc."},"experimentalNetworking":{"type":"string","default":"auto","description":"Bật tính năng kiểm tra thử nghiệm trong Node.js. Với cài đặt `auto`, tính năng này được bật cho các phiên bản Node.js hỗ trợ nó. Có thể đặt thành `on` hoặc `off` để bật hoặc tắt một cách rõ ràng.","enum":["auto","on","off"]}}},{"type":"object","description":"Terminal gỡ lỗi JavaScript","additionalProperties":false,"default":{"program":"npm start"},"properties":{"resolveSourceMapLocations":{"type":["array","null"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","default":["${workspaceFolder}/**","!**/node_modules/**"],"items":{"type":"string"}},"outFiles":{"type":["array"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"items":{"type":"string"},"tags":["setup"]},"pauseForSourceMap":{"type":"boolean","markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","default":false},"showAsyncStacks":{"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","default":true,"oneOf":[{"type":"boolean"},{"type":"object","required":["onAttach"],"properties":{"onAttach":{"type":"number","default":32}}},{"type":"object","required":["onceBreakpointResolved"],"properties":{"onceBreakpointResolved":{"type":"number","default":32}}}]},"skipFiles":{"type":"array","description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","default":["${/**"]},"smartStep":{"type":"boolean","description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","default":true},"sourceMaps":{"type":"boolean","description":"Sử dụng tệp sourcemap JavaScript (nếu có).","default":true},"sourceMapRenames":{"type":"boolean","default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi."},"sourceMapPathOverrides":{"type":"object","description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","default":{"webpack://?:*/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","meteor://💻app/*":"${workspaceFolder}/*"}},"timeout":{"type":"number","description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","default":10000},"timeouts":{"type":"object","description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","default":{},"properties":{"sourceMapMinPause":{"type":"number","description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","default":1000},"sourceMapCumulativePause":{"type":"number","description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","default":1000},"hoverEvaluation":{"type":"number","description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","default":500}},"additionalProperties":false,"markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau."},"trace":{"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","default":true,"oneOf":[{"type":"boolean","description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa."},{"type":"object","additionalProperties":false,"properties":{"stdio":{"type":"boolean","description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không."},"logFile":{"type":["string","null"],"description":"Cấu hình nơi ghi nhật ký trên đĩa."}}}]},"outputCapture":{"enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr.","default":"console"},"enableContentValidation":{"default":true,"type":"boolean","description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn."},"customDescriptionGenerator":{"type":"string","description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      "},"customPropertiesGenerator":{"type":"string","deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181"},"cascadeTerminateToConfigurations":{"type":"array","items":{"type":"string","uniqueItems":true},"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc."},"enableDWARF":{"type":"boolean","default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động."},"cwd":{"type":"string","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","default":"${workspaceFolder}","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"]},"localRoot":{"type":["string","null"],"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","default":null},"remoteRoot":{"type":["string","null"],"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","default":null},"autoAttachChildProcesses":{"type":"boolean","description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","default":true},"env":{"type":"object","additionalProperties":{"type":["string","null"]},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","default":{},"tags":["setup"]},"envFile":{"type":"string","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","default":"${workspaceFolder}/.env"},"runtimeSourcemapPausePatterns":{"type":"array","items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","default":[]},"nodeVersionHint":{"type":"number","minimum":8,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","default":12},"command":{"type":["string","null"],"description":"Lệnh để thực thi trong terminal đã khởi động. Nếu không có, terminal sẽ mở mà không khởi chạy chương trình.","default":"npm start","tags":["setup"]}}}]},"perScriptSourcemaps":{"type":"string","default":"auto","enum":["yes","no","auto"],"description":"Chỉ định xem các tập lệnh có được tải riêng lẻ với các sourcemap duy nhất chứa tên cơ bản của tệp nguồn hay không. Tùy chọn này có thể được đặt để tối ưu hóa xử lý sourcemap khi làm việc với nhiều tập lệnh nhỏ. Nếu đặt thành \"Tự động\", các trường hợp đã biết mà việc xử lý này phù hợp sẽ được phát hiện."},"port":{"type":"number","description":"Cổng mà trình duyệt đang lắng nghe. Giá trị mặc định là \"0\", khiến việc gỡ lỗi trình duyệt được thực hiện qua đường ống. Tùy chọn này thường an toàn hơn và nên được sử dụng - trừ khi bạn cần đính kèm trình duyệt bằng một công cụ khác.","default":0},"file":{"type":"string","description":"Một tệp HTML cục bộ để mở trong trình duyệt","default":"${workspaceFolder}/index.html","tags":["setup"]},"userDataDir":{"type":["string","boolean"],"description":"Theo mặc định, trình duyệt được khởi chạy với hồ sơ người dùng riêng biệt trong thư mục tạm thời. Sử dụng tùy chọn này để ghi đè. Đặt giá trị này thành \"false\" để khởi chạy với hồ sơ người dùng mặc định của bạn. Không thể khởi chạy trình duyệt mới nếu một phiên bản đang chạy từ userDataDir.","default":true},"includeDefaultArgs":{"type":"boolean","description":"Chỉ định xem có bao gồm các đối số mặc định khi khởi động trình duyệt (để tắt các tính năng có thể gây khó khăn cho việc gỡ lỗi) khi bắt đầu hay không.","default":true},"includeLaunchArgs":{"type":"boolean","description":"Nâng cao: Chỉ định xem các đối số khởi động/gỡ lỗi mặc định có được đặt trong trình duyệt hay không. Trình gỡ lỗi giả định rằng trình duyệt sử dụng gỡ lỗi qua đường ống, chẳng hạn như được cung cấp với \"--remote-debugging-pipe\".","default":true},"runtimeExecutable":{"type":["string","null"],"description":"Có thể là \"canary\", \"stable\", \"custom\" hoặc đường dẫn đến tệp thực thi trình duyệt. \"custom\" đại diện cho một wrapper tùy chỉnh, bản dựng tùy chỉnh hoặc biến môi trường CHROME_PATH.","default":"stable"},"runtimeArgs":{"type":"array","description":"Các đối số tùy chọn được truyền cho tệp thực thi của runtime.","items":{"type":"string"},"default":[]},"env":{"type":"object","description":"Từ điển tùy chọn các cặp khóa/giá trị môi trường cho trình duyệt.","default":{}},"cwd":{"type":"string","description":"Thư mục làm việc tùy chọn cho tệp thực thi runtime.","default":null},"profileStartup":{"type":"boolean","description":"Nếu là TRUE, việc tạo hồ sơ sẽ bắt đầu ngay khi tiến trình khởi động.","default":true},"cleanUp":{"type":"string","enum":["wholeBrowser","onlyTab"],"description":"Hoạt động dọn dẹp sau khi phiên gỡ lỗi kết thúc. Chỉ đóng tab đang được gỡ lỗi, không đóng toàn bộ trình duyệt.","default":"wholeBrowser"},"killBehavior":{"type":"string","enum":["forceful","polite","none"],"default":"forceful","markdownDescription":"Định cấu hình cách các tiến trình trình duyệt bị kết thúc khi phiên kết thúc với \"cleanUp: wholeBrowser\". Các tùy chọn có thể:\r\n\r\n- forceful (mặc định): Buộc kết thúc cây tiến trình. Trên POSIX, gửi SIGKILL, trên Windows sử dụng \"taskkill.exe /F\".\r\n- polite: Kết thúc cây tiến trình một cách lịch sự. Các tiến trình không có hành vi tắt tiêu chuẩn có thể vẫn chạy sau khi tắt. Trên POSIX, gửi SIGTERM, trên Windows sử dụng \"taskkill.exe\" không có cờ \"/F (force)\".\r\n- none: Không kết thúc."},"browserLaunchLocation":{"description":"Buộc trình duyệt khởi động tại một vị trí duy nhất. Trong không gian làm việc từ xa (ví dụ: qua SSH hoặc WSL), cài đặt này có thể được sử dụng để mở trình duyệt trên máy từ xa thay vì trên máy cục bộ.","default":null,"oneOf":[{"type":"null"},{"type":"string","enum":["ui","workspace"]}]},"enabled":{"type":"string","enum":["on","off","always"]}}}]},"debug.javascript.pickAndAttachOptions":{"type":"object","default":{},"markdownDescription":"Các tùy chọn mặc định được sử dụng khi gỡ lỗi một tiến trình thông qua lệnh \"Gỡ lỗi: Đính kèm vào tiến trình Node.js\"","properties":{"resolveSourceMapLocations":{"type":["array","null"],"description":"Danh sách các mẫu Minimatch cho các vị trí (thư mục và URL) nơi các tệp ánh xạ nguồn có thể được sử dụng để giải quyết các tệp cục bộ. Điều này có thể tránh việc mã từ các tệp ánh xạ nguồn bên ngoài bị bọc sai. Bạn có thể thêm tiền tố \"!\" vào các mẫu để loại trừ chúng. Có thể đặt thành một mảng trống hoặc NULL để tránh các hạn chế.","default":["${workspaceFolder}/**","!**/node_modules/**"],"items":{"type":"string"}},"outFiles":{"type":["array"],"description":"Khi các tệp ánh xạ nguồn được bật, các mẫu glob này chỉ định các tệp JavaScript được tạo. Nếu một mẫu bắt đầu bằng \"!\", các tệp sẽ bị loại trừ. Nếu không được chỉ định, mã được tạo ra sẽ được mong đợi trong cùng thư mục với nguồn tương ứng.","default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"items":{"type":"string"},"tags":["setup"]},"pauseForSourceMap":{"type":"boolean","markdownDescription":"Xác định xem có nên đợi các tệp ánh xạ nguồn được tải cho mỗi tập lệnh đến hay không. Điều này có chi phí hiệu suất và có thể được tắt một cách an toàn nếu chạy trên ổ đĩa, miễn là \"rootPath\" không bị tắt.","default":false},"showAsyncStacks":{"description":"Hiển thị các cuộc gọi không đồng bộ dẫn đến ngăn xếp cuộc gọi hiện tại.","default":true,"oneOf":[{"type":"boolean"},{"type":"object","required":["onAttach"],"properties":{"onAttach":{"type":"number","default":32}}},{"type":"object","required":["onceBreakpointResolved"],"properties":{"onceBreakpointResolved":{"type":"number","default":32}}}]},"skipFiles":{"type":"array","description":"Một mảng các tên tệp hoặc thư mục, hoặc các glob đường dẫn sẽ được bỏ qua khi gỡ lỗi. Cho phép sử dụng mẫu sao và phủ định, ví dụ: [\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]","default":["${/**"]},"smartStep":{"type":"boolean","description":"Tự động bước qua mã được tạo không thể ánh xạ về nguồn gốc.","default":true},"sourceMaps":{"type":"boolean","description":"Sử dụng tệp sourcemap JavaScript (nếu có).","default":true},"sourceMapRenames":{"type":"boolean","default":true,"description":"Chỉ định liệu có sử dụng ánh xạ \"names\" trong sourcemap hay không. Điều này yêu cầu lấy nội dung nguồn, có thể chậm với một số trình gỡ lỗi."},"sourceMapPathOverrides":{"type":"object","description":"Một nhóm ánh xạ để viết lại đường dẫn tệp nguồn được chỉ định trong bản đồ nguồn thành đường dẫn trên đĩa của chúng.","default":{"webpack://?:*/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","meteor://💻app/*":"${workspaceFolder}/*"}},"timeout":{"type":"number","description":"Chỉ định khoảng thời gian tính bằng mili giây trước khi thử kết nối lại với Node.js. Giá trị mặc định là 10000 ms.","default":10000},"timeouts":{"type":"object","description":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau.","default":{},"properties":{"sourceMapMinPause":{"type":"number","description":"Thời gian tối thiểu tính bằng mili giây chờ xử lý mỗi ánh xạ nguồn khi phân tích một tập lệnh.","default":1000},"sourceMapCumulativePause":{"type":"number","description":"Thời gian bổ sung tính bằng mili giây chờ xử lý ánh xạ nguồn mỗi phiên sau khi thời gian tối thiểu (sourceMapMinPause) đã trôi qua.","default":1000},"hoverEvaluation":{"type":"number","description":"Thời gian trước khi hủy đánh giá giá trị cho các biểu tượng khi di chuột qua. Nếu đặt thành 0, việc đánh giá khi di chuột sẽ không bao giờ bị hủy.","default":500}},"additionalProperties":false,"markdownDescription":"Giới hạn thời gian cho các hoạt động gỡ lỗi khác nhau."},"trace":{"description":"Cấu hình đầu ra chẩn đoán nào được tạo ra.","default":true,"oneOf":[{"type":"boolean","description":"Có thể đặt thành TRUE để ghi nhật ký chẩn đoán vào đĩa."},{"type":"object","additionalProperties":false,"properties":{"stdio":{"type":"boolean","description":"Chỉ định xem có nên trả về dữ liệu theo dõi từ ứng dụng hoặc trình duyệt đã khởi chạy hay không."},"logFile":{"type":["string","null"],"description":"Cấu hình nơi ghi nhật ký trên đĩa."}}}]},"outputCapture":{"enum":["console","std"],"markdownDescription":"Xác định nơi ghi lại các thông báo đầu ra. Nếu đặt là \"console\", sẽ sử dụng API gỡ lỗi mặc định; nếu đặt là \"std\", sẽ sử dụng các luồng stdout/stderr.","default":"console"},"enableContentValidation":{"default":true,"type":"boolean","description":"Bật hoặc tắt việc kiểm tra xem nội dung của tệp trên đĩa có khớp với nội dung của tệp được tải lúc runtime hay không. Điều này hữu ích trong nhiều tình huống và đôi khi cần thiết, nhưng có thể gây ra vấn đề nếu bạn thực hiện chuyển đổi phía máy chủ cho script, chẳng hạn."},"customDescriptionGenerator":{"type":"string","description":"Tùy chỉnh mô tả văn bản mà trình gỡ lỗi hiển thị cho các đối tượng (ví dụ: biến cục bộ). Ví dụ:\r\n      1. this.toString() // Gọi \"toString\" để in tất cả đối tượng.\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      3. function (def) { return this.customDescription ? this.customDescription() : def } // Sử dụng phương thức customDescription nếu có, nếu không thì trả về giá trị defaultValue.\r\n      "},"customPropertiesGenerator":{"type":"string","deprecated":true,"description":"Tùy chỉnh các thuộc tính được hiển thị cho một đối tượng trong trình gỡ lỗi (biến cục bộ, v.v.). Ví dụ:\r\n    1. { ...this, extraProperty: '12345' } // Thêm thuộc tính bổ sung \"12345\" vào tất cả đối tượng.\r\n    2. this.customProperties ? this.customProperties() : this // Sử dụng phương thức customProperties (nếu có), nếu không thì sử dụng các thuộc tính this (các thuộc tính mặc định)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Sử dụng phương thức customDescription (nếu có), nếu không thì trả về các thuộc tính mặc định.\r\n\r\n    Đã lỗi thời: Đây là một triển khai tạm thời của tính năng cho đến khi chúng tôi có thời gian để triển khai nó như mô tả ở đây: https://github.com/microsoft/vscode/issues/102181"},"cascadeTerminateToConfigurations":{"type":"array","items":{"type":"string","uniqueItems":true},"default":[],"description":"Danh sách các phiên gỡ lỗi sẽ bị kết thúc khi phiên gỡ lỗi này kết thúc."},"enableDWARF":{"type":"boolean","default":true,"markdownDescription":"Chuyển đổi việc trình gỡ lỗi có cố đọc ký hiệu gỡ lỗi DWARF từ WebAssembly hay không, việc này có thể tốn tài nguyên. Yêu cầu tiện ích mở rộng \"ms-vscode.wasm-debugging\" để hoạt động."},"cwd":{"type":"string","description":"Đường dẫn tuyệt đối đến thư mục làm việc của chương trình đang được gỡ lỗi. Nếu bạn đã đặt \"localRoot\", CWD sẽ bằng giá trị đó, nếu không, CWD sẽ được đặt lại thành \"workspaceFolder\".","default":"${workspaceFolder}","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"]},"localRoot":{"type":["string","null"],"description":"Đường dẫn đến thư mục cục bộ chứa chương trình.","default":null},"remoteRoot":{"type":["string","null"],"description":"Đường dẫn tuyệt đối đến thư mục từ xa chứa chương trình.","default":null},"autoAttachChildProcesses":{"type":"boolean","description":"Tự động gắn trình gỡ lỗi vào các tiến trình con mới.","default":true},"env":{"type":"object","additionalProperties":{"type":["string","null"]},"markdownDescription":"Các biến môi trường được truyền cho chương trình. Giá trị NULL sẽ xóa biến khỏi môi trường.","default":{},"tags":["setup"]},"envFile":{"type":"string","description":"Đường dẫn tuyệt đối đến tệp chứa định nghĩa biến môi trường.","default":"${workspaceFolder}/.env"},"runtimeSourcemapPausePatterns":{"type":"array","items":{"type":"string"},"markdownDescription":"Danh sách các mẫu để chèn thủ công các điểm dừng tại điểm vào. Điều này cho phép trình gỡ lỗi đặt điểm dừng khi sử dụng các tệp ánh xạ nguồn không tồn tại hoặc không thể được phát hiện trước khi khởi động, chẳng hạn như với [Serverless Framework](https://github.com/microsoft/vscode-js-debug/issues/492).","default":[]},"nodeVersionHint":{"type":"number","minimum":8,"description":"Cho phép bạn chỉ định rõ phiên bản Node đang chạy, có thể được sử dụng để vô hiệu hóa hoặc kích hoạt các hành vi nhất định khi phát hiện phiên bản tự động không hoạt động.","default":12},"address":{"type":"string","description":"Địa chỉ TCP/IP của tiến trình cần gỡ lỗi. Giá trị mặc định là \"localhost\".","default":"localhost"},"port":{"description":"Cổng gỡ lỗi để đính kèm. Mặc định là 9229.","default":9229,"oneOf":[{"type":"integer"},{"type":"string","pattern":"^\\${.*}$"}],"tags":["setup"]},"websocketAddress":{"type":"string","description":"Địa chỉ WebSocket chính xác cho quá trình đính kèm. Nếu không được cung cấp, nó sẽ được suy ra từ địa chỉ và cổng."},"remoteHostHeader":{"type":"string","description":"Tiêu đề máy chủ rõ ràng sẽ được sử dụng khi kết nối với websocket của thanh tra viên. Nếu không chỉ định, tiêu đề máy chủ sẽ được đặt thành \"localhost\". Điều này hữu ích khi thanh tra viên chạy sau một proxy chỉ chấp nhận một tiêu đề máy chủ cụ thể."},"restart":{"description":"Thử kết nối lại với chương trình nếu kết nối bị ngắt. Nếu đặt là TRUE, sẽ thử lại mỗi giây một lần vô thời hạn. Bạn có thể điều chỉnh khoảng thời gian và số lần thử tối đa bằng cách chỉ định một đối tượng với \"delay\" và \"maxAttempts\".","default":true,"oneOf":[{"type":"boolean"},{"type":"object","properties":{"delay":{"type":"number","minimum":0,"default":1000},"maxAttempts":{"type":"number","minimum":0,"default":10}}}]},"processId":{"type":"string","description":"ID của tiến trình để gắn kèm.","default":"${command:PickProcess}"},"attachExistingChildren":{"type":"boolean","description":"Chỉ định có nên thử gắn kèm các tiến trình con đã được tạo sẵn hay không.","default":false},"continueOnAttach":{"type":"boolean","markdownDescription":"Nếu là TRUE, các chương trình tự động khởi chạy sẽ được tiếp tục và sẽ chờ --inspect-brk","default":true}}},"debug.javascript.autoAttachFilter":{"type":"string","default":"disabled","enum":["always","smart","onlyWithFlag","disabled"],"enumDescriptions":["Tự động đính kèm vào mọi tiến trình Node.js được khởi chạy trong terminal.","Tự động đính kèm khi chạy các tập lệnh không nằm trong thư mục node_modules.","Chỉ tự động đính kèm khi \"--inspect\" được chỉ định.","Tự động đính kèm bị tắt và không hiển thị trên thanh trạng thái."],"markdownDescription":"Cấu hình các tiến trình nào sẽ tự động đính kèm và gỡ lỗi khi \"#debug.node.autoAttach#\" được bật. Một tiến trình Node được khởi chạy với cờ \"--inspect\" sẽ luôn được đính kèm bất kể cài đặt này."},"debug.javascript.autoAttachSmartPattern":{"type":"array","items":{"type":"string"},"default":["${workspaceFolder}/**","!**/node_modules/**","**/$KNOWN_TOOLS$/**"],"markdownDescription":"Cấu hình các mẫu glob để xác định khi nào đính kèm trong chế độ \"thông minh\" #debug.javascript.autoAttachFilter#. \"$KNOWN_TOOLS$\" được thay thế bằng danh sách tên của các công cụ chạy thử nghiệm và mã phổ biến. [Xem thêm trong tài liệu VS Code](https://code.visualstudio.com/docs/nodejs/nodejs-debugging#_auto-attach-smart-patterns)."},"debug.javascript.breakOnConditionalError":{"type":"boolean","default":false,"markdownDescription":"Chỉ định liệu có nên dừng thao tác khi các điểm dừng có điều kiện gây ra lỗi hay không."},"debug.javascript.unmapMissingSources":{"type":"boolean","default":false,"description":"Cấu hình việc ánh xạ tệp Sourcemap có thể không đọc được tệp gốc có bị tự động hủy bỏ hay không. Nếu giá trị này là FALSE (mặc định), một lời nhắc sẽ được hiển thị."},"debug.javascript.defaultRuntimeExecutable":{"type":"object","default":{"pwa-node":"node"},"markdownDescription":"Giá trị mặc định cho \"runtimeExecutable\" được sử dụng cho các cấu hình khởi chạy nếu không được chỉ định. Có thể dùng để cấu hình đường dẫn tùy chỉnh cho cài đặt Node.js hoặc trình duyệt.","properties":{"pwa-node":{"type":"string"},"pwa-chrome":{"type":"string"},"pwa-msedge":{"type":"string"}}},"debug.javascript.resourceRequestOptions":{"type":"object","default":{},"markdownDescription":"Các tùy chọn yêu cầu được sử dụng khi tải tài nguyên như các tệp bản đồ nguồn trong trình gỡ lỗi. Có thể cần cấu hình các tùy chọn này nếu tệp bản đồ nguồn của bạn yêu cầu xác thực hoặc sử dụng chứng chỉ tự ký. Các tùy chọn được dùng để tạo một yêu cầu bằng thư viện [\"got\"](https://github.com/sindresorhus/got).\r\n\r\nMột trường hợp phổ biến là vô hiệu hóa việc kiểm tra chứng chỉ bằng cách truyền \"{ \"https\": { \"rejectUnauthorized\": false } }\"."},"debug.javascript.enableNetworkView":{"type":"boolean","default":true,"description":"Bật chế độ xem mạng thử nghiệm cho các mục tiêu hỗ trợ nó."}}},"grammars":[{"language":"wat","scopeName":"text.wat","path":"./src/ui/basic-wat.tmLanguage.json"}],"languages":[{"id":"wat","extensions":[".wat",".wasm"],"aliases":["WebAssembly Text Format"],"firstLine":"^\\(module","mimetypes":["text/wat"],"configuration":"./src/ui/basic-wat.configuration.json"}],"terminal":{"profiles":[{"id":"extension.js-debug.debugTerminal","title":"Terminal gỡ lỗi JavaScript","icon":"$(debug)"}]},"views":{"debug":[{"id":"jsBrowserBreakpoints","name":"Browser Options","when":"debugType == pwa-chrome || debugType == pwa-msedge"},{"id":"jsExcludedCallers","name":"Excluded Callers","when":"debugType == pwa-extensionHost && jsDebugHasExcludedCallers || debugType == node-terminal && jsDebugHasExcludedCallers || debugType == pwa-node && jsDebugHasExcludedCallers || debugType == pwa-chrome && jsDebugHasExcludedCallers || debugType == pwa-msedge && jsDebugHasExcludedCallers"},{"id":"jsDebugNetworkTree","name":"Network","when":"jsDebugNetworkAvailable"}]},"viewsWelcome":[{"view":"debug","contents":"[Terminal gỡ lỗi JavaScript](command:extension.js-debug.createDebuggerTerminal)\r\n\r\nTerminal gỡ lỗi JavaScript cho phép bạn gỡ lỗi các tiến trình Node.js chạy trong dòng lệnh.\r\n\r\n[URL gỡ lỗi](command:extension.js-debug.debugLink)","when":"debugStartLanguage == javascript && !isWeb || debugStartLanguage == typescript && !isWeb || debugStartLanguage == javascriptreact && !isWeb || debugStartLanguage == typescriptreact && !isWeb"},{"view":"debug","contents":"[Ter