"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.html-language-features"},"manifest":{"name":"html-language-features","displayName":"Tính năng ngôn ngữ HTML","description":"Hỗ trợ ngôn ngữ phong phú cho các tệp HTML và HANDLEBAR","version":"10.0.0","publisher":"vscode","license":"MIT","aiKey":"0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255","engines":{"vscode":"^1.77.0"},"icon":"icons/html.png","activationEvents":["onLanguage:html","onLanguage:handlebars"],"enabledApiProposals":["extensionsAny"],"main":"./client/dist/node/htmlClientMain","browser":"./client/dist/browser/htmlClientMain","capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"categories":["Programming Languages"],"contributes":{"configuration":{"id":"html","order":20,"type":"object","title":"HTML","properties":{"html.completion.attributeDefaultValue":{"type":"string","scope":"resource","enum":["doublequotes","singlequotes","empty"],"enumDescriptions":["Giá trị thuộc tính được đặt thành \"\".","Giá trị thuộc tính được đặt thành \".","Giá trị thuộc tính không được đặt."],"default":"doublequotes","markdownDescription":"Điều khiển giá trị mặc định cho thuộc tính khi chấp nhận hoàn thành."},"html.customData":{"type":"array","markdownDescription":"Danh sách các đường dẫn tệp tương đối tham chiếu đến các tệp JSON theo [định dạng dữ liệu tùy chỉnh](https://github.com/microsoft/vscode-html-languageservice/blob/master/docs/customData.md).\r\n\r\nVS Code tải dữ liệu tùy chỉnh khi khởi động để nâng cao hỗ trợ HTML cho các thẻ HTML, thuộc tính và giá trị thuộc tính tùy chỉnh mà bạn chỉ định trong các tệp JSON.\r\n\r\nCác đường dẫn tệp được chỉ định tương đối với không gian làm việc và chỉ các cài đặt cho thư mục không gian làm việc được xem xét.","default":[],"items":{"type":"string"},"scope":"resource"},"html.format.enable":{"type":"boolean","scope":"window","default":true,"description":"Bật/Tắt trình định dạng mặc định HTML."},"html.format.wrapLineLength":{"type":"integer","scope":"resource","default":120,"description":"Số ký tự tối đa mỗi dòng (0 = tắt)."},"html.format.unformatted":{"type":["string","null"],"scope":"resource","default":"wbr","markdownDescription":"Danh sách các thẻ (phân cách bằng dấu phẩy) không được định dạng lại. Mặc định `null` áp dụng cho tất cả thẻ được liệt kê tại https://www.w3.org/TR/html5/dom.html#phrasing-content."},"html.format.contentUnformatted":{"type":["string","null"],"scope":"resource","default":"pre,code,textarea","markdownDescription":"Danh sách các thẻ (được phân tách bằng dấu phẩy) trong đó nội dung không cần định dạng lại. `null` mặc định khớp với thẻ `pre`."},"html.format.indentInnerHtml":{"type":"boolean","scope":"resource","default":false,"markdownDescription":"Thụt lề các phần `<head>` và `<body>`."},"html.format.preserveNewLines":{"type":"boolean","scope":"resource","default":true,"description":"Xác định xem có giữ lại ngắt dòng hiện có trước phần tử không. Chỉ hoạt động trước phần tử, không trong thẻ hoặc văn bản."},"html.format.maxPreserveNewLines":{"type":["number","null"],"scope":"resource","default":null,"markdownDescription":"Số dòng trống tối đa được giữ lại trong một khối. Dùng `null` để không giới hạn."},"html.format.indentHandlebars":{"type":"boolean","scope":"resource","default":false,"markdownDescription":"Định dạng `{{#foo}}` và `{{/foo}}` và thụt lề."},"html.format.extraLiners":{"type":["string","null"],"scope":"resource","default":"head, body, /html","markdownDescription":"Danh sách các thẻ (được phân tách bằng dấu phẩy) mà trước đó nên chèn một dòng mới bổ sung. `null` mặc định sử dụng `\"head, body, /HTML\"`."},"html.format.wrapAttributes":{"type":"string","scope":"resource","default":"auto","enum":["auto","force","force-aligned","force-expand-multiline","aligned-multiple","preserve","preserve-aligned"],"enumDescriptions":["Chỉ xuống dòng thuộc tính khi vượt quá độ dài dòng.","Xuống dòng tất cả thuộc tính trừ thuộc tính đầu tiên.","Xuống dòng tất cả thuộc tính trừ thuộc tính đầu tiên và giữ căn chỉnh.","Xuống dòng tất cả thuộc tính.","Xuống dòng khi vượt quá độ dài dòng và căn chỉnh thuộc tính theo chiều dọc.","Giữ nguyên cách xuống dòng thuộc tính.","Giữ nguyên cách xuống dòng thuộc tính nhưng căn chỉnh."],"description":"Xuống dòng thuộc tính."},"html.format.wrapAttributesIndentSize":{"type":["number","null"],"scope":"resource","default":null,"markdownDescription":"Thụt lề thuộc tính đã xuống dòng sau N ký tự. Dùng \"null\" để dùng kích thước thụt lề mặc định. Bị bỏ qua nếu \"#html.format.wrapAttributes#\" đặt thành \"aligned\"."},"html.format.templating":{"type":"boolean","scope":"resource","default":false,"description":"Xem xét các thẻ ngôn ngữ cho mẫu Django, ERB, Handlebars và PHP."},"html.format.unformattedContentDelimiter":{"type":"string","scope":"resource","default":"","markdownDescription":"Giữ nội dung văn bản bên trong chuỗi này dính liền."},"html.suggest.html5":{"type":"boolean","scope":"resource","default":true,"description":"Xác định xem hỗ trợ ngôn ngữ HTML tích hợp có gợi ý thẻ, thuộc tính và giá trị HTML5 không."},"html.suggest.hideEndTagSuggestions":{"type":"boolean","scope":"resource","default":false,"description":"Controls whether the built-in HTML language support suggests closing tags. When disabled, end tag completions like `</div>` will not be shown."},"html.validate.scripts":{"type":"boolean","scope":"resource","default":true,"description":"Xác định xem hỗ trợ ngôn ngữ HTML tích hợp có xác thực tập lệnh nhúng không."},"html.validate.styles":{"type":"boolean","scope":"resource","default":true,"description":"Xác định xem hỗ trợ ngôn ngữ HTML tích hợp có xác thực kiểu nhúng không."},"html.autoCreateQuotes":{"type":"boolean","scope":"resource","default":true,"markdownDescription":"Bật/Tắt tính năng tự động tạo dấu ngoặc kép cho phép gán thuộc tính HTML. Loại dấu ngoặc kép có thể được cấu hình bằng `#html.completion.attributeDefaultValue#`."},"html.autoClosingTags":{"type":"boolean","scope":"resource","default":true,"description":"Bật/Tắt tính năng tự động đóng thẻ HTML."},"html.hover.documentation":{"type":"boolean","scope":"resource","default":true,"description":"Hiển thị tài liệu thẻ và thuộc tính khi di chuột qua phần tử."},"html.hover.references":{"type":"boolean","scope":"resource","default":true,"description":"Hiển thị tham chiếu MDN khi di chuột qua phần tử."},"html.mirrorCursorOnMatchingTag":{"type":"boolean","scope":"resource","default":false,"description":"Bật/tắt con trỏ nhảy khi khớp thẻ HTML","deprecationMessage":"Đã lỗi thời và được thay thế bằng \"editor.linkedEditing\""},"html.trace.server":{"type":"string","scope":"window","enum":["off","messages","verbose"],"default":"off","description":"Theo dõi giao tiếp giữa VS Code và máy chủ ngôn ngữ HTML."}}},"configurationDefaults":{"[html]":{"editor.suggest.insertMode":"replace"},"[handlebars]":{"editor.suggest.insertMode":"replace"}},"jsonValidation":[{"fileMatch":"*.html-data.json","url":"https://raw.githubusercontent.com/microsoft/vscode-html-languageservice/master/docs/customData.schema.json"},{"fileMatch":"package.json","url":"./schemas/package.schema.json"}]},"repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/opt/visual-studio-code/resources/app/extensions/html-language-features","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[],"preRelease":false},{"type":0,"identifier":{"id":"vscode.ini"},"manifest":{"name":"ini","displayName":"Cơ bản về ngôn ngữ Ini","description":"Cung cấp tô sáng cú pháp và khớp ngoặc trong tệp Ini.","version":"10.0.0","private":true,"publisher":"vscode","license":"MIT","engines":{"vscode":"*"},"scripts":{"update-grammar":"node ../node_modules/vscode-grammar-updater/bin textmate/ini.tmbundle Syntaxes/Ini.plist ./syntaxes/ini.tmLanguage.json"},"categories":["Programming Languages"],"cont