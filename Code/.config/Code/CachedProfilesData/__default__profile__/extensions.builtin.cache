s":{"virtualWorkspaces":{"supported":"limited","description":"Các chức năng yêu cầu thực thi lệnh \"npm\" không khả dụng trong không gian làm việc ảo."},"untrustedWorkspaces":{"supported":"limited","description":"Tiện ích mở rộng này thực hiện các tác vụ đòi hỏi phải có mức độ tin cậy để thực thi."}},"contributes":{"languages":[{"id":"ignore","extensions":[".npmignore"]},{"id":"properties","extensions":[".npmrc"]}],"views":{"explorer":[{"id":"npm","name":"Các script npm","when":"npm:showScriptExplorer","icon":"$(json)","visibility":"hidden","contextualTitle":"Các script npm"}]},"commands":[{"command":"npm.runScript","title":{"value":"Khởi chạy","original":"Run"},"icon":"$(run)"},{"command":"npm.debugScript","title":{"value":"Gỡ lỗi","original":"Debug"},"icon":"$(debug)"},{"command":"npm.openScript","title":{"value":"Mở","original":"Open"}},{"command":"npm.runInstall","title":{"value":"Thực thi cài đặt","original":"Run Install"}},{"command":"npm.refresh","title":{"value":"Cập nhật","original":"Refresh"},"icon":"$(refresh)"},{"command":"npm.runSelectedScript","title":{"value":"Chạy tập lệnh","original":"Run Script"}},{"command":"npm.runScriptFromFolder","title":{"value":"Chạy tập lệnh NPM trong thư mục...","original":"Run NPM Script in Folder..."}},{"command":"npm.packageManager","title":{"value":"Lấy trình quản lý gói đã cấu hình","original":"Get Configured Package Manager"}}],"menus":{"commandPalette":[{"command":"npm.refresh","when":"false"},{"command":"npm.runScript","when":"false"},{"command":"npm.debugScript","when":"false"},{"command":"npm.openScript","when":"false"},{"command":"npm.runInstall","when":"false"},{"command":"npm.runSelectedScript","when":"false"},{"command":"npm.runScriptFromFolder","when":"false"},{"command":"npm.packageManager","when":"false"}],"editor/context":[{"command":"npm.runSelectedScript","when":"resourceFilename == 'package.json' && resourceScheme == file","group":"navigation@+1"}],"view/title":[{"command":"npm.refresh","when":"view == npm","group":"navigation"}],"view/item/context":[{"command":"npm.openScript","when":"view == npm && viewItem == packageJSON","group":"navigation@1"},{"command":"npm.runInstall","when":"view == npm && viewItem == packageJSON","group":"navigation@2"},{"command":"npm.openScript","when":"view == npm && viewItem == script","group":"navigation@1"},{"command":"npm.runScript","when":"view == npm && viewItem == script","group":"navigation@2"},{"command":"npm.runScript","when":"view == npm && viewItem == script","group":"inline"},{"command":"npm.debugScript","when":"view == npm && viewItem == script","group":"inline"},{"command":"npm.debugScript","when":"view == npm && viewItem == script","group":"navigation@3"}],"explorer/context":[{"when":"config.npm.enableRunFromFolder && explorerViewletVisible && explorerResourceIsFolder && resourceScheme == file","command":"npm.runScriptFromFolder","group":"2_workspace"}]},"configuration":{"id":"npm","type":"object","title":"Npm","properties":{"npm.autoDetect":{"type":"string","enum":["off","on"],"default":"on","scope":"resource","description":"Xác định xem các tập lệnh npm có nên được tự động phát hiện hay không."},"npm.runSilent":{"type":"boolean","default":false,"scope":"resource","markdownDescription":"Chạy các lệnh npm với tùy chọn \"--silent\"."},"npm.packageManager":{"scope":"resource","type":"string","enum":["auto","npm","yarn","pnpm","bun"],"enumDescriptions":["Tự động phát hiện trình quản lý gói sẽ sử dụng dựa trên các file khóa và các trình quản lý gói đã cài đặt.","Sử dụng npm làm trình quản lý gói.","Sử dụng Yarn làm trình quản lý gói.","Sử dụng pnpm làm trình quản lý gói.","Sử dụng Bun làm trình quản lý gói."],"default":"auto","description":"Trình quản lý gói được sử dụng để cài đặt các phụ thuộc."},"npm.scriptRunner":{"scope":"resource","type":"string","enum":["auto","npm","yarn","pnpm","bun","node"],"enumDescriptions":["Tự động phát hiện trình thực thi script sẽ sử dụng dựa trên các file khóa và trình quản lý gói đã cài đặt.","Sử dụng npm làm trình thực thi script.","Sử dụng Yarn làm trình thực thi script.","Sử dụng PNPM làm trình thực thi script.","Sử dụng bun làm trình thực thi script.","Sử dụng Node.js làm trình thực thi script."],"default":"auto","description":"Trình thực thi script được sử dụng để chạy các script."},"npm.exclude":{"type":["string","array"],"items":{"type":"string"},"description":"Cấu hình mẫu toàn cục cho các thư mục cần loại trừ khỏi việc phát hiện script tự động.","scope":"resource"},"npm.enableScriptExplorer":{"type":"boolean","default":false,"scope":"resource","deprecationMessage":"The NPM Script Explorer is now available in 'Views' menu in the Explorer in all folders.","description":"Tính năng này kích hoạt chế độ xem Explorer cho các script npm khi không có file \"package.json\" ở cấp cao nhất."},"npm.enableRunFromFolder":{"type":"boolean","default":false,"scope":"resource","description":"Kích hoạt việc chạy các tập lệnh NPM nằm trong một thư mục từ menu ngữ cảnh của Explorer."},"npm.scriptExplorerAction":{"type":"string","enum":["open","run"],"markdownDescription":"Hành động nhấp chuột mặc định được sử dụng trong NPM Script Explorer: \"Mở\" (mặc định) hoặc \"Chạy\".","scope":"window","default":"open"},"npm.scriptExplorerExclude":{"type":"array","items":{"type":"string"},"markdownDescription":"Một mảng các biểu thức chính quy xác định script nào sẽ bị loại trừ khỏi chế độ xem NPM Script.","scope":"resource","default":[]},"npm.fetchOnlinePackageInfo":{"type":"boolean","description":"Truy xuất dữ liệu từ https://registry.npmjs.org và https://registry.bower.io để hỗ trợ tự động hoàn thành và cung cấp thông tin cho tính năng hover trên các phụ thuộc npm.","default":true,"scope":"window","tags":["usesOnlineServices"]},"npm.scriptHover":{"type":"boolean","description":"Hiển thị hover với các lệnh \"Chạy\" và \"Gỡ lỗi\" cho các script.","default":true,"scope":"window"}}},"jsonValidation":[{"fileMatch":"package.json","url":"https://www.schemastore.org/package"},{